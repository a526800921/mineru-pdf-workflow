#!/usr/bin/env bash
set -euo pipefail

# 优先使用隔离 venv 中的 mineru（兼容 transformers 4.57.x）
if [[ -d "$HOME/Documents/models/.venv/bin" ]]; then
  export PATH="$HOME/Documents/models/.venv/bin:$PATH"
fi

# --- ModelPad PDF 服务编排 ---
_this_file="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
source "${_this_file%/*}/lib/modelpad-pdf-service"

json_mode="${PDF_SEG_JSON:-0}"

log() {
  if [[ "$json_mode" == "1" ]]; then
    echo "$@" >&2
  else
    echo "$@"
  fi
}

usage() {
  cat <<'EOF'
用法:
  pdf-seg xxx.pdf
  pdf-seg /完整路径/xxx.pdf

说明:
  分段解析 PDF，默认每 1 页一段。
  每段输出到 PDF 所在目录的 segments/ 子目录：
  <PDF所在目录>/segments/p0001-0001/

可选环境变量:
  MINERU_SEGMENT_DIR=/path/to/segments  自定义分段输出目录（覆盖默认路径）
  MINERU_SEGMENT_SIZE=10
  MINERU_BACKEND=hybrid-engine|vlm-engine|pipeline
  MINERU_EFFORT=medium|high
  MINERU_METHOD=auto|txt|ocr
  MINERU_LANG=ch
  MINERU_PDF_RENDER_THREADS=2
  MINERU_PROCESSING_WINDOW_SIZE=10
  PDF_SEG_JSON=1                        输出机器可读 JSON（stdout），人类可读信息改到 stderr
EOF
}

# JSON 输出函数
emit_json() {
  local segments_dir="$1"
  local manifest_path="$2"
  local total_pages="$3"
  local segment_size="$4"
  shift 4
  # remaining args are segment_name:start_page:end_page tuples

  python3 - "$segments_dir" "$manifest_path" "$total_pages" "$segment_size" "$@" <<'PY'
import json, sys

segments_dir = sys.argv[1]
manifest_path = sys.argv[2]
total_pages = int(sys.argv[3])
segment_size = int(sys.argv[4])

segments = []
for arg in sys.argv[5:]:
    if not arg.strip():
        continue
    parts = arg.split(":")
    if len(parts) != 3:
        continue
    name, start, end = parts
    segments.append({
        "name": name,
        "start_page": int(start),
        "end_page": int(end),
        "status": "done",
    })

output = {
    "status": "completed",
    "total_pages": total_pages,
    "segment_size": segment_size,
    "segments_dir": segments_dir,
    "manifest_path": manifest_path,
    "segments": segments,
}
json.dump(output, sys.stdout, ensure_ascii=False, indent=2)
sys.stdout.write("\n")
PY
}

if [[ $# -ne 1 ]]; then
  if [[ "$json_mode" == "1" ]]; then
    usage >&2
    python3 -c 'import json, sys; json.dump({"status":"error","exit_code":2}, sys.stdout); sys.stdout.write("\n")'
  else
    usage
  fi
  exit 2
fi

input="$1"

if [[ "$input" == "-h" || "$input" == "--help" ]]; then
  if [[ "$json_mode" == "1" ]]; then
    usage >&2
  else
    usage
  fi
  exit 0
fi

if [[ ! -f "$input" ]]; then
  log "错误：找不到 PDF 文件：$input"
  if [[ "$json_mode" == "1" ]]; then
    python3 -c 'import json, sys; json.dump({"status":"error","exit_code":1}, sys.stdout); sys.stdout.write("\n")'
  fi
  exit 1
fi

case "$(printf '%s' "$input" | tr '[:upper:]' '[:lower:]')" in
  *.pdf) ;;
  *)
    log "错误：输入文件不是 PDF：$input"
    if [[ "$json_mode" == "1" ]]; then
      python3 -c 'import json, sys; json.dump({"status":"error","exit_code":1}, sys.stdout); sys.stdout.write("\n")'
    fi
    exit 1
    ;;
esac

pdf_path="$(cd "$(dirname "$input")" && pwd)/$(basename "$input")"
pdf_dir="$(dirname "$pdf_path")"
pdf_name="$(basename "$pdf_path")"
pdf_stem="${pdf_name%.*}"

segment_size="${MINERU_SEGMENT_SIZE:-1}"
backend="${MINERU_BACKEND:-hybrid-engine}"
effort="${MINERU_EFFORT:-medium}"
method="${MINERU_METHOD:-auto}"
lang="${MINERU_LANG:-ch}"

export MINERU_DEVICE_MODE="${MINERU_DEVICE_MODE:-mps}"
export MINERU_PDF_RENDER_THREADS="${MINERU_PDF_RENDER_THREADS:-2}"
export MINERU_API_MAX_CONCURRENT_REQUESTS="${MINERU_API_MAX_CONCURRENT_REQUESTS:-1}"
export MINERU_PROCESSING_WINDOW_SIZE="${MINERU_PROCESSING_WINDOW_SIZE:-$segment_size}"

# 检测或启动 PDF API 服务
ensure_pdf_api echo

if ! [[ "$segment_size" =~ ^[0-9]+$ ]] || [[ "$segment_size" -lt 1 ]]; then
  log "错误：MINERU_SEGMENT_SIZE 必须是正整数，当前是：$segment_size"
  if [[ "$json_mode" == "1" ]]; then
    python3 -c 'import json, sys; json.dump({"status":"error","exit_code":1}, sys.stdout); sys.stdout.write("\n")'
  fi
  exit 1
fi

pages="$(
  python - "$pdf_path" <<'PY'
import sys
try:
    import fitz
except Exception as exc:
    raise SystemExit(f"无法导入 PyMuPDF/fitz：{exc}")

doc = fitz.open(sys.argv[1])
print(doc.page_count)
PY
)"

if ! [[ "$pages" =~ ^[0-9]+$ ]] || [[ "$pages" -lt 1 ]]; then
  log "错误：无法读取 PDF 页数：$pdf_path"
  if [[ "$json_mode" == "1" ]]; then
    python3 -c 'import json, sys; json.dump({"status":"error","exit_code":1}, sys.stdout); sys.stdout.write("\n")'
  fi
  exit 1
fi

root_output_dir="${MINERU_SEGMENT_DIR:-$pdf_dir/segments}"
mkdir -p "$root_output_dir"

log "PDF: $pdf_path"
log "总页数: $pages"
log "每段页数: $segment_size"
log "输出根目录: $root_output_dir"
log "后端: $backend, method: $method, effort: $effort, lang: $lang"
log "API 服务: $api_url"
trap 'modelpad_stop_pdf_if_started log' EXIT
log

# 收集分段信息用于 JSON 输出
_seg_info=()

start=0
while [[ "$start" -lt "$pages" ]]; do
  end=$((start + segment_size - 1))
  [[ "$end" -ge "$pages" ]] && end=$((pages - 1))

  segment_name="$(printf 'p%04d-%04d' "$((start + 1))" "$((end + 1))")"
  segment_output_dir="$root_output_dir/$segment_name"

  log
  log "开始分段: $segment_name"
  log "输出目录: $segment_output_dir"

  {
    printf '\n===== %s =====\n' "$segment_name"
    printf '页码范围: %s-%s\n' "$start" "$end"
    printf '输出目录: %s\n\n' "$segment_output_dir"

    mineru \
        -p "$pdf_path" \
        -o "$segment_output_dir" \
        -b "$backend" \
        -m "$method" \
        --effort "$effort" \
        -l "$lang" \
        -s "$start" \
        -e "$end" \
        --api-url "$api_url"
  } 2>&1

  log "✓ 分段完成: $segment_name"
  _seg_info+=("${segment_name}:$((start + 1)):$((end + 1))")
  start=$((end + 1))
done

# 创建占位目录（为 V2 预留）
mkdir -p "$pdf_dir/images"
mkdir -p "$pdf_dir/data"

# 生成 manifest.json
manifest_path="$pdf_dir/manifest.json"
sha256="$(shasum -a 256 "$pdf_path" | awk '{print $1}')"
python3 - "$manifest_path" "$pdf_stem" "$pdf_path" "$pdf_name" "$sha256" <<'PY'
import json, sys
manifest_path = sys.argv[1]
model = sys.argv[2]
source_pdf = sys.argv[3]
pdf_name = sys.argv[4]
sha256 = sys.argv[5]

manifest = {
    "model": model,
    "version": None,
    "source_pdf": source_pdf,
    "files": {
        "pdf": pdf_name,
        "markdown": None,
        "review": None,
        "segments": "segments",
        "images": "images",
        "data": "data"
    },
    "hash": {
        "sha256": sha256
    },
    "parse_status": "segmented"
}
with open(manifest_path, "w", encoding="utf-8") as f:
    json.dump(manifest, f, ensure_ascii=False, indent=2)
    f.write("\n")
print(f"manifest: {manifest_path}", file=sys.stderr)
PY

log
log "全部分段完成。"
log "输出包根目录: $pdf_dir"
log "  segments: $root_output_dir"
log "  manifest: $manifest_path"

# JSON 模式：输出结构化 JSON 到 stdout
if [[ "$json_mode" == "1" ]]; then
  emit_json "$root_output_dir" "$manifest_path" "$pages" "$segment_size" "${_seg_info[@]}"
fi
