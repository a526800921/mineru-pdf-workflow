#!/usr/bin/env bash
set -euo pipefail

# 优先使用隔离 venv 中的 mineru（兼容 transformers 4.57.x）
if [[ -d "$HOME/Documents/models/.venv/bin" ]]; then
  export PATH="$HOME/Documents/models/.venv/bin:$PATH"
fi

# --- ModelPad PDF 服务编排 ---
_this_file="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
source "${_this_file%/*}/lib/modelpad-pdf-service"

json_mode="${PDF_SEG_JSON:-0}"

log() {
  if [[ "$json_mode" == "1" ]]; then
    echo "$@" >&2
  else
    echo "$@"
  fi
}

source "${_this_file%/*}/lib/segment-consistency"

usage() {
  cat <<'EOF'
用法:
  pdf-seg xxx.pdf
  pdf-seg /完整路径/xxx.pdf

说明:
  分段解析 PDF，默认每 1 页一段。
  每段输出到 PDF 所在目录的 segments/ 子目录：
  <PDF所在目录>/segments/p0001-0001/

可选环境变量:
  MINERU_SEGMENT_DIR=/path/to/segments  自定义分段输出目录（覆盖默认路径）
  MINERU_SEGMENT_SIZE=10
  MINERU_BACKEND=hybrid-engine|vlm-engine|pipeline
  MINERU_EFFORT=medium|high
  MINERU_METHOD=auto|txt|ocr
  MINERU_LANG=ch
  MINERU_PDF_RENDER_THREADS=2
  MINERU_PROCESSING_WINDOW_SIZE=10
  PDF_SEG_JSON=1                        输出机器可读 JSON（stdout），人类可读信息改到 stderr
EOF
}

# JSON 输出函数
emit_json() {
  local segments_dir="$1"
  local manifest_path="$2"
  local total_pages="$3"
  local segment_size="$4"
  shift 4
  # remaining args are segment_name:start_page:end_page tuples

  python3 - "$segments_dir" "$manifest_path" "$total_pages" "$segment_size" "$@" <<'PY'
import json, sys

segments_dir = sys.argv[1]
manifest_path = sys.argv[2]
total_pages = int(sys.argv[3])
segment_size = int(sys.argv[4])

segments = []
for arg in sys.argv[5:]:
    if not arg.strip():
        continue
    parts = arg.split(":")
    if len(parts) != 3:
        continue
    name, start, end = parts
    segments.append({
        "name": name,
        "start_page": int(start),
        "end_page": int(end),
        "status": "done",
    })

output = {
    "status": "completed",
    "total_pages": total_pages,
    "segment_size": segment_size,
    "segments_dir": segments_dir,
    "manifest_path": manifest_path,
    "segments": segments,
}
json.dump(output, sys.stdout, ensure_ascii=False, indent=2)
sys.stdout.write("\n")
PY
}

# 输出目录一致性检查
# 检查现有 segments/ 是否匹配当前 PDF 和运行配置
# 不一致时清理旧内容并返回非零退出码
_check_seg_consistency() {
  local seg_dir="$1" pdf="$2" pages="$3" seg_size="$4"
  local cur_backend="$5" cur_method="$6" cur_effort="$7" cur_lang="$8"
  local manifest="${seg_dir%/segments*}/manifest.json"

  # 无旧输出 → 干净状态
  if [[ ! -d "$seg_dir" ]] || [[ -z "$(ls -A "$seg_dir" 2>/dev/null)" ]]; then
    return 0
  fi

  # 无 manifest → 无法校验，清理
  if [[ ! -f "$manifest" ]]; then
    log "⚠ 旧输出包缺少 manifest.json，清理重建"
    rm -rf "$seg_dir"/*
    return 1
  fi

  # Python 校验
  local result
  result="$(python3 - "$manifest" "$pdf" "$pages" "$seg_size" "$cur_backend" "$cur_method" "$cur_effort" "$cur_lang" <<'PY'
import json, sys, hashlib
from pathlib import Path

manifest_path = sys.argv[1]
pdf_path = sys.argv[2]
current_pages = int(sys.argv[3])
current_seg_size = int(sys.argv[4])
cur_backend = sys.argv[5]
cur_method = sys.argv[6]
cur_effort = sys.argv[7]
cur_lang = sys.argv[8]

with open(manifest_path) as f:
    manifest = json.load(f)

reasons = []

# Verify PDF hash
old_hash = manifest.get("hash", {}).get("sha256", "")
if old_hash:
    with open(pdf_path, "rb") as f:
        new_hash = hashlib.sha256(f.read()).hexdigest()
    if old_hash != new_hash:
        reasons.append("PDF 文件变更 (SHA-256 不匹配)")

# Verify segmentation fingerprint
seg = manifest.get("segmentation", {})
if not seg:
    reasons.append("缺少 segmentation 指纹 (旧输出格式)")
else:
    if seg.get("total_pages") != current_pages:
        reasons.append(f"页数变更: {seg.get('total_pages')} -> {current_pages}")
    if seg.get("segment_size") != current_seg_size:
        reasons.append(f"分段大小变更: {seg.get('segment_size')} -> {current_seg_size}")
    mu = seg.get("mineru", {})
    if mu.get("backend") != cur_backend:
        reasons.append(f"backend 变更: {mu.get('backend')} -> {cur_backend}")
    if mu.get("method") != cur_method:
        reasons.append(f"method 变更: {mu.get('method')} -> {cur_method}")
    if mu.get("effort") != cur_effort:
        reasons.append(f"effort 变更: {mu.get('effort')} -> {cur_effort}")
    if mu.get("lang") != cur_lang:
        reasons.append(f"lang 变更: {mu.get('lang')} -> {cur_lang}")

# 单页模式下检查旧多页段残留
if current_seg_size == 1:
    seg_root = Path(manifest_path).parent / "segments"
    if seg_root.exists():
        for d in sorted(seg_root.iterdir()):
            if not d.is_dir() or not d.name.startswith("p"):
                continue
            parts = d.name[1:].split("-")
            if len(parts) == 2 and parts[0].isdigit() and parts[1].isdigit():
                if int(parts[1]) - int(parts[0]) > 0:
                    reasons.append(f"旧多页段残留: {d.name}")
                    break

        # Consecutive single-page directory completeness check
        seg_root = Path(manifest_path).parent / "segments"
        expected_pages = current_pages
        found_dirs = set()
        for d in sorted(seg_root.iterdir()):
            if d.is_dir() and d.name.startswith("p"):
                parts = d.name[1:].split("-")
                if len(parts) == 2 and parts[0].isdigit() and parts[1].isdigit():
                    s = int(parts[0]); e = int(parts[1])
                    if s == e:
                        found_dirs.add(s)
        if found_dirs:
            expected = set(range(1, expected_pages + 1))
            missing = expected - found_dirs
            extra = found_dirs - expected
            if missing:
                missing_str = ", ".join(str(p) for p in sorted(missing)[:10])
                if len(missing) > 10:
                    missing_str += f" ... (共 {len(missing)} 页)"
                reasons.append(f"缺少页面: {missing_str}")
            if extra:
                extra_str = ", ".join(str(p) for p in sorted(extra)[:5])
                reasons.append(f"多余页面: {extra_str}")

for reason in reasons:
    print(reason)

if reasons:
    sys.exit(1)
PY
)"
  local rc=$?

  if [[ $rc -ne 0 ]] || [[ -n "$result" ]]; then
    while IFS= read -r reason; do
      [[ -n "$reason" ]] && log "  - ${reason}"
    done <<< "$result"
    log "Cleaning old output, re-parsing"
    rm -rf "$seg_dir"/*
    return 1
  fi

  log "  Output directory consistency check passed"
  return 0
}

if [[ $# -ne 1 ]]; then
  if [[ "$json_mode" == "1" ]]; then
    usage >&2
    python3 -c 'import json, sys; json.dump({"status":"error","exit_code":2}, sys.stdout); sys.stdout.write("\n")'
  else
    usage
  fi
  exit 2
fi

input="$1"

if [[ "$input" == "-h" || "$input" == "--help" ]]; then
  if [[ "$json_mode" == "1" ]]; then
    usage >&2
  else
    usage
  fi
  exit 0
fi

if [[ ! -f "$input" ]]; then
  log "错误：找不到 PDF 文件：$input"
  if [[ "$json_mode" == "1" ]]; then
    python3 -c 'import json, sys; json.dump({"status":"error","exit_code":1}, sys.stdout); sys.stdout.write("\n")'
  fi
  exit 1
fi

case "$(printf '%s' "$input" | tr '[:upper:]' '[:lower:]')" in
  *.pdf) ;;
  *)
    log "错误：输入文件不是 PDF：$input"
    if [[ "$json_mode" == "1" ]]; then
      python3 -c 'import json, sys; json.dump({"status":"error","exit_code":1}, sys.stdout); sys.stdout.write("\n")'
    fi
    exit 1
    ;;
esac

pdf_path="$(cd "$(dirname "$input")" && pwd)/$(basename "$input")"
pdf_dir="$(dirname "$pdf_path")"
pdf_name="$(basename "$pdf_path")"
pdf_stem="${pdf_name%.*}"

segment_size="${MINERU_SEGMENT_SIZE:-1}"
backend="${MINERU_BACKEND:-hybrid-engine}"
effort="${MINERU_EFFORT:-medium}"
method="${MINERU_METHOD:-auto}"
lang="${MINERU_LANG:-ch}"

export MINERU_DEVICE_MODE="${MINERU_DEVICE_MODE:-mps}"
export MINERU_PDF_RENDER_THREADS="${MINERU_PDF_RENDER_THREADS:-2}"
export MINERU_API_MAX_CONCURRENT_REQUESTS="${MINERU_API_MAX_CONCURRENT_REQUESTS:-1}"
export MINERU_PROCESSING_WINDOW_SIZE="${MINERU_PROCESSING_WINDOW_SIZE:-$segment_size}"

# 检测或启动 PDF API 服务
ensure_pdf_api echo

if ! [[ "$segment_size" =~ ^[0-9]+$ ]] || [[ "$segment_size" -lt 1 ]]; then
  log "错误：MINERU_SEGMENT_SIZE 必须是正整数，当前是：$segment_size"
  if [[ "$json_mode" == "1" ]]; then
    python3 -c 'import json, sys; json.dump({"status":"error","exit_code":1}, sys.stdout); sys.stdout.write("\n")'
  fi
  exit 1
fi

pages="$(
  python - "$pdf_path" <<'PY'
import sys
try:
    import fitz
except Exception as exc:
    raise SystemExit(f"无法导入 PyMuPDF/fitz：{exc}")

doc = fitz.open(sys.argv[1])
print(doc.page_count)
PY
)"

if ! [[ "$pages" =~ ^[0-9]+$ ]] || [[ "$pages" -lt 1 ]]; then
  log "错误：无法读取 PDF 页数：$pdf_path"
  if [[ "$json_mode" == "1" ]]; then
    python3 -c 'import json, sys; json.dump({"status":"error","exit_code":1}, sys.stdout); sys.stdout.write("\n")'
  fi
  exit 1
fi

root_output_dir="${MINERU_SEGMENT_DIR:-$pdf_dir/segments}"
mkdir -p "$root_output_dir"

# 输出目录一致性检查：若旧输出与当前配置不一致则清理重建
check_segment_consistency "$root_output_dir" "$pdf_path" "$pages" "$segment_size" "$backend" "$method" "$effort" "$lang" || true

log "PDF: $pdf_path"
log "总页数: $pages"
log "每段页数: $segment_size"
log "输出根目录: $root_output_dir"
log "后端: $backend, method: $method, effort: $effort, lang: $lang"
log "API 服务: $api_url"
trap 'modelpad_stop_pdf_if_started log' EXIT
log

# 收集分段信息用于 JSON 输出
_seg_info=()

start=0
while [[ "$start" -lt "$pages" ]]; do
  end=$((start + segment_size - 1))
  [[ "$end" -ge "$pages" ]] && end=$((pages - 1))

  segment_name="$(printf 'p%04d-%04d' "$((start + 1))" "$((end + 1))")"
  segment_output_dir="$root_output_dir/$segment_name"

  log
  log "开始分段: $segment_name"
  log "输出目录: $segment_output_dir"

  {
    printf '\n===== %s =====\n' "$segment_name"
    printf '页码范围: %s-%s\n' "$start" "$end"
    printf '输出目录: %s\n\n' "$segment_output_dir"

    mineru \
        -p "$pdf_path" \
        -o "$segment_output_dir" \
        -b "$backend" \
        -m "$method" \
        --effort "$effort" \
        -l "$lang" \
        -s "$start" \
        -e "$end" \
        --api-url "$api_url"
  } 2>&1

  log "✓ 分段完成: $segment_name"
  _seg_info+=("${segment_name}:$((start + 1)):$((end + 1))")
  start=$((end + 1))
done

# 创建占位目录（为 V2 预留）
mkdir -p "$pdf_dir/images"
mkdir -p "$pdf_dir/data"

# 生成 manifest.json（含 segmentation 运行指纹供后续一致性检查）
manifest_path="$pdf_dir/manifest.json"
sha256="$(shasum -a 256 "$pdf_path" | awk '{print $1}')"
python3 - "$manifest_path" "$pdf_stem" "$pdf_path" "$pdf_name" "$sha256" "$segment_size" "$pages" "$backend" "$method" "$effort" "$lang" <<'PY'
import json, sys
manifest_path = sys.argv[1]
model = sys.argv[2]
source_pdf = sys.argv[3]
pdf_name = sys.argv[4]
sha256 = sys.argv[5]
segment_size = int(sys.argv[6])
total_pages = int(sys.argv[7])
backend = sys.argv[8]
method = sys.argv[9]
effort = sys.argv[10]
lang = sys.argv[11]

manifest = {
    "model": model,
    "version": None,
    "source_pdf": source_pdf,
    "files": {
        "pdf": pdf_name,
        "markdown": None,
        "review": None,
        "segments": "segments",
        "images": "images",
        "data": "data"
    },
    "hash": {
        "sha256": sha256
    },
    "segmentation": {
        "schema_version": 1,
        "layout": "single_page" if segment_size == 1 else "batch",
        "segment_size": segment_size,
        "total_pages": total_pages,
        "mineru": {
            "backend": backend,
            "method": method,
            "effort": effort,
            "lang": lang,
        }
    },
    "parse_status": "segmented"
}
with open(manifest_path, "w", encoding="utf-8") as f:
    json.dump(manifest, f, ensure_ascii=False, indent=2)
    f.write("\n")
print(f"manifest: {manifest_path}", file=sys.stderr)
PY

log
log "全部分段完成。"
log "输出包根目录: $pdf_dir"
log "  segments: $root_output_dir"
log "  manifest: $manifest_path"

# JSON 模式：输出结构化 JSON 到 stdout
if [[ "$json_mode" == "1" ]]; then
  emit_json "$root_output_dir" "$manifest_path" "$pages" "$segment_size" "${_seg_info[@]}"
fi
