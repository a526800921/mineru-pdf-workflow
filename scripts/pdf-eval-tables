#!/usr/bin/env bash
set -euo pipefail

_this_file="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
_scripts_dir="${_this_file%/*}"

json_mode="${PDF_EVAL_TABLES_JSON:-0}"

log() {
  if [[ "$json_mode" == "1" ]]; then
    echo "$@" >&2
  else
    echo "$@"
  fi
}

usage() {
  cat <<'EOF'
用法:
  pdf-eval-tables <package_dir> [output_path]

说明:
  对输出包 content_list.json（v1）的 table 元素做结构自检评测，产出
  <package>/data/table_accuracy.csv（每行一个表格，11 个字段）。
  属启发式（非 TEDS）：col_consistent / parse_status 标出列数不一致或解析异常的破损表。

参数:
  package_dir    输出包根目录（含 segments/ 和 <stem>.md）
  output_path    可选，默认输出到 <package>/data/table_accuracy.csv

可选环境变量:
  PDF_EVAL_TABLES_JSON=1    输出 JSON（stdout），人类可读信息改到 stderr
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  if [[ "$json_mode" == "1" ]]; then usage >&2; else usage; fi
  exit 0
fi

if [[ $# -lt 1 ]]; then
  if [[ "$json_mode" == "1" ]]; then
    usage >&2
    python3 -c 'import json,sys; json.dump({"status":"error","exit_code":2},sys.stdout); sys.stdout.write("\n")'
  else
    usage
  fi
  exit 2
fi

package_dir="$1"
output_path="${2:-}"

if [[ ! -d "$package_dir" ]]; then
  log "错误：输出包目录不存在：$package_dir"
  if [[ "$json_mode" == "1" ]]; then
    python3 -c 'import json,sys; json.dump({"status":"error","exit_code":1},sys.stdout); sys.stdout.write("\n")'
  fi
  exit 1
fi

package_dir="$(cd "$package_dir" && pwd)"

python3 - "$_scripts_dir" "$package_dir" "$output_path" "$json_mode" <<'PY'
import json, sys
from collections import Counter
from pathlib import Path

scripts_dir = Path(sys.argv[1])
sys.path.insert(0, str(scripts_dir))
from lib.table_eval import eval_package_tables

package_dir = Path(sys.argv[2])
output_path = sys.argv[3] if sys.argv[3] else None
json_mode = sys.argv[4] == "1"

try:
    rows, out_path = eval_package_tables(package_dir, output_path)
    counts = Counter(r["parse_status"] for r in rows)
    if json_mode:
        output = {
            "status": "completed",
            "table_count": len(rows),
            "status_counts": dict(counts),
            "output_path": str(out_path),
        }
        json.dump(output, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print(f"表格数: {len(rows)}")
        print(f"  ok={counts.get('ok',0)}, malformed={counts.get('malformed',0)}, "
              f"empty={counts.get('empty',0)}")
        print(f"输出: {out_path}")
        for r in rows[:5]:
            print(f"  {r['table_id']}: page={r['page']}, {r['row_count']}x{r['col_count']}, "
                  f"status={r['parse_status']}, section={r['section'][:20]}")
except FileNotFoundError as e:
    if json_mode:
        json.dump({"status": "error", "exit_code": 1, "error": str(e)},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print(f"错误：{e}", file=sys.stderr)
    sys.exit(1)
except Exception as e:
    if json_mode:
        json.dump({"status": "error", "exit_code": 1, "error": str(e)},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print(f"错误：{e}", file=sys.stderr)
    sys.exit(1)
PY
