#!/usr/bin/env bash
set -euo pipefail

# 优先使用隔离 venv 中的 mineru（兼容 transformers 4.57.x）
if [[ -d "$HOME/Documents/models/.venv/bin" ]]; then
  export PATH="$HOME/Documents/models/.venv/bin:$PATH"
fi

# --- ModelPad PDF 服务编排 ---
_this_file="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
_scripts_dir="${_this_file%/*}"
source "$_scripts_dir/lib/modelpad-pdf-service"

json_mode="${PDF_RERUN_JSON:-0}"

log() {
  if [[ "$json_mode" == "1" ]]; then
    echo "$@" >&2
  else
    echo "$@"
  fi
}

usage() {
  cat <<'EOF'
用法:
  pdf-rerun <pdf> <segments_dir> <页码|分段名>...

说明:
  对指定页高精度重跑 MinerU 解析，替换原分段结果，完成后自动合并。
  支持混合传入 PDF 页码（1-based）和分段名（p0000-0000）。

示例:
  pdf-rerun pdf/demo60/demo60.pdf pdf/demo60/segments 27 29 30
  pdf-rerun pdf/demo60/demo60.pdf pdf/demo60/segments p0026-0026 28

可选环境变量:
  MINERU_BACKEND=hybrid-engine
  MINERU_EFFORT=high        重跑精度默认 high
  MINERU_METHOD=auto
  MINERU_LANG=ch
  PDF_MERGE_OUTPUT           合并输出路径（默认自动推导）
  PDF_RERUN_JSON=1           输出机器可读 JSON（stdout），人类可读信息改到 stderr
EOF
}

# JSON 输出函数
emit_json() {
  local status="$1"
  local exit_code="$2"
  local rerun_count="$3"
  local merge_output="$4"
  shift 4
  # remaining args are result tuples: segment_name:start_page:end_page:seg_status

  python3 - "$status" "$exit_code" "$rerun_count" "$merge_output" "$@" <<'PY'
import json, sys

status = sys.argv[1]
exit_code = int(sys.argv[2])
rerun_count = int(sys.argv[3])
merge_output = sys.argv[4] if sys.argv[4] and sys.argv[4] != "none" else None

results = []
for arg in sys.argv[5:]:
    if not arg.strip():
        continue
    parts = arg.split(":")
    if len(parts) != 4:
        continue
    name, start, end, seg_status = parts
    results.append({
        "name": name,
        "start_page": int(start),
        "end_page": int(end),
        "status": seg_status,
    })

output = {
    "status": status,
    "exit_code": exit_code,
    "rerun_count": rerun_count,
    "merged_markdown": merge_output,
    "segments": results,
}
json.dump(output, sys.stdout, ensure_ascii=False, indent=2)
sys.stdout.write("\n")
PY
}

if [[ $# -lt 3 ]]; then
  if [[ "$json_mode" == "1" ]]; then
    usage >&2
    python3 -c 'import json, sys; json.dump({"status":"error","exit_code":2}, sys.stdout); sys.stdout.write("\n")'
  else
    usage
  fi
  exit 2
fi

pdf="$1"
shift
segments_dir="$1"
shift

if [[ "$pdf" == "-h" || "$pdf" == "--help" ]]; then
  if [[ "$json_mode" == "1" ]]; then
    usage >&2
  else
    usage
  fi
  exit 0
fi

if [[ ! -f "$pdf" ]]; then
  log "错误：找不到 PDF 文件：$pdf"
  if [[ "$json_mode" == "1" ]]; then
    emit_json "error" 1 0 "" ""
  fi
  exit 1
fi

if [[ ! -d "$segments_dir" ]]; then
  log "错误：找不到分段目录：$segments_dir"
  if [[ "$json_mode" == "1" ]]; then
    emit_json "error" 1 0 "" ""
  fi
  exit 1
fi

pdf_path="$(cd "$(dirname "$pdf")" && pwd)/$(basename "$pdf")"
segments_dir="$(cd "$segments_dir" && pwd)"
pdf_stem="$(basename "$pdf_path" .pdf)"

backend="${MINERU_BACKEND:-hybrid-engine}"
effort="${MINERU_EFFORT:-high}"
method="${MINERU_METHOD:-auto}"
lang="${MINERU_LANG:-ch}"

export MINERU_DEVICE_MODE="${MINERU_DEVICE_MODE:-mps}"
export MINERU_PDF_RENDER_THREADS="${MINERU_PDF_RENDER_THREADS:-2}"
export MINERU_API_MAX_CONCURRENT_REQUESTS="${MINERU_API_MAX_CONCURRENT_REQUESTS:-1}"
export MINERU_PROCESSING_WINDOW_SIZE="${MINERU_PROCESSING_WINDOW_SIZE:-8}"

# 自动检测 API 端口
ensure_pdf_api echo

trap 'modelpad_stop_pdf_if_started log' EXIT

log "PDF: $pdf_path"
log "分段目录: $segments_dir"
log "精度: $effort, 后端: $backend"
[[ -n "$api_url" ]] && log "API: $api_url"

rerun_count=0
# 收集结果用于 JSON 输出
_rerun_results=()
# 已处理的段名集合（去重：多页码映射到同段时只跑一次，空格分隔兼容 bash 3.2）
_seen_list=""

for target in "$@"; do
  if [[ "$target" =~ ^p[0-9]{4,}-[0-9]{4,}$ ]]; then
    # 分段名：p0001-0020（1-based，对齐 PDF 页码）
    seg_name="$target"
    seg_dir="$segments_dir/$seg_name"
    if [[ ! -d "$seg_dir" ]]; then
      log "  ✗ 分段不存在：$seg_name，跳过"
      _rerun_results+=("${seg_name}:0:0:skipped")
      continue
    fi
    start_page="${seg_name#p}"
    start_page="${start_page%-*}"
    start_page=$((10#${start_page}))
    end_page="${seg_name##*-}"
    end_page=$((10#${end_page}))
  elif [[ "$target" =~ ^[0-9]+$ ]]; then
    # 页码（1-based）→ 找到对应分段（分段名已 1-based）
    seg_dir=""
    for d in "$segments_dir"/p*-*; do
      [[ -d "$d" ]] || continue
      name="$(basename "$d")"
      s="${name#p}"; s="${s%-*}"; s=$((10#${s}))
      e="${name##*-}"; e=$((10#${e}))
      if [[ $target -ge $s && $target -le $e ]]; then
        seg_dir="$d"
        seg_name="$name"
        start_page=$s
        end_page=$e
        break
      fi
    done
    if [[ -z "$seg_dir" ]]; then
      log "  ✗ 页码 ${target} 无对应分段，跳过"
      _rerun_results+=("page_${target}:0:0:skipped")
      continue
    fi
  else
    log "  ✗ 无法识别：$target（需要页码或 p0000-0000 分段名），跳过"
    continue
  fi

  # 去重：同一段被多次引用只跑一次
  if [[ " $_seen_list " == *" $seg_name "* ]]; then
    log "  - ${seg_name}: 已处理，跳过重复引用"
    continue
  fi
  _seen_list="$_seen_list $seg_name"

  log
  log "重跑: $seg_name (PDF 第 ${start_page} 页)"
  rm -rf "$seg_dir"
  mkdir -p "$seg_dir"

  _api_arg=(--api-url "$api_url")

  # mineru uses 0-based page indices
  if mineru \
    -p "$pdf_path" \
    -o "$seg_dir" \
    -b "$backend" \
    -m "$method" \
    --effort "$effort" \
    -l "$lang" \
    -s "$((start_page - 1))" \
    -e "$((end_page - 1))" \
    "${_api_arg[@]}" >/dev/null 2>&1; then
    # 检查生成了 md 文件
    find_md="$(find "$seg_dir" -name "*.md" -type f | head -1)"
    if [[ -n "$find_md" && -f "$find_md" ]]; then
      cp "$find_md" "$seg_dir/${pdf_stem}.md"
      log "  ✓ 完成"
      rerun_count=$((rerun_count + 1))
      _rerun_results+=("${seg_name}:${start_page}:${end_page}:done")
    else
      log "  ✗ 完成但无 Markdown 输出"
      _rerun_results+=("${seg_name}:${start_page}:${end_page}:no_markdown")
    fi
  else
    log "  ✗ 失败"
    _rerun_results+=("${seg_name}:${start_page}:${end_page}:failed")
  fi
done

log
log "重跑完成: $rerun_count 段"


# 自动合并
log
log "=== 合并 ==="
"$_scripts_dir/pdf-merge" "$segments_dir"

# JSON 模式：输出结构化 JSON 到 stdout
if [[ "$json_mode" == "1" ]]; then
  _pkg_dir="$(dirname "$segments_dir")"
  merge_out="${PDF_MERGE_OUTPUT:-$_pkg_dir/${pdf_stem}.md}"
  emit_json "completed" 0 "$rerun_count" "$merge_out" "${_rerun_results[@]}"
fi
