#!/usr/bin/env bash
set -euo pipefail

# 优先使用隔离 venv 中的 mineru（兼容 transformers 4.57.x）
if [[ -d "$HOME/Documents/models/.venv/bin" ]]; then
  export PATH="$HOME/Documents/models/.venv/bin:$PATH"
fi

# --- ModelPad PDF 服务编排 ---
_this_file="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
_scripts_dir="${_this_file%/*}"
source "$_scripts_dir/lib/modelpad-pdf-service"

json_mode="${PDF_RERUN_JSON:-0}"

log() {
  if [[ "$json_mode" == "1" ]]; then
    echo "$@" >&2
  else
    echo "$@"
  fi
}

usage() {
  cat <<'EOF'
用法:
  pdf-rerun <pdf> <segments_dir> <页码|分段名>...

说明:
  对指定页高精度重跑 MinerU 解析，替换原分段结果，完成后自动合并。
  支持混合传入 PDF 页码（1-based）和分段名（p0000-0000）。

示例:
  pdf-rerun pdf/demo60/demo60.pdf pdf/demo60/segments 27 29 30
  pdf-rerun pdf/demo60/demo60.pdf pdf/demo60/segments p0026-0026 28

可选环境变量:
  MINERU_BACKEND=hybrid-engine
  MINERU_EFFORT=high        重跑精度默认 high
  MINERU_METHOD=auto
  MINERU_LANG=ch
  PDF_MERGE_OUTPUT           合并输出路径（默认自动推导）
  PDF_RERUN_JSON=1           输出机器可读 JSON（stdout），人类可读信息改到 stderr
EOF
}

# JSON 输出函数
emit_json() {
  local status="$1"
  local exit_code="$2"
  local rerun_count="$3"
  local merge_output="$4"
  shift 4
  # remaining args are result tuples: segment_name:start_page:end_page:seg_status[:restored:final_source]

  python3 - "$status" "$exit_code" "$rerun_count" "$merge_output" "$@" <<'PY'
import json, sys

status = sys.argv[1]
exit_code = int(sys.argv[2])
rerun_count = int(sys.argv[3])
merge_output = sys.argv[4] if sys.argv[4] and sys.argv[4] != "none" else None

results = []
for arg in sys.argv[5:]:
    if not arg.strip():
        continue
    parts = arg.split(":")
    name, start, end = parts[0], parts[1], parts[2]
    seg_status = parts[3] if len(parts) > 3 else "unknown"
    restored = parts[4].lower() == "true" if len(parts) > 4 else False
    final_source = parts[5] if len(parts) > 5 else "rerun"
    results.append({
        "name": name,
        "start_page": int(start),
        "end_page": int(end),
        "status": seg_status,
        "restored": restored,
        "final_source": final_source,
    })

output = {
    "status": status,
    "exit_code": exit_code,
    "rerun_count": rerun_count,
    "merged_markdown": merge_output,
    "segments": results,
}
json.dump(output, sys.stdout, ensure_ascii=False, indent=2)
sys.stdout.write("\n")
PY
}

if [[ $# -lt 3 ]]; then
  if [[ "$json_mode" == "1" ]]; then
    usage >&2
    python3 -c 'import json, sys; json.dump({"status":"error","exit_code":2}, sys.stdout); sys.stdout.write("\n")'
  else
    usage
  fi
  exit 2
fi

pdf="$1"
shift
segments_dir="$1"
shift

if [[ "$pdf" == "-h" || "$pdf" == "--help" ]]; then
  if [[ "$json_mode" == "1" ]]; then
    usage >&2
  else
    usage
  fi
  exit 0
fi

if [[ ! -f "$pdf" ]]; then
  log "错误：找不到 PDF 文件：$pdf"
  if [[ "$json_mode" == "1" ]]; then
    emit_json "error" 1 0 "" ""
  fi
  exit 1
fi

if [[ ! -d "$segments_dir" ]]; then
  log "错误：找不到分段目录：$segments_dir"
  if [[ "$json_mode" == "1" ]]; then
    emit_json "error" 1 0 "" ""
  fi
  exit 1
fi

pdf_path="$(cd "$(dirname "$pdf")" && pwd)/$(basename "$pdf")"
segments_dir="$(cd "$segments_dir" && pwd)"
pdf_stem="$(basename "$pdf_path" .pdf)"

backend="${MINERU_BACKEND:-hybrid-engine}"
effort="${MINERU_EFFORT:-high}"
method="${MINERU_METHOD:-auto}"
lang="${MINERU_LANG:-ch}"

export MINERU_DEVICE_MODE="${MINERU_DEVICE_MODE:-mps}"
export MINERU_PDF_RENDER_THREADS="${MINERU_PDF_RENDER_THREADS:-2}"
export MINERU_API_MAX_CONCURRENT_REQUESTS="${MINERU_API_MAX_CONCURRENT_REQUESTS:-1}"
export MINERU_PROCESSING_WINDOW_SIZE="${MINERU_PROCESSING_WINDOW_SIZE:-8}"

# 自动检测 API 端口
ensure_pdf_api echo

trap 'modelpad_stop_pdf_if_started log' EXIT

log "PDF: $pdf_path"
log "分段目录: $segments_dir"
log "精度: $effort, 后端: $backend"
[[ -n "$api_url" ]] && log "API: $api_url"

rerun_count=0
# 收集结果用于 JSON 输出
_rerun_results=()
# 已处理的段名集合（去重：多页码映射到同段时只跑一次，空格分隔兼容 bash 3.2）
_seen_list=""

for target in "$@"; do
  if [[ "$target" =~ ^p[0-9]{4,}-[0-9]{4,}$ ]]; then
    # 分段名：p0001-0020（1-based，对齐 PDF 页码）
    seg_name="$target"
    seg_dir="$segments_dir/$seg_name"
    start_page="${seg_name#p}"
    start_page="${start_page%-*}"
    start_page=$((10#${start_page}))
    end_page="${seg_name##*-}"
    end_page=$((10#${end_page}))
    # 单页模式下拒绝多页段名
    if [[ $start_page -ne $end_page ]]; then
      log "  ✗ 多页段名 ${seg_name} 不再支持。请使用单页段名（如 p0001-0001）或页码。"
      _rerun_results+=("${seg_name}:${start_page}:${end_page}:skipped:false:none")
      continue
    fi
    # 安全处理残留 backup（在 seg_dir 检查之前，确保 backup 可还原）
    _backup_dir="${seg_dir}.backup"
    if [[ -d "$_backup_dir" ]]; then
      if [[ -d "$seg_dir" ]]; then
        # seg_dir 存在 → backup 是陈旧的，清理
        log "  ⚠ 清除陈旧残留备份: $_backup_dir"
        rm -rf "$_backup_dir"
      else
        # seg_dir 不存在且 backup 存在 → 还原唯一原始数据
        log "  ℹ 还原上次中断的备份: $_backup_dir → $seg_name"
        mv "$_backup_dir" "$seg_dir"
      fi
    fi
    # 若无 seg_dir 也无 backup，则创建全新分段（直接段名输入视为合法操作）
    if [[ ! -d "$seg_dir" ]]; then
      log "  ℹ 创建新分段: $seg_name"
      mkdir -p "$seg_dir"
    fi
  elif [[ "$target" =~ ^[0-9]+$ ]]; then
    # 页码（1-based）→ 找到对应分段，优先精确匹配单页段
    seg_dir=""
    multi_seg_dir=""
    multi_seg_name=""
    multi_start=0
    multi_end=0
    for d in "$segments_dir"/p*-*; do
      [[ -d "$d" ]] || continue
      name="$(basename "$d")"
      s="${name#p}"; s="${s%-*}"; s=$((10#${s}))
      e="${name##*-}"; e=$((10#${e}))
      if [[ $target -ge $s && $target -le $e ]]; then
        if [[ $s -eq $e ]]; then
          # 精确匹配单页段 → 立即使用
          seg_dir="$d"
          seg_name="$name"
          start_page=$s
          end_page=$e
          multi_seg_dir=""
          break
        elif [[ -z "$multi_seg_dir" ]]; then
          # 记录第一个匹配的多页段作为 fallback
          multi_seg_dir="$d"
          multi_seg_name="$name"
          multi_start=$s
          multi_end=$e
        fi
      fi
    done

    if [[ -z "$seg_dir" ]]; then
      if [[ -n "$multi_seg_dir" ]]; then
        log "  ✗ 页码 ${target} 落在多页段 ${multi_seg_name} (${multi_start}-${multi_end}) 中。输出目录含多页段残留，请先清空 segments/ 后重新运行 pdf-seg。"
        _rerun_results+=("page_${target}:0:0:skipped:false:none")
        continue
      else
        log "  ✗ 页码 ${target} 无对应分段，跳过"
        _rerun_results+=("page_${target}:0:0:skipped")
        continue
      fi
    fi
  else
    log "  ✗ 无法识别：${target}（需要页码或 p0000-0000 分段名），跳过"
    continue
  fi

  # 去重：同一段被多次引用只跑一次
  if [[ " $_seen_list " == *" $seg_name "* ]]; then
    log "  - ${seg_name}: 已处理，跳过重复引用"
    continue
  fi
  _seen_list="$_seen_list $seg_name"

  log
  log "重跑: $seg_name (PDF 第 ${start_page} 页)"
  # 备份原段，重跑成功则删除备份，失败则恢复
  _backup_dir="${seg_dir}.backup"
  # 安全处理残留 backup
  if [[ -d "$_backup_dir" ]]; then
    if [[ -d "$seg_dir" ]]; then
      # seg_dir 存在 → backup 是陈旧的，清理
      log "  ⚠ 清除陈旧残留备份: $_backup_dir"
      rm -rf "$_backup_dir"
    else
      # seg_dir 不存在且 backup 存在 → 还原唯一原始数据
      log "  ℹ 还原上次中断的备份: $_backup_dir → $seg_name"
      mv "$_backup_dir" "$seg_dir"
    fi
  fi
  # 是否实际做了备份（用于判断最终来源）
  _had_backup=false
  if [[ -d "$seg_dir" ]]; then
    mv "$seg_dir" "$_backup_dir"
    _had_backup=true
  fi
  mkdir -p "$seg_dir"

  _api_arg=(--api-url "$api_url")

  # 重跑结果状态变量（在恢复处理后才写入结果数组）
  _seg_executed=true
  _seg_status="failed"
  _rerun_ok=false
  # mineru uses 0-based page indices
  if mineru \
    -p "$pdf_path" \
    -o "$seg_dir" \
    -b "$backend" \
    -m "$method" \
    --effort "$effort" \
    -l "$lang" \
    -s "$((start_page - 1))" \
    -e "$((end_page - 1))" \
    "${_api_arg[@]}" >/dev/null 2>&1; then
    # 检查生成了 md 文件
    find_md="$(find "$seg_dir" -name "*.md" -type f | head -1)"
    if [[ -n "$find_md" && -f "$find_md" ]]; then
      cp "$find_md" "$seg_dir/${pdf_stem}.md"
      # 同步全部 MinerU 输出产物到段根目录（保正文与中间结构同源）
      _find_mineru_dir="$(dirname "$find_md")"
      if [[ "$_find_mineru_dir" != "$seg_dir" ]]; then
        # content_list v1 + v2
        for _cl in "$_find_mineru_dir"/*_content_list*.json; do
          [[ -f "$_cl" ]] && cp "$_cl" "$seg_dir/"
        done
        # middle.json / model.json
        [[ -f "$_find_mineru_dir/middle.json" ]] && cp "$_find_mineru_dir/middle.json" "$seg_dir/"
        [[ -f "$_find_mineru_dir/model.json" ]] && cp "$_find_mineru_dir/model.json" "$seg_dir/"
        # images 目录
        [[ -d "$_find_mineru_dir/images" ]] && cp -a "$_find_mineru_dir/images" "$seg_dir/"
      fi
      unset _find_mineru_dir _cl
      log "  ✓ 完成"
      rerun_count=$((rerun_count + 1))
      _seg_status="done"
      _rerun_ok=true
    else
      log "  ✗ 完成但无 Markdown 输出"
      _seg_status="no_markdown"
    fi
  else
    log "  ✗ 失败"
    _seg_status="failed"
  fi

  # 恢复处理：重跑成功则清理备份，失败则恢复原始
  # 同时确定 restored 和 final_source
  _seg_restored=false
  _seg_final_source="rerun"
  if $_rerun_ok; then
    rm -rf "$_backup_dir"
    _seg_restored=false
    _seg_final_source="rerun"
  else
    rm -rf "$seg_dir"
    if $_had_backup && [[ -d "$_backup_dir" ]]; then
      mv "$_backup_dir" "$seg_dir"
      log "  ℹ 已恢复原始段: $seg_name"
      _seg_restored=true
      _seg_final_source="original"
    else
      # 无备份可恢复（原始目录本不存在）
      _seg_restored=false
      _seg_final_source="none"
    fi
  fi
  # 写入结果数组（含 restored 和 final_source）
  _rerun_results+=("${seg_name}:${start_page}:${end_page}:${_seg_status}:${_seg_restored}:${_seg_final_source}")
  unset _rerun_ok _backup_dir _had_backup _seg_executed _seg_status _seg_restored _seg_final_source
done

log
log "重跑完成: $rerun_count 段"


# 自动合并（JSON 模式下输出到 stderr，避免污染 stdout）
log
log "=== 合并 ==="
if [[ "$json_mode" == "1" ]]; then
  "$_scripts_dir/pdf-merge" "$segments_dir" >&2 || true
else
  "$_scripts_dir/pdf-merge" "$segments_dir"
fi

# JSON 模式：输出结构化 JSON 到 stdout
if [[ "$json_mode" == "1" ]]; then
  _pkg_dir="$(dirname "$segments_dir")"
  merge_out="${PDF_MERGE_OUTPUT:-$_pkg_dir/${pdf_stem}.md}"
  emit_json "completed" 0 "$rerun_count" "$merge_out" "${_rerun_results[@]}"
fi
