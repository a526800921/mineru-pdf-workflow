#!/usr/bin/env bash
set -euo pipefail

# 优先使用隔离 venv 中的 mineru（兼容 transformers 4.57.x）
if [[ -d "$HOME/Documents/models/.venv/bin" ]]; then
  export PATH="$HOME/Documents/models/.venv/bin:$PATH"
fi

# --- JSON mode infrastructure ---
json_mode="${PDF_AUTO_JSON:-0}"

# Temp file for rerun segment name tracking (cleanup added to existing traps in Task 2)
_rerun_names_file="$(mktemp)"

# In JSON mode, silence subprocess stdout to /dev/null (prevent polluting JSON output)
if [[ "$json_mode" == "1" ]]; then
  _subprocess_stdout="/dev/null"
else
  _subprocess_stdout="/dev/stdout"
fi

# Human-readable log: stderr in JSON mode, stdout otherwise
log() {
  if [[ "$json_mode" == "1" ]]; then
    echo "$@" >&2
  else
    echo "$@"
  fi
}

# Emit final JSON to stdout
emit_json() {
  local status="$1"
  local exit_code="$2"
  local merged_path="${3:-}"
  local review_path="${4:-}"
  local validate_tmp="${5:-}"

  python3 - "$status" "$exit_code" "$merged_path" "$review_path" "$validate_tmp" "$_rerun_names_file" <<'PY'
import json, sys

status = sys.argv[1]
exit_code = int(sys.argv[2])
merged = sys.argv[3] if sys.argv[3] else None
review = sys.argv[4] if sys.argv[4] else None

# Read rerun names
rerun_names = set()
rerun_names_file = sys.argv[6]
if rerun_names_file:
    try:
        with open(rerun_names_file) as f:
            rerun_names = {line.strip() for line in f if line.strip()}
    except Exception:
        pass

# Read validation JSON to get rerun segment statuses
rerun_segments = []
validate_tmp = sys.argv[5]
if validate_tmp and rerun_names:
    try:
        with open(validate_tmp) as f:
            report = json.load(f)
        for seg in report.get("segments", []):
            if seg["name"] in rerun_names:
                rerun_segments.append({"name": seg["name"], "status": seg["status"]})
    except Exception:
        pass

output = {
    "status": status,
    "exit_code": exit_code,
    "merged_markdown": merged,
    "review_markdown": review,
    "rerun_segments": rerun_segments,
}
json.dump(output, sys.stdout, ensure_ascii=False, indent=2)
sys.stdout.write("\n")
PY
}
# --- end JSON mode infrastructure ---

# Update manifest.json parse_status and file fields
# Usage: update_manifest <status> [merged_md] [review_md]
update_manifest() {
  local status="$1"
  local merged="${2:-}"
  local review="${3:-}"
  local manifest="$(dirname "$segments_dir")/manifest.json"
  if [[ ! -f "$manifest" ]]; then
    return 0
  fi
  python3 - "$manifest" "$status" "$merged" "$review" <<'PY'
import json, sys
manifest_path = sys.argv[1]
status = sys.argv[2]
merged = sys.argv[3] if sys.argv[3] else None
review = sys.argv[4] if sys.argv[4] else None
with open(manifest_path) as f:
    m = json.load(f)
m["parse_status"] = status
if merged:
    m["files"]["markdown"] = merged
if review:
    m["files"]["review"] = review
with open(manifest_path, "w", encoding="utf-8") as f:
    json.dump(m, f, ensure_ascii=False, indent=2)
    f.write("\n")
PY
}

usage() {
  cat <<'EOF'
用法:
  pdf-auto 原始.pdf <package>/segments

说明:
  逐页验证覆盖率、对可疑段高精度重跑、再验证。
  如果全部通过则直接合并；如果仍有未通过段则输出人工兜底清单，不合并。
  默认合并输出：<package>/<原始PDF文件名>.md

可选环境变量:
  PDF_VALIDATE_THRESHOLD=0.82    覆盖率阈值
  MINERU_RERUN_EFFORT=high       重跑精度
  PDF_AUTO_MERGE_OUTPUT           合并输出路径（覆盖默认路径）
  PDF_AUTO_JSON=1                输出机器可读 JSON（stdout），人类可读信息改到 stderr
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  if [[ "$json_mode" == "1" ]]; then
    usage >&2
  else
    usage
  fi
  exit 0
fi

if [[ $# -ne 2 ]]; then
  if [[ "$json_mode" == "1" ]]; then
    emit_json "error" 1 "" "" ""
    usage >&2
  else
    usage
  fi
  exit 1
fi

pdf="$1"
segments_dir="$2"

if [[ ! -f "$pdf" ]]; then
  if [[ "$json_mode" == "1" ]]; then
    emit_json "error" 1 "" "" ""
  fi
  echo "错误：找不到 PDF 文件：$pdf" >&2
  exit 1
fi

if [[ ! -d "$segments_dir" ]]; then
  if [[ "$json_mode" == "1" ]]; then
    emit_json "error" 1 "" "" ""
  fi
  echo "错误：找不到分段目录：$segments_dir" >&2
  exit 1
fi

pdf_path="$(cd "$(dirname "$pdf")" && pwd)/$(basename "$pdf")"
segments_dir="$(cd "$segments_dir" && pwd)"

threshold="${PDF_VALIDATE_THRESHOLD:-0.82}"
rerun_effort="${MINERU_RERUN_EFFORT:-high}"
# 自动检测可用 API 端口
api_base="${MINERU_API_BASE_PORT:-9000}"
api_url=""
for ((_p=0; _p<3; _p++)); do
  _port=$((api_base + _p))
  if lsof -i ":$_port" -sTCP:LISTEN >/dev/null 2>&1; then
    api_url="http://127.0.0.1:$_port"
    break
  fi
done

log "pdf-auto: $pdf_path"
log "分段目录: $segments_dir"
log "阈值: $threshold"
log "重跑精度: $rerun_effort"

# 清理上次运行可能残留的 rerun 目录
for _d in "$segments_dir"/*-rerun/; do
  [[ -d "$_d" ]] || continue
  log "清理残留重跑目录: $(basename "$_d")"
  rm -rf "$_d"
done

# 提取 PDF 文件名（无扩展名） 用于自动推导合并输出
pdf_stem="$(basename "$pdf_path" .pdf)"

# --- 第一次验证 ---
log
log "=== 第一次验证 ==="

# 临时文件保存 pdf-validate 的 JSON 输出
validate_tmp="$(mktemp)"
trap 'rm -f "$validate_tmp" "$_rerun_names_file"; _d="$(cd "$(dirname "$0")" && pwd)"; rm -rf "$(dirname "$_d")/output"' EXIT

# JSON 模式：stdout=JSON, stderr=人可读
PDF_VALIDATE_JSON=1 scripts/pdf-validate "$pdf_path" "$segments_dir" >"$validate_tmp" 2>/dev/null || true

# Python 解析 JSON，输出 "merge" 或 "rerun" 到 stdout，日志到 stderr
action="$(python3 - "$threshold" "$validate_tmp" <<'PY'
import json
import sys

threshold = float(sys.argv[1])
report_path = sys.argv[2]

with open(report_path) as f:
    content = f.read()
if not content or not content.strip().startswith('{'):
    print(f"pdf-validate 输出异常（非 JSON）：\n{content}", file=sys.stderr)
    sys.exit(1)
report = json.loads(content)

segments = report["segments"]
ok_count = sum(1 for s in segments if s["status"] == "passed")
rerunnable = [s for s in segments if s.get("rerunnable", False)]
review_only = [s for s in segments if s.get("decision") == "review_only"]

print(f"通过: {ok_count} 段", file=sys.stderr)
print(f"需重跑: {len(rerunnable)} 段", file=sys.stderr)
if review_only:
    print(f"需人工复核: {len(review_only)} 段", file=sys.stderr)

if not rerunnable:
    for s in segments:
        decision = s.get("decision", s.get("status", "?"))
        reason = s.get("reason", "")
        note = f" ({reason})" if reason else ""
        print(f"  [{decision}] {s['name']}: 覆盖率 {s.get('coverage', 'N/A')}{note}", file=sys.stderr)
    if review_only:
        print("needs_review")
    else:
        print("merge")
else:
    for s in rerunnable:
        print(f"  需重跑: {s['name']} (覆盖率 {s.get('coverage', 'N/A')})", file=sys.stderr)
    print("rerun")
PY
)" || {
  if [[ "$json_mode" == "1" ]]; then
    emit_json "error" 1 "" "" ""
  fi
  update_manifest "error" "" ""
  exit 1
}

if [[ "$action" == "merge" ]]; then
  merge_output="${PDF_AUTO_MERGE_OUTPUT:-$(dirname "$segments_dir")/${pdf_stem}.md}"
  log "全部通过，开始合并..."

  # --- TOC 段修复：用 PDF 文本层重生成目录页 Markdown ---
  log "检查 TOC 页..."
  python3 - "$pdf_path" "$segments_dir" "$validate_tmp" <<'PY'
import json, re, sys
from collections import OrderedDict
from pathlib import Path

try:
    import fitz
except Exception:
    print("TOC 修复跳过：PyMuPDF 不可用", file=sys.stderr)
    sys.exit(0)

pdf_path = Path(sys.argv[1])
segments_dir = Path(sys.argv[2])
validate_tmp = sys.argv[3]

with open(validate_tmp) as f:
    report = json.load(f)

# 找到所有 TOC 段
toc_segs = []
for seg in report["segments"]:
    summary = seg.get("page_type_summary", {})
    if summary.get("toc", 0) > 0:
        toc_segs.append(seg)

if not toc_segs:
    sys.exit(0)

doc = fitz.open(pdf_path)

TITLE_DOTS = re.compile(r'^(\S.+?)\s*[.]{3,}\s*$')
DOTS_NUM = re.compile(r'^\s*[.]{3,}\s*(\d+)\s*$')

fixed_count = 0
for seg in toc_segs:
    seg_dir = segments_dir / seg["name"]
    md_files = sorted(seg_dir.rglob("*.md"))
    if not md_files:
        continue
    md_path = md_files[0]

    # 从 PDF 文本层提取条目
    pdf_lines = []
    for p in range(seg["start_page"] - 1, min(seg["end_page"], doc.page_count)):
        pdf_lines.append(doc[p].get_text())
    pdf_text = "\n".join(pdf_lines)

    lines = [l.strip() for l in pdf_text.strip().split('\n') if l.strip()]
    entries = OrderedDict()

    entries = []  # list of (title, page_ref)
    prev_key = None
    for i in range(len(lines) - 1):
        title_m = TITLE_DOTS.match(lines[i])
        num_m = DOTS_NUM.match(lines[i + 1])
        if title_m and num_m:
            title = title_m.group(1).strip()
            page_ref = num_m.group(1)
            if len(title) >= 2 and not title.isdigit():
                # 去相邻完全重复（PDF 排版导致同一行出现两次），
                # 同名但不同页码的条目保留（如"左手把开关 35"和"左手把开关 36"）
                key = (title, page_ref)
                if key == prev_key:
                    continue
                entries.append((title, int(page_ref)))
                prev_key = key

    if not entries:
        continue

    print(f"  {seg['name']}: {len(entries)} 条目，从 PDF 重建", file=sys.stderr)

    # 生成干净 Markdown
    new_md = [f"## 目录\n"]
    current_first_char = None
    for title, page_ref in entries:
        first = title[0]
        if current_first_char and first != current_first_char:
            new_md.append("")
        new_md.append(f"- {title} {page_ref}")
        current_first_char = first

    md_path.write_text("\n".join(new_md) + "\n", encoding="utf-8")
    fixed_count += 1

doc.close()
if fixed_count:
    print(f"TOC 修复: {fixed_count} 个段已从 PDF 重建", file=sys.stderr)

# --- TOC 修复后再验证：条目召回率 ---
if fixed_count:
    print("TOC 再验证（条目召回率）:", file=sys.stderr)
    # 重新读取 pdf-validate JSON，更新 TOC 段的 coverage/status
    with open(validate_tmp) as f:
        vreport = json.load(f)

    doc2 = fitz.open(pdf_path)
    updated = 0
    for seg in vreport["segments"]:
        summary = seg.get("page_type_summary", {})
        if summary.get("toc", 0) == 0:
            continue

        seg_dir = segments_dir / seg["name"]
        md_files = sorted(seg_dir.rglob("*.md"))
        if not md_files:
            continue
        md_text = md_files[0].read_text(encoding="utf-8", errors="replace")

        # 从 PDF 再提取条目，计算召回率
        pdf_lines = []
        for p in range(seg["start_page"] - 1, min(seg["end_page"], doc2.page_count)):
            pdf_lines.append(doc2[p].get_text())
        pdf_text2 = "\n".join(pdf_lines)
        lines = [l.strip() for l in pdf_text2.strip().split('\n') if l.strip()]
        toc_entries = []
        prev_key = None
        for i in range(len(lines) - 1):
            title_m = TITLE_DOTS.match(lines[i])
            num_m = DOTS_NUM.match(lines[i + 1])
            if title_m and num_m:
                title = title_m.group(1).strip()
                page_ref = num_m.group(1)
                if len(title) >= 2 and not title.isdigit():
                    key = (title, page_ref)
                    if key == prev_key:
                        continue
                    toc_entries.append((title, int(page_ref)))
                    prev_key = key

        if not toc_entries:
            continue

        found = sum(1 for t, _ in toc_entries if t in md_text)
        recall = found / len(toc_entries)

        # 条目召回率 >= 90% 视为通过
        new_coverage = round(recall, 4)
        new_status = "passed" if recall >= 0.9 else "suspicious"
        new_decision = "pass" if recall >= 0.9 else "review_only"

        print(f"  {seg['name']}: 条目召回 {found}/{len(toc_entries)} ({recall:.0%}) → {new_status}", file=sys.stderr)

        seg["coverage"] = new_coverage
        seg["status"] = new_status
        seg["decision"] = new_decision
        seg["reason"] = "toc_entry_recall"
        seg["rerunnable"] = False
        # 更新页面级数据
        for p in seg.get("pages", []):
            p["coverage"] = new_coverage
            p["status"] = new_status
            p["decision"] = new_decision
            p["reason"] = "toc_entry_recall"
        updated += 1

    doc2.close()

    # 重写 validate JSON 供后续 review.md 使用
    if updated:
        with open(validate_tmp, "w") as f:
            json.dump(vreport, f, ensure_ascii=False)
        # 更新 passed 标志
        all_ok = all(s["status"] == "passed" for s in vreport["segments"])
        print(f"TOC 再验证完成: {updated} 段，{'全部通过' if all_ok else '仍有未通过'}", file=sys.stderr)
PY

  log "合并输出: $merge_output"
  PDF_MERGE_OUTPUT="$merge_output" scripts/pdf-merge "$segments_dir" >"$_subprocess_stdout"

  # 检查是否有 review_only 段，生成人工复核清单
  review_count="$(python3 -c "
import json
with open('$validate_tmp') as f:
    report = json.load(f)
review_only = [s for s in report['segments'] if s.get('decision') == 'review_only']
print(len(review_only))
")"
  review_output=""
  if [[ "$review_count" -gt 0 ]]; then
    review_output="$(dirname "$segments_dir")/review.md"
    log "存在 ${review_count} 个需人工复核段，生成: $review_output"
    python3 - "$threshold" "$pdf_path" "$segments_dir" "$review_output" "$validate_tmp" "" <<'PY'
import json, sys
from datetime import datetime
from pathlib import Path

threshold = float(sys.argv[1])
pdf_path = sys.argv[2]
segments_dir = sys.argv[3]
review_path = sys.argv[4]

with open(sys.argv[5]) as f:
    report = json.load(f)

issues = [s for s in report["segments"] if s.get("decision") in ("review_only", "rerun") or s["status"] in ("failed", "skipped")]

lines = []
lines.append("# 人工兜底清单")
lines.append("")
lines.append(f"生成时间: {datetime.now().strftime('%Y-%m-%d %H:%M')}")
lines.append(f"原始 PDF: {pdf_path}")
lines.append(f"分段目录: {segments_dir}")
lines.append(f"阈值: {threshold}")
lines.append("")

# --- 段级汇总 ---
lines.append("## 段级汇总")
lines.append("")
lines.append("| 分段 | 页码范围 | 段级状态 | 可重跑 | 需复核页数 | 页级分布 |")
lines.append("|------|----------|----------|--------|------------|----------|")

for seg in report["segments"]:
    seg_name = seg["name"]
    pages = f"{seg['start_page']}-{seg['end_page']}"
    decision = seg.get("decision", "")
    status = seg.get("status", "")
    if decision == "review_only":
        seg_status = "`review_only`"
    elif decision == "rerun":
        seg_status = "`rerun`"
    elif decision == "pass" or status == "passed":
        seg_status = "`passed`"
    elif status == "failed":
        seg_status = "`failed`"
    elif status == "skipped":
        seg_status = "`skipped`"
    else:
        seg_status = f"`{decision or status}`"
    rerunnable = "是" if seg.get("rerunnable", False) else "否"
    pages_data = seg.get("pages", [])
    review_count = 0
    dist = {}
    if pages_data:
        for p in pages_data:
            pd = p.get("decision", "")
            ps = p.get("status", "")
            key = pd if pd in ("review_only", "rerun", "pass") else (ps or "?")
            dist[key] = dist.get(key, 0) + 1
            if pd in ("review_only", "rerun") or ps in ("failed", "skipped", "suspicious"):
                review_count += 1
    else:
        if decision in ("review_only", "rerun") or status in ("failed", "skipped"):
            review_count = 1
        key = decision or status or "?"
        dist[key] = 1
    dist_str = ", ".join(f"{k}:{v}" for k, v in sorted(dist.items()))
    lines.append(f"| {seg_name} | {pages} | {seg_status} | {rerunnable} | {review_count} | {dist_str} |")

lines.append("")

# --- 人工审核结论约定 ---
lines.append("## 人工审核结论约定")
lines.append("")
lines.append("| 结论 | 含义 |")
lines.append("|------|------|")
lines.append("| `pass` | 人工确认该段无需修改 |")
lines.append("| `fix_md` | 人工直接修正合并 Markdown |")
lines.append("| `rerun` | 人工决定后续重新解析该段 |")
lines.append("")

lines.append("## 需人工复核分段")
lines.append("")
lines.append("| 分段 | 页码范围 | 覆盖率 | 处理建议 | 原因 |")
lines.append("|------|----------|--------|----------|------|")

for seg in issues:
    pages = f"{seg['start_page']}-{seg['end_page']}"
    cov = f"{seg['coverage']:.2f}" if seg.get("coverage") is not None else "-"
    decision = seg.get("decision", seg["status"])
    reason = seg.get("reason", "")
    status = seg["status"]

    if decision == "review_only":
        page_type_summary = seg.get("page_type_summary", {})
        type_desc = ", ".join(f"{t}({c})" for t, c in page_type_summary.items() if c > 0)
        action = "人工复核（不重跑）"
        note = f"页面类型: {type_desc}" if type_desc else reason
    elif decision == "rerun":
        action = "需重跑"
        note = f"high 重跑后仍未通过阈值 {threshold}"
    elif status == "failed" and reason == "missing_markdown":
        action = "需检查"
        note = "mineru 运行成功但未生成 Markdown 文件"
    elif status == "skipped" and reason == "no_text_layer":
        action = "已跳过"
        note = "原 PDF 文本层为空，无法验证"
    else:
        action = "需复核"
        note = f"{decision}: {reason}" if reason else decision

    lines.append(f"| {seg['name']} | {pages} | {cov} | {action} | {note} |")

lines.append("")

# 逐页详情
for seg in issues:
    pages_data = seg.get("pages", [])
    if not pages_data:
        continue

    seg_pages = f"{seg['start_page']}-{seg['end_page']}"
    lines.append(f"## {seg['name']} 逐页详情（PDF 第 {seg_pages} 页）")
    lines.append("")
    lines.append("| PDF 页码 | 覆盖率 | 页面类型 | 处理决策 | PDF token | MD token | 缺失较多的词 |")
    lines.append("|----------|--------|----------|----------|-----------|----------|-------------|")

    for p in pages_data:
        cov = p.get("coverage")
        if cov is None:
            continue

        pdf_page_num = p["page"] + 1
        cov_str = f"{cov:.2f}"
        flag = " ⚠️" if cov < threshold else ""
        page_type = p.get("page_type", "?")
        page_decision = p.get("decision", "?")
        missing = ", ".join(
            f"{t}({c})" for t, c in p.get("missing_tokens", [])[:5]
        )
        if not missing:
            missing = "—"

        lines.append(
            f"| {pdf_page_num}{flag} | {cov_str} | {page_type} | {page_decision} | {p['pdf_tokens']} | {p['md_tokens']} | {missing} |"
        )

    lines.append("")

Path(review_path).write_text("\n".join(lines), encoding="utf-8")
print(f"人工兜底清单已生成: {review_path}", file=sys.stderr)
PY
  fi

  if [[ "$json_mode" == "1" ]]; then
    emit_json "all_passed" 0 "$merge_output" "$review_output" "$validate_tmp"
  fi
  update_manifest "all_passed" "$(basename "$merge_output")" "${review_output:+review.md}"
  exit 0
fi

if [[ "$action" == "needs_review" ]]; then
  review_output="$(dirname "$segments_dir")/review.md"

  log
  log "=== 首次验证：存在需人工复核段，跳过合并 ==="

  python3 - "$threshold" "$pdf_path" "$segments_dir" "$review_output" "$validate_tmp" "" <<'PY'
import json, sys
from datetime import datetime
from pathlib import Path

threshold = float(sys.argv[1])
pdf_path = sys.argv[2]
segments_dir = sys.argv[3]
review_path = sys.argv[4]

with open(sys.argv[5]) as f:
    report = json.load(f)

rerun_failures_str = sys.argv[6] if len(sys.argv) > 6 else ""
rerun_failures = set(rerun_failures_str.split()) if rerun_failures_str.strip() else set()

issues = [s for s in report["segments"] if s.get("decision") in ("review_only", "rerun") or s["status"] in ("failed", "skipped")]

lines = []
lines.append("# 人工兜底清单")
lines.append("")
lines.append(f"生成时间: {datetime.now().strftime('%Y-%m-%d %H:%M')}")
lines.append(f"原始 PDF: {pdf_path}")
lines.append(f"分段目录: {segments_dir}")
lines.append(f"阈值: {threshold}")
lines.append("")
lines.append("")

# --- 段级汇总 ---
lines.append("## 段级汇总")
lines.append("")
lines.append("| 分段 | 页码范围 | 段级状态 | 可重跑 | 需复核页数 | 页级分布 |")
lines.append("|------|----------|----------|--------|------------|----------|")

for seg in report["segments"]:
    seg_name = seg["name"]
    pages = f"{seg['start_page']}-{seg['end_page']}"
    decision = seg.get("decision", "")
    status = seg.get("status", "")
    if decision == "review_only":
        seg_status = "`review_only`"
    elif decision == "rerun":
        seg_status = "`rerun`"
    elif decision == "pass" or status == "passed":
        seg_status = "`passed`"
    elif status == "failed":
        seg_status = "`failed`"
    elif status == "skipped":
        seg_status = "`skipped`"
    else:
        seg_status = f"`{decision or status}`"
    rerunnable = "是" if seg.get("rerunnable", False) else "否"
    pages_data = seg.get("pages", [])
    review_count = 0
    dist = {}
    if pages_data:
        for p in pages_data:
            pd = p.get("decision", "")
            ps = p.get("status", "")
            key = pd if pd in ("review_only", "rerun", "pass") else (ps or "?")
            dist[key] = dist.get(key, 0) + 1
            if pd in ("review_only", "rerun") or ps in ("failed", "skipped", "suspicious"):
                review_count += 1
    else:
        if decision in ("review_only", "rerun") or status in ("failed", "skipped"):
            review_count = 1
        key = decision or status or "?"
        dist[key] = 1
    dist_str = ", ".join(f"{k}:{v}" for k, v in sorted(dist.items()))
    lines.append(f"| {seg_name} | {pages} | {seg_status} | {rerunnable} | {review_count} | {dist_str} |")

lines.append("")

# --- 人工审核结论约定 ---
lines.append("## 人工审核结论约定")
lines.append("")
lines.append("| 结论 | 含义 |")
lines.append("|------|------|")
lines.append("| `pass` | 人工确认该段无需修改 |")
lines.append("| `fix_md` | 人工直接修正合并 Markdown |")
lines.append("| `rerun` | 人工决定后续重新解析该段 |")
lines.append("")

lines.append("## 需复核分段")
lines.append("")
lines.append("| 分段 | 页码范围 | 覆盖率 | 处理建议 | 原因 |")
lines.append("|------|----------|--------|----------|------|")

for seg in issues:
    pages = f"{seg['start_page']}-{seg['end_page']}"
    cov = f"{seg['coverage']:.2f}" if seg.get("coverage") is not None else "-"

    decision = seg.get("decision", seg["status"])
    reason = seg.get("reason", "")
    status = seg["status"]

    if seg['name'] in rerun_failures:
        action = "重跑失败，使用原始结果"
        note = "mineru 退出非0"
    elif decision == "review_only":
        page_type_summary = seg.get("page_type_summary", {})
        type_desc = ", ".join(f"{t}({c})" for t, c in page_type_summary.items() if c > 0)
        action = "人工复核（不重跑）"
        note = f"页面类型: {type_desc}" if type_desc else reason
    elif decision == "rerun":
        action = "需重跑"
        note = f"high 重跑后仍未通过阈值 {threshold}"
    elif status == "failed" and reason == "missing_markdown":
        action = "需检查"
        note = "mineru 运行成功但未生成 Markdown 文件"
    elif status == "skipped" and reason == "no_text_layer":
        action = "已跳过"
        note = "原 PDF 文本层为空，无法验证"
    else:
        action = "需复核"
        note = f"{decision}: {reason}" if reason else decision

    lines.append(f"| {seg['name']} | {pages} | {cov} | {action} | {note} |")

lines.append("")

# --- 逐页详情 ---
for seg in issues:
    pages_data = seg.get("pages", [])
    if not pages_data:
        continue

    low_pages = [p for p in pages_data if p.get("coverage") is not None and p["coverage"] < threshold]
    if not low_pages:
        continue

    seg_pages = f"{seg['start_page']}-{seg['end_page']}"
    lines.append(f"## {seg['name']} 逐页详情（PDF 第 {seg_pages} 页）")
    lines.append("")
    lines.append("| PDF 页码 | 覆盖率 | PDF token | MD token | 缺失较多的词 |")
    lines.append("|----------|--------|-----------|----------|-------------|")

    for p in pages_data:
        cov = p.get("coverage")
        if cov is None:
            continue

        pdf_page_num = p["page"] + 1
        cov_str = f"{cov:.2f}"
        flag = " ⚠️" if cov < threshold else ""
        missing = ", ".join(
            f"{t}({c})" for t, c in p.get("missing_tokens", [])[:5]
        )
        if not missing:
            missing = "—"

        lines.append(
            f"| {pdf_page_num}{flag} | {cov_str} | {p['pdf_tokens']} | {p['md_tokens']} | {missing} |"
        )

    lines.append("")

Path(review_path).write_text("\n".join(lines), encoding="utf-8")
print(f"人工兜底清单已生成: {review_path}", file=sys.stderr)
PY

  if [[ "$json_mode" == "1" ]]; then
    emit_json "needs_review" 2 "" "$review_output" "$validate_tmp"
  fi
  update_manifest "needs_review" "" "review.md"
  exit 2
fi

log "需要重跑可疑段，继续执行..."

if [[ "$action" == "rerun" ]]; then
  log
  log "=== 重跑可疑段（effort=${rerun_effort}） ==="

  # Extract rerunnable segment names from JSON (阶段 4：只重跑 rerunnable==true 的段)
  rerun_names="$(cat "$validate_tmp" | python3 -c "
import json, sys
report = json.loads(sys.stdin.read())
for s in report['segments']:
    if s.get('rerunnable', False):
        print(s['name'])
")"

  backend="${MINERU_BACKEND:-hybrid-engine}"
  method="${MINERU_METHOD:-auto}"
  lang="${MINERU_LANG:-ch}"

  export MINERU_DEVICE_MODE="${MINERU_DEVICE_MODE:-mps}"
  export MINERU_PDF_RENDER_THREADS="${MINERU_PDF_RENDER_THREADS:-2}"
  export MINERU_API_MAX_CONCURRENT_REQUESTS="${MINERU_API_MAX_CONCURRENT_REQUESTS:-1}"
  export MINERU_PROCESSING_WINDOW_SIZE="${MINERU_PROCESSING_WINDOW_SIZE:-8}"

  rerun_failures=""

  while IFS= read -r name; do
    [[ -z "$name" ]] && continue

    rerun_dir="$segments_dir/${name}-rerun"

    # Extract start/end page from segment name p0001-0020 (1-based, align PDF page)
    start_page="${name#p}"
    start_page="${start_page%-*}"
    start_page=$((10#${start_page}))
    end_page="${name##*-}"
    end_page=$((10#${end_page}))
    # mineru uses 0-based page indices
    start_page=$((start_page - 1))
    end_page=$((end_page - 1))

    # Clean existing rerun dir for idempotent rerun
    if [[ -d "$rerun_dir" ]]; then
      log "清理已有重跑目录: $rerun_dir"
      rm -rf "$rerun_dir"
    fi
    mkdir -p "$rerun_dir"

    segment_pages=$((end_page - start_page + 1))
    log
    log "重跑分段: $name ($segment_pages 页)"

    # 标记此段是否成功
    segment_ok=true

    if [[ -n "$api_url" ]]; then
      mineru \
        -p "$pdf_path" \
        -o "$rerun_dir" \
        -b "$backend" \
        -m "$method" \
        --effort "$rerun_effort" \
        -l "$lang" \
        -s "$start_page" \
        -e "$end_page" \
        --api-url "$api_url" >"$_subprocess_stdout" 2>&1
    else
      mineru \
        -p "$pdf_path" \
        -o "$rerun_dir" \
        -b "$backend" \
        -m "$method" \
        --effort "$rerun_effort" \
        -l "$lang" \
        -s "$start_page" \
        -e "$end_page" >"$_subprocess_stdout" 2>&1
    fi
    mineru_rc=$?
    if [[ "$mineru_rc" -eq 0 ]]; then
      log "    ✓ 完成"
      find_md="$(find "$rerun_dir" -name "*.md" -type f | head -1)"
      if [[ -n "$find_md" && -f "$find_md" ]]; then
        cp "$find_md" "$rerun_dir/$(basename "$pdf_stem").md"
      fi
    else
      log "    ✗ 失败 (mineru 退出非0)"
      segment_ok=false
    fi

    if $segment_ok; then
      echo "$name" >> "$_rerun_names_file"
    else
      log "重跑部分失败: $name（将使用原始结果继续）"
      rerun_failures="$rerun_failures $name"
      echo "$name" >> "$_rerun_names_file"
    fi
  done <<< "$rerun_names"

  if [[ -n "$rerun_failures" ]]; then
    log
    log "以下分段重跑失败（将使用原始结果继续）：$rerun_failures"
  fi
fi

# --- 第二次验证 ---
log
log "=== 第二次验证 ==="

validate2_tmp="$(mktemp)"
trap 'rm -f "$validate_tmp" "$validate2_tmp" "$_rerun_names_file"; _d="$(cd "$(dirname "$0")" && pwd)"; rm -rf "$(dirname "$_d")/output"' EXIT

PDF_VALIDATE_JSON=1 scripts/pdf-validate "$pdf_path" "$segments_dir" >"$validate2_tmp" 2>/dev/null || true

# 判定是否全部通过，保存到 decision 变量供 Task 5 使用
decision="$(python3 - "$threshold" "$validate2_tmp" <<'PY'
import json, sys
with open(sys.argv[2]) as f:
    content = f.read()
if not content or not content.strip().startswith('{'):
    print(f"pdf-validate 输出异常（非 JSON）：\n{content}", file=sys.stderr)
    sys.exit(1)
report = json.loads(content)
threshold = float(sys.argv[1])

segments = report["segments"]
rerunnable_remaining = [s for s in segments if s.get("rerunnable", False)]
issues = [s for s in segments if s.get("decision") in ("rerun", "review_only")]
all_ok = len(rerunnable_remaining) == 0

for s in segments:
    decision = s.get("decision", s["status"])
    reason = s.get("reason", "")
    cov = s.get('coverage', 'N/A')
    note = f" ({reason})" if reason else ""
    label_map = {
        "pass": "通过",
        "rerun": "需重跑",
        "review_only": "需人工复核",
        "skip": "已跳过",
    }
    label = label_map.get(decision, decision)
    print(f"  [{decision}] {s['name']}: {label} — 覆盖率 {cov}{note}", file=sys.stderr)

if all_ok:
    print("all_passed")
else:
    for s in issues:
        reason = s.get("reason", "")
        cov = s.get("coverage", "N/A")
        print(f"ISSUE:{s['name']}:{s.get('decision', s['status'])}:{reason}:{cov}")
    print("has_issues")
PY
)" || {
  if [[ "$json_mode" == "1" ]]; then
    emit_json "error" 1 "" "" ""
  fi
  update_manifest "error" "" ""
  exit 1
}

merge_output="${PDF_AUTO_MERGE_OUTPUT:-$(dirname "$segments_dir")/${pdf_stem}.md}"

# --- 全部通过：直接合并 ---
if echo "$decision" | grep -q "^all_passed$"; then
  log
  log "=== 准备合并 ==="

  for rerun_dir in "$segments_dir"/*-rerun/; do
    [[ -d "$rerun_dir" ]] || continue
    name="$(basename "$rerun_dir")"
    name="${name%-rerun}"
    original_dir="$segments_dir/$name"

    rerun_md="$(find "$rerun_dir" -maxdepth 1 -name "*.md" -type f | head -1)"
    if [[ -z "$rerun_md" ]]; then
      rerun_md="$(find "$rerun_dir" -name "*.md" -type f | head -1)"
    fi
    if [[ -n "$rerun_md" && -f "$rerun_md" ]]; then
      original_md="$(find "$original_dir" -name "*.md" -type f | head -1)"
      if [[ -n "$original_md" ]]; then
        log "用重跑结果覆盖: ${name} ($(basename "$rerun_md") → $(basename "$original_md"))"
        cp "$rerun_md" "$original_md"
      fi
    fi
  done

  log
  log "=== 合并 ==="

  # --- TOC 段修复 ---
  python3 - "$pdf_path" "$segments_dir" "$validate2_tmp" <<'PY'
import json, re, sys
from collections import OrderedDict
from pathlib import Path
try:
    import fitz
except Exception:
    sys.exit(0)
pdf_path = Path(sys.argv[1])
segments_dir = Path(sys.argv[2])
with open(sys.argv[3]) as f:
    report = json.load(f)
toc_segs = [s for s in report["segments"] if s.get("page_type_summary", {}).get("toc", 0) > 0]
if not toc_segs:
    sys.exit(0)
doc = fitz.open(pdf_path)
TITLE_DOTS = re.compile(r'^(\S.+?)\s*[.]{3,}\s*$')
DOTS_NUM = re.compile(r'^\s*[.]{3,}\s*(\d+)\s*$')
fixed = 0
for seg in toc_segs:
    seg_dir = segments_dir / seg["name"]
    md_files = sorted(seg_dir.rglob("*.md"))
    if not md_files:
        continue
    md_path = md_files[0]
    pdf_lines = []
    for p in range(seg["start_page"] - 1, min(seg["end_page"], doc.page_count)):
        pdf_lines.append(doc[p].get_text())
    pdf_text = "\n".join(pdf_lines)
    lines = [l.strip() for l in pdf_text.strip().split('\n') if l.strip()]
    entries = []  # list of (title, page_ref)
    prev_key = None
    for i in range(len(lines) - 1):
        title_m = TITLE_DOTS.match(lines[i])
        num_m = DOTS_NUM.match(lines[i + 1])
        if title_m and num_m:
            title = title_m.group(1).strip()
            page_ref = num_m.group(1)
            if len(title) >= 2 and not title.isdigit():
                key = (title, page_ref)
                if key == prev_key:
                    continue
                entries.append((title, int(page_ref)))
                prev_key = key
    if not entries:
        continue
    print(f"  {seg['name']}: {len(entries)} 条目，从 PDF 重建", file=sys.stderr)
    new_md = ["## 目录\n"]
    cf = None
    for title, page_ref in entries:
        first = title[0]
        if cf and first != cf:
            new_md.append("")
        new_md.append(f"- {title} {page_ref}")
        cf = first
    md_path.write_text("\n".join(new_md) + "\n", encoding="utf-8")
    fixed += 1
doc.close()
if fixed:
    print(f"TOC 修复: {fixed} 个段已从 PDF 重建", file=sys.stderr)
PY

  PDF_MERGE_OUTPUT="$merge_output" scripts/pdf-merge "$segments_dir" >"$_subprocess_stdout"
  log "合并完成: $merge_output"

  if [[ "$json_mode" == "1" ]]; then
    emit_json "all_passed" 0 "$merge_output" "" "$validate2_tmp"
  fi
  update_manifest "all_passed" "$(basename "$merge_output")" ""
  exit 0
fi

# --- 有未通过段：只出 review，不合并 ---
if echo "$decision" | grep -q "^has_issues$"; then
  review_output="$(dirname "$segments_dir")/review.md"

  log
  log "=== 人工兜底清单 ==="

  python3 - "$threshold" "$pdf_path" "$segments_dir" "$review_output" "$validate2_tmp" "$rerun_failures" <<'PY'
