#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
用法:
  pdf-merge <package>/segments

说明:
  合并 pdf-seg 生成的分段 Markdown。
  输出文件默认放在分段目录的父目录（输出包根目录）：
  <输出包名>.md

可选环境变量:
  PDF_MERGE_OUTPUT=/path/to/output.md
EOF
}

if [[ $# -ne 1 ]]; then
  usage
  exit 2
fi

segments_dir="$1"

if [[ "$segments_dir" == "-h" || "$segments_dir" == "--help" ]]; then
  usage
  exit 0
fi

if [[ ! -d "$segments_dir" ]]; then
  echo "错误：找不到分段目录：$segments_dir" >&2
  exit 1
fi

segments_dir="$(cd "$segments_dir" && pwd)"
pkg_dir="$(dirname "$segments_dir")"
pkg_name="$(basename "$pkg_dir")"
output="${PDF_MERGE_OUTPUT:-$pkg_dir/${pkg_name}.md}"

pkg_images_dir="$pkg_dir/images"
mkdir -p "$pkg_images_dir"

_this_dir="$(cd "$(dirname "$0")" && pwd)"

python - "$_this_dir" "$segments_dir" "$output" "$pkg_images_dir" <<'PY'
import hashlib
import json
import re
import shutil
import sys
from pathlib import Path

scripts_dir = sys.argv[1]
sys.path.insert(0, scripts_dir)
from lib.page_anchors import insert_page_anchors


def file_sha256(p: Path) -> str:
    """计算文件内容 SHA-256。"""
    return hashlib.sha256(p.read_bytes()).hexdigest()


def find_v1_content_list(seg_md_dir: Path):
    """段 md 同目录的 v1 content_list.json（排除 v2）。"""
    for f in sorted(seg_md_dir.rglob("*_content_list.json")):
        if not f.name.endswith("_content_list_v2.json"):
            return f
    return None


segments_dir = Path(sys.argv[2])
output = Path(sys.argv[3])
pkg_images = Path(sys.argv[4])

# 读取 manifest.page_fallback，用于页级质量 fallback 的选择合并
manifest_path = segments_dir.parent / "manifest.json"
page_fallback: dict = {}
if manifest_path.exists():
    try:
        m = json.loads(manifest_path.read_text(encoding="utf-8"))
        page_fallback = m.get("page_fallback", {})
    except (ValueError, OSError):
        pass

segment_re = re.compile(r"^p(\d{4,})-(\d{4,})$")

segments = []
for child in segments_dir.iterdir():
    if not child.is_dir():
        continue
    match = segment_re.match(child.name)
    if not match:
        continue
    start = int(match.group(1))
    end = int(match.group(2))
    md_files = sorted(child.rglob("*.md"))
    if not md_files:
        segments.append((start, end, child.name, None))
        continue

    # 单页段且 manifest 标记了 selected=fallback → 从 -fallback/ 读 MD
    md_path = md_files[0]
    if start == end and page_fallback:
        fb_entry = page_fallback.get(str(start), {})
        if fb_entry.get("selected") == "fallback":
            fb_dir = segments_dir / f"{child.name}-fallback"
            if not fb_dir.exists():
                raise SystemExit(
                    f"manifest 选择 fallback 但候选目录不存在：{fb_dir}"
                )
            fb_mds = sorted(fb_dir.rglob("*.md"))
            if not fb_mds:
                raise SystemExit(
                    f"manifest 选择 fallback 但候选目录缺少 Markdown：{fb_dir}"
                )
            md_path = fb_mds[0]

    segments.append((start, end, child.name, md_path))

if not segments:
    raise SystemExit(f"没有找到分段目录：{segments_dir}/p0001-0020")

segments.sort(key=lambda item: item[0])

missing = [name for _, _, name, md in segments if md is None]
if missing:
    raise SystemExit("以下分段缺少 Markdown：\n" + "\n".join(missing))

pieces = []
anchor_warnings = {}  # 段名 -> 逐页锚点 warning（近似定位 / 整段回退）
page_anchor_total = 0
for index, (start, end, name, md_path) in enumerate(segments):
    text = md_path.read_text(encoding="utf-8").strip()
    if not text:
        raise SystemExit(f"分段 Markdown 为空：{md_path}")
    text += "\n"  # 保证尾换行，使段末逐页锚点落在行首（独立注释行，不粘正文）

    # 逐页锚点（A′ + X）：读同目录 content_list.json(v1)，按 page_idx 插 <!-- page N -->
    cl = find_v1_content_list(md_path.parent)
    if cl is not None:
        items = json.loads(cl.read_text(encoding="utf-8"))
        text, warns = insert_page_anchors(
            text, items if isinstance(items, list) else [], start, end)
        page_anchor_total += text.count("<!-- page ")
        if warns:
            anchor_warnings[name] = warns

    if index:
        pieces.append("\n\n---\n\n")
    pieces.append(f"<!-- pages {start}-{end} -->\n\n")
    pieces.append(text)  # text 已以 \n 结尾

output.parent.mkdir(parents=True, exist_ok=True)
output.write_text("".join(pieces), encoding="utf-8")

# 逐页锚点 warning 写入 manifest.json（存在才更新，不新建）
if manifest_path.exists():
    try:
        manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
        manifest["page_anchors"] = {
            "total_anchors": page_anchor_total,
            "segments_with_warnings": len(anchor_warnings),
            "warnings": anchor_warnings,
        }
        manifest_path.write_text(
            json.dumps(manifest, ensure_ascii=False, indent=2) + "\n",
            encoding="utf-8")
    except (ValueError, OSError):
        pass

print(f"逐页锚点: {page_anchor_total} 个，{len(anchor_warnings)} 段有近似/回退 warning")
print(f"已合并分段数: {len(segments)}")
print(f"输出文件: {output}")
for start, end, name, md_path in segments:
    print(f"- {name}: pages {start}-{end}, {md_path}")

# --- 收集图片到输出包 images/ ---
image_count = 0
skipped_same = 0
conflicts = []
pkg_images.mkdir(parents=True, exist_ok=True)
for _, _, _, md_path in segments:
    # MinerU 图片在 md_path 同级的 images/ 目录
    seg_images = md_path.parent / "images"
    if not seg_images.is_dir():
        continue
    for img in seg_images.iterdir():
        if not img.is_file():
            continue
        dest = pkg_images / img.name
        if not dest.exists():
            shutil.copy2(img, dest)
            image_count += 1
        elif file_sha256(img) == file_sha256(dest):
            skipped_same += 1
        else:
            conflicts.append((str(img), str(dest)))

if conflicts:
    print("错误：图片同名但内容不同，合并终止：", file=sys.stderr)
    for src, dst in conflicts:
        print(f"  源: {src}", file=sys.stderr)
        print(f"  目标: {dst}", file=sys.stderr)
        print(file=sys.stderr)
    raise SystemExit(
        f"检测到 {len(conflicts)} 个图片文件名冲突。"
        f"请检查分段图片目录后重新合并。"
    )

if image_count:
    print(f"收集图片: {image_count} 张 -> {pkg_images}")
if skipped_same:
    print(f"跳过幂等图片: {skipped_same} 张（同名同内容）")
PY
