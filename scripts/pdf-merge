#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
用法:
  pdf-merge <package>/segments

说明:
  合并 pdf-seg 生成的分段 Markdown。
  输出文件默认放在分段目录的父目录（输出包根目录）：
  <输出包名>.md

可选环境变量:
  PDF_MERGE_OUTPUT=/path/to/output.md
EOF
}

if [[ $# -ne 1 ]]; then
  usage
  exit 2
fi

segments_dir="$1"

if [[ "$segments_dir" == "-h" || "$segments_dir" == "--help" ]]; then
  usage
  exit 0
fi

if [[ ! -d "$segments_dir" ]]; then
  echo "错误：找不到分段目录：$segments_dir" >&2
  exit 1
fi

segments_dir="$(cd "$segments_dir" && pwd)"
pkg_dir="$(dirname "$segments_dir")"
pkg_name="$(basename "$pkg_dir")"
output="${PDF_MERGE_OUTPUT:-$pkg_dir/${pkg_name}.md}"

pkg_images_dir="$pkg_dir/images"
mkdir -p "$pkg_images_dir"

python - "$segments_dir" "$output" "$pkg_images_dir" <<'PY'
import re
import shutil
import sys
from pathlib import Path

segments_dir = Path(sys.argv[1])
output = Path(sys.argv[2])
pkg_images = Path(sys.argv[3])

segment_re = re.compile(r"^p(\d{4,})-(\d{4,})$")

segments = []
for child in segments_dir.iterdir():
    if not child.is_dir():
        continue
    match = segment_re.match(child.name)
    if not match:
        continue
    start = int(match.group(1))
    end = int(match.group(2))
    md_files = sorted(child.rglob("*.md"))
    if not md_files:
        segments.append((start, end, child.name, None))
        continue
    segments.append((start, end, child.name, md_files[0]))

if not segments:
    raise SystemExit(f"没有找到分段目录：{segments_dir}/p0001-0020")

segments.sort(key=lambda item: item[0])

missing = [name for _, _, name, md in segments if md is None]
if missing:
    raise SystemExit("以下分段缺少 Markdown：\n" + "\n".join(missing))

pieces = []
for index, (start, end, name, md_path) in enumerate(segments):
    text = md_path.read_text(encoding="utf-8").strip()
    if not text:
        raise SystemExit(f"分段 Markdown 为空：{md_path}")

    if index:
        pieces.append("\n\n---\n\n")
    pieces.append(f"<!-- pages {start}-{end} -->\n\n")
    pieces.append(text)
    pieces.append("\n")

output.parent.mkdir(parents=True, exist_ok=True)
output.write_text("".join(pieces), encoding="utf-8")

print(f"已合并分段数: {len(segments)}")
print(f"输出文件: {output}")
for start, end, name, md_path in segments:
    print(f"- {name}: pages {start}-{end}, {md_path}")

# --- 收集图片到输出包 images/ ---
image_count = 0
pkg_images.mkdir(parents=True, exist_ok=True)
for _, _, _, md_path in segments:
    # MinerU 图片在 md_path 同级的 images/ 目录
    seg_images = md_path.parent / "images"
    if not seg_images.is_dir():
        continue
    for img in seg_images.iterdir():
        if img.is_file():
            dest = pkg_images / img.name
            if not dest.exists():
                shutil.copy2(img, dest)
                image_count += 1
if image_count:
    print(f"收集图片: {image_count} 张 -> {pkg_images}")
PY
