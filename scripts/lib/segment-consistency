#!/usr/bin/env bash

# 输出目录一致性检查。
# 调用方必须先定义 log()，参数为：
#   segments_dir pdf pages segment_size backend method effort lang

_clear_segment_output() {
  local seg_dir="$1"
  [[ -d "$seg_dir" ]] || return 0
  find "$seg_dir" -mindepth 1 -maxdepth 1 -exec rm -rf {} +
}

check_segment_consistency() {
  local seg_dir="$1" pdf="$2" pages="$3" seg_size="$4"
  local backend="$5" method="$6" effort="$7" lang="$8"
  local manifest result rc

  if [[ ! -d "$seg_dir" ]] || [[ -z "$(ls -A "$seg_dir" 2>/dev/null)" ]]; then
    return 0
  fi

  manifest="$(cd "$(dirname "$seg_dir")" && pwd)/manifest.json"
  if [[ ! -f "$manifest" ]]; then
    log "⚠ 旧输出包缺少 manifest.json，清理重建"
    _clear_segment_output "$seg_dir"
    return 1
  fi

  if result="$(python3 - "$manifest" "$pdf" "$seg_dir" "$pages" "$seg_size" "$backend" "$method" "$effort" "$lang" <<'PY'
import hashlib
import json
import re
import sys
from pathlib import Path

manifest_path = Path(sys.argv[1])
pdf_path = Path(sys.argv[2])
segments_dir = Path(sys.argv[3])
current_pages = int(sys.argv[4])
current_seg_size = int(sys.argv[5])
current_mineru = {
    "backend": sys.argv[6],
    "method": sys.argv[7],
    "effort": sys.argv[8],
    "lang": sys.argv[9],
}

try:
    manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
except Exception as exc:
    print(f"manifest.json 无法读取: {exc}")
    raise SystemExit(1)

reasons = []

old_hash = manifest.get("hash", {}).get("sha256", "")
if not old_hash:
    reasons.append("缺少 PDF SHA-256")
else:
    new_hash = hashlib.sha256(pdf_path.read_bytes()).hexdigest()
    if old_hash != new_hash:
        reasons.append("PDF 文件变更 (SHA-256 不匹配)")

seg = manifest.get("segmentation", {})
if not seg:
    reasons.append("缺少 segmentation 指纹 (旧输出格式)")
else:
    expected_layout = "single_page" if current_seg_size == 1 else "batch"
    if seg.get("layout") != expected_layout:
        reasons.append(f"输出布局变更: {seg.get('layout')} -> {expected_layout}")
    if seg.get("total_pages") != current_pages:
        reasons.append(f"页数变更: {seg.get('total_pages')} -> {current_pages}")
    if seg.get("segment_size") != current_seg_size:
        reasons.append(f"分段大小变更: {seg.get('segment_size')} -> {current_seg_size}")
    recorded_mineru = seg.get("mineru", {})
    for key, current in current_mineru.items():
        if recorded_mineru.get(key) != current:
            reasons.append(f"{key} 变更: {recorded_mineru.get(key)} -> {current}")

formal_re = re.compile(r"^p(\d{4,})-(\d{4,})$")
formal_dirs = {}
stale_dirs = []
for child in sorted(segments_dir.iterdir()):
    if not child.is_dir():
        continue
    name = child.name
    if name.endswith(".backup") or name.endswith("-rerun"):
        stale_dirs.append(name)
    match = formal_re.match(name)
    if match:
        formal_dirs[name] = (int(match.group(1)), int(match.group(2)))

if stale_dirs:
    reasons.append("残留临时目录: " + ", ".join(stale_dirs[:10]))

if current_seg_size == 1:
    expected_names = {
        f"p{page:04d}-{page:04d}" for page in range(1, current_pages + 1)
    }
    actual_names = set(formal_dirs)
    missing = sorted(expected_names - actual_names)
    extra = sorted(actual_names - expected_names)
    if missing:
        reasons.append("缺少页面: " + ", ".join(missing[:10]))
    if extra:
        reasons.append("多余/旧分段: " + ", ".join(extra[:10]))

for reason in reasons:
    print(reason)
if reasons:
    raise SystemExit(1)
PY
)"; then
    rc=0
  else
    rc=$?
  fi

  if [[ "$rc" -ne 0 || -n "$result" ]]; then
    while IFS= read -r reason; do
      [[ -n "$reason" ]] && log "  - ${reason}"
    done <<< "$result"
    log "⚠ 输出目录与当前配置不一致，清理重建"
    _clear_segment_output "$seg_dir"
    return 1
  fi

  log "  ✓ 输出目录一致性检查通过"
  return 0
}
