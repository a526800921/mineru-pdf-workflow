#!/usr/bin/env bash
# ModelPad PDF 服务按需编排 helper
#
# 用法（在 pdf-seg / pdf-auto / pdf-rerun 中 source）：
#   source "${BASH_SOURCE[0]%/*}/lib/modelpad-pdf-service"
#
#   1. 调用 detect_pdf_api   → 通过 ModelPad API 获取 pdf 模型端口，返回 api_url
#   2. 调用 ensure_pdf_api   → 无服务时通过 ModelPad API 启动
#   3. 在 EXIT trap 中调用   → modelpad_stop_pdf_if_started
#
# 环境变量：
#   MODELPAD_API_BASE          默认 http://127.0.0.1:9786
#   MODELPAD_PDF_MODEL_ID      默认 40621169-461C-4018-974E-9FAC92A542E7
#   MODELPAD_PDF_START_TIMEOUT 默认 120 (秒)

set -euo pipefail

MODELPAD_API_BASE="${MODELPAD_API_BASE:-http://127.0.0.1:9786}"
MODELPAD_PDF_MODEL_ID="${MODELPAD_PDF_MODEL_ID:-40621169-461C-4018-974E-9FAC92A542E7}"
MODELPAD_PDF_START_TIMEOUT="${MODELPAD_PDF_START_TIMEOUT:-120}"

# 内部状态：仅当本次脚本通过 ModelPad API 启动了服务时才为 1
_MODELPAD_PDF_STARTED_BY_SCRIPT=0
# 内部状态：本次启动创建的临时输出目录（仅 helper 创建时非空）
_MODELPAD_PDF_OUTPUT_DIR=""

# detect_pdf_api — 通过 ModelPad API 获取 pdf 模型运行端口
# 输出：设置全局变量 api_url；服务运行中则非空，否则为空
detect_pdf_api() {
  api_url=""
  local models_url="${MODELPAD_API_BASE}/api/models/${MODELPAD_PDF_MODEL_ID}"
  local resp
  resp="$(curl -s "$models_url" 2>&1)" || true
  if [[ -z "$resp" ]]; then
    return 1
  fi
  # 解析 model_status 和 port；仅 running 状态才认为可用
  local model_status port
  model_status="$(echo "$resp" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("model",{}).get("status",""))' 2>/dev/null)" || true
  port="$(echo "$resp" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("model",{}).get("port",""))' 2>/dev/null)" || true
  if [[ "$model_status" == "running" ]] && [[ -n "$port" ]] && [[ "$port" =~ ^[0-9]+$ ]]; then
    api_url="http://127.0.0.1:$port"
    return 0
  fi
  return 1
}

# wait_pdf_api — 等待 ModelPad 报告 pdf 模型进入 running 状态
# 参数：$1 = log 函数名（可选，默认 echo）
wait_pdf_api() {
  local log_fn="${1:-echo}"
  local deadline=$(($(date +%s) + MODELPAD_PDF_START_TIMEOUT))
  while [[ $(date +%s) -lt $deadline ]]; do
    if detect_pdf_api; then
      return 0
    fi
    sleep 1
  done
  "$log_fn" "错误：等待 PDF 服务就绪超时（${MODELPAD_PDF_START_TIMEOUT}s）" >&2
  return 1
}

# modelpad_start_pdf — 通过 ModelPad API 启动 pdf 模型
# 前置：detect_pdf_api 已返回非空（服务已在运行），或 detect_pdf_api 失败（需要启动）
# 参数：$1 = log 函数名（可选，默认 echo）
# 输出：成功返回 0，失败返回 1
modelpad_start_pdf() {
  local log_fn="${1:-echo}"
  api_url="${api_url:-}"

  # 如果服务已经可用，只复用，不启动
  if detect_pdf_api; then
    "$log_fn" "PDF 服务已在运行: ${api_url:-unknown}（复用，不启动）"
    return 0
  fi

  # 为本次运行创建临时输出目录
  if ! _MODELPAD_PDF_OUTPUT_DIR="$(mktemp -d "${TMPDIR:-/tmp}/mineru-pdf-output-XXXXXXXX" 2>&1)"; then
    "$log_fn" "错误：无法创建临时输出目录: $_MODELPAD_PDF_OUTPUT_DIR" >&2
    _MODELPAD_PDF_OUTPUT_DIR=""
    return 1
  fi
  "$log_fn" "本次临时输出目录: $_MODELPAD_PDF_OUTPUT_DIR"

  "$log_fn" "正在通过 ModelPad 启动 PDF 服务..."
  local start_url="${MODELPAD_API_BASE}/api/models/${MODELPAD_PDF_MODEL_ID}/start"
  local resp
  resp="$(curl -s -X POST "$start_url" \
    -H "Content-Type: application/json" \
    -d "{\"env\":{\"MINERU_API_OUTPUT_ROOT\":\"$_MODELPAD_PDF_OUTPUT_DIR\"}}" 2>&1)" || true

  # 检查 ModelPad API 是否响应
  if [[ -z "$resp" ]]; then
    "$log_fn" "错误：ModelPad API 无响应 ($start_url)" >&2
    rm -rf "$_MODELPAD_PDF_OUTPUT_DIR"
    _MODELPAD_PDF_OUTPUT_DIR=""
    return 1
  fi

  # 检查响应中 ok 字段
  if ! echo "$resp" | python3 -c 'import json,sys; d=json.load(sys.stdin); sys.exit(0 if d.get("ok") else 1)' 2>/dev/null; then
    "$log_fn" "错误：ModelPad 启动 PDF 服务失败: $resp" >&2
    rm -rf "$_MODELPAD_PDF_OUTPUT_DIR"
    _MODELPAD_PDF_OUTPUT_DIR=""
    return 1
  fi

  "$log_fn" "ModelPad 已接受启动请求，等待 MinerU API 就绪..."
  if ! wait_pdf_api "$log_fn"; then
    "$log_fn" "错误：PDF 服务启动超时" >&2
    rm -rf "$_MODELPAD_PDF_OUTPUT_DIR"
    _MODELPAD_PDF_OUTPUT_DIR=""
    return 1
  fi

  detect_pdf_api
  _MODELPAD_PDF_STARTED_BY_SCRIPT=1
  "$log_fn" "PDF 服务已就绪: $api_url"
  return 0
}

# modelpad_stop_pdf_if_started — 仅停止本次脚本启动的服务
# 参数：$1 = log 函数名（可选，默认 echo）
modelpad_stop_pdf_if_started() {
  local log_fn="${1:-echo}"
  if [[ "$_MODELPAD_PDF_STARTED_BY_SCRIPT" != "1" ]]; then
    return 0
  fi
  "$log_fn" "正在通过 ModelPad 停止本次启动的 PDF 服务..."
  local stop_url="${MODELPAD_API_BASE}/api/models/${MODELPAD_PDF_MODEL_ID}/stop"
  local resp
  resp="$(curl -s -X POST "$stop_url" 2>&1)" || true
  if [[ -n "$resp" ]] && echo "$resp" | python3 -c 'import json,sys; d=json.load(sys.stdin); sys.exit(0 if d.get("ok") else 1)' 2>/dev/null; then
    "$log_fn" "PDF 服务已停止"
  else
    "$log_fn" "警告：ModelPad 停止 PDF 服务可能失败: ${resp:-无响应}" >&2
  fi

  # 清理本次临时输出目录（幂等：仅清理 helper 自己创建的目录）
  if [[ -n "$_MODELPAD_PDF_OUTPUT_DIR" ]] && [[ -d "$_MODELPAD_PDF_OUTPUT_DIR" ]]; then
    rm -rf "$_MODELPAD_PDF_OUTPUT_DIR"
    "$log_fn" "已清理临时输出目录: $_MODELPAD_PDF_OUTPUT_DIR"
    _MODELPAD_PDF_OUTPUT_DIR=""
  fi
}

# ensure_pdf_api — 一键确保 PDF API 可用
# 参数：$1 = log 函数名（可选，默认 echo）
# 输出：成功设置 api_url 返回 0，失败返回 1
ensure_pdf_api() {
  local log_fn="${1:-echo}"
  if ! modelpad_start_pdf "$log_fn"; then
    "$log_fn" "错误：无法确保 PDF 服务可用。请检查 ModelPad app 是否已启动。" >&2
    return 1
  fi
  return 0
}
