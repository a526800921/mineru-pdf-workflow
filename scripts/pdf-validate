#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
用法:
  pdf-validate 原始.pdf xxx-mineru-segments

说明:
  自动验证 MinerU 分段输出的文本覆盖情况。
  它会从原 PDF 文本层提取文字，并和每个分段 Markdown 对比，找出覆盖率低或缺失词较多的页段。

可选环境变量:
  PDF_VALIDATE_THRESHOLD=0.82
  PDF_VALIDATE_JSON=1           输出机器可读 JSON（stdout），人类可读信息改到 stderr
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -ne 2 ]]; then
  usage
  exit 2
fi

pdf="$1"
segments_dir="$2"

if [[ ! -f "$pdf" ]]; then
  echo "错误：找不到 PDF 文件：$pdf" >&2
  exit 1
fi

if [[ ! -d "$segments_dir" ]]; then
  echo "错误：找不到分段目录：$segments_dir" >&2
  exit 1
fi

threshold="${PDF_VALIDATE_THRESHOLD:-0.82}"
json_mode="${PDF_VALIDATE_JSON:-0}"

python - "$pdf" "$segments_dir" "$threshold" "$json_mode" <<'PY'
import json
import re
import sys
from collections import Counter
from pathlib import Path

try:
    import fitz
except Exception as exc:
    raise SystemExit(f"无法导入 PyMuPDF/fitz：{exc}")

pdf_path = Path(sys.argv[1])
segments_dir = Path(sys.argv[2])
threshold = float(sys.argv[3])
json_mode = sys.argv[4] == "1"

segment_re = re.compile(r"^p(\d{4,})-(\d{4,})$")

def log(*args, **kwargs):
    """人类可读日志：JSON 模式写 stderr，否则写 stdout。"""
    if json_mode:
        print(*args, **kwargs, file=sys.stderr)
    else:
        print(*args, **kwargs)

def normalize(text: str) -> str:
    text = text.lower()
    text = re.sub(r"\s+", "", text)
    text = re.sub(r"[·•.。．,，:：;；!！?？\-_—~～()（）\[\]【】<>《》/\\|]", "", text)
    return text

def tokens(text: str) -> list[str]:
    normalized = normalize(text)
    # 连续英文数字作为词；中文按单字统计，适合发现 LCD 这类缺失。
    return re.findall(r"[a-z0-9]+|[一-鿿]", normalized)


def dedup_lines(text: str) -> str:
    """去掉 PDF 文本层中连续重复的行，避免重复行拉低覆盖率。

    PDF 文本提取在某些文档中会出现标题/段落重复的现象（同一行出现两次），
    导致分母虚高。这里只去连续相同行，保留非连续出现的相同行。
    """
    if not text:
        return text
    lines = text.split("\n")
    if len(lines) < 2:
        return text
    deduped = [lines[0]]
    for i in range(1, len(lines)):
        if lines[i] != lines[i - 1]:
            deduped.append(lines[i])
    return "\n".join(deduped)


def segment_markdown(segment: Path) -> Path | None:
    mds = sorted(segment.rglob("*.md"))
    return mds[0] if mds else None


def _strip_html(text: str) -> str:
    """去除 HTML 标签，保留文本内容。"""
    t = re.sub(r'<(style|script)[^>]*>.*?</\1>', '', text, flags=re.DOTALL | re.IGNORECASE)
    t = re.sub(r'</?(?:br|td|th|tr|p|div|li|h\d)[^>]*>', ' ', t, flags=re.IGNORECASE)
    t = re.sub(r'<[^>]+>', '', t)
    t = t.replace('&amp;', '&').replace('&lt;', '<').replace('&gt;', '>').replace('&quot;', '"').replace('&#39;', "'").replace('&nbsp;', ' ')
    t = re.sub(r'\s+', ' ', t).strip()
    return t


def _extract_texts(obj):
    """递归提取嵌套结构中的所有文本内容，含 HTML 标签内文本。"""
    texts = []
    if isinstance(obj, dict):
        if "type" in obj and obj.get("type") == "text" and "content" in obj:
            c = obj["content"]
            if isinstance(c, str):
                texts.append(c)
        # content_list_v2.json 中 table 元素的 html 字段是原始 HTML 字符串
        if "html" in obj:
            html_str = obj["html"]
            if isinstance(html_str, str):
                cleaned = _strip_html(html_str)
                if cleaned.strip():
                    texts.append(cleaned)
        for v in obj.values():
            texts.extend(_extract_texts(v))
    elif isinstance(obj, list):
        for item in obj:
            texts.extend(_extract_texts(item))
    return texts


# --- 页面类型检测（阶段 3） ---
def list_content_types(content_list_page: list) -> set[str]:
    """提取 content_list_v2.json 单页中所有元素的 type 集合。"""
    types = set()
    for item in (content_list_page or []):
        if isinstance(item, dict):
            types.add(item.get("type", "unknown"))
    return types


# TOC 特征：PDF 文本中包含大量点线 + 页码组合的短行
_TOC_PATTERN = re.compile(r"[.]{4,}\s*\d+")
# 表格特征：Markdown 表格行
_TABLE_PATTERN = re.compile(r"^\|.+\|$", re.MULTILINE)


def detect_page_type(
    pdf_page_text: str,
    cl_page: list | None,
    md_text: str,
    pdf_token_count: int,
) -> str:
    """根据 PDF 文本特征和 content_list 元素类型判断页面类型。

    优先级：no_text_layer > toc > image_or_sparse > table > text > unknown
    """
    # 1. 无文本层
    if not pdf_page_text.strip() or pdf_token_count == 0:
        return "no_text_layer"

    # 2. 目录页检测：PDF 文本包含大量点线+页码模式，或标题含"目录"且元素很少
    cl_types = list_content_types(cl_page[0] if cl_page and isinstance(cl_page, list) and len(cl_page) > 0 else None)
    cl_elem_count = len(cl_page[0]) if cl_page and isinstance(cl_page, list) and len(cl_page) > 0 else 0
    toc_lines = len(_TOC_PATTERN.findall(pdf_page_text))
    has_toc_title = "目录" in pdf_page_text or "目錄" in pdf_page_text

    if toc_lines >= 3 or (has_toc_title and cl_elem_count <= 5 and pdf_token_count > 50):
        return "toc"

    # 3. 图片/稀疏页检测：content_list 含 image 元素，或 PDF token 极少
    if "image" in cl_types or pdf_token_count < 15:
        return "image_or_sparse"

    # 4. 表格页检测：content_list 含 table 元素，或 Markdown 含表格语法
    if "table" in cl_types or bool(_TABLE_PATTERN.search(md_text)):
        return "table"

    # 5. 纯文字页：PDF token 足够多
    if pdf_token_count >= 30:
        return "text"

    # 6. 兜底
    return "unknown"


doc = fitz.open(pdf_path)

segments = []
for child in segments_dir.iterdir():
    if not child.is_dir():
        continue
    match = segment_re.match(child.name)
    if not match:
        continue
    start, end = int(match.group(1)), int(match.group(2))
    segments.append((start, end, child))

if not segments:
    raise SystemExit(f"没有找到分段目录：{segments_dir}/p0000-0019")

segments.sort(key=lambda item: item[0])

log(f"PDF: {pdf_path}")
log(f"分段目录: {segments_dir}")
log(f"阈值: {threshold:.2f}")
log()

results = []
failed = []

for start, end, segment in segments:
    md_path = segment_markdown(segment)
    if md_path is None:
        log(f"[失败] {segment.name}: 缺少 Markdown")
        failed.append(segment.name)
        results.append({
            "name": segment.name,
            "start_page": start,
            "end_page": end,
            "coverage": None,
            "status": "failed",
            "decision": "review_only",
            "rerunnable": False,
            "reason": "missing_markdown",
            "page_type_summary": {"text": 0, "toc": 0, "table": 0, "image_or_sparse": 0, "no_text_layer": 0, "unknown": 0},
            "missing_tokens": [],
            "markdown_path": None,
            "pages": [],
        })
        continue

    original_parts = []
    for page_idx in range(start - 1, min(end, doc.page_count)):
        original_parts.append(dedup_lines(doc[page_idx].get_text()))

    original_text = "\n".join(original_parts)
    markdown_raw = md_path.read_text(encoding="utf-8", errors="replace")
    # 段级覆盖率计算前去除 HTML 标签，避免标签碎片变成垃圾 token
    markdown_text = _strip_html(markdown_raw) if _strip_html(markdown_raw).strip() else markdown_raw

    original_tokens = tokens(original_text)
    markdown_tokens = tokens(markdown_text)

    if not original_tokens:
        log(f"[跳过] {segment.name}: 原 PDF 文本层为空")
        results.append({
            "name": segment.name,
            "start_page": start,
            "end_page": end,
            "coverage": None,
            "status": "skipped",
            "decision": "skip",
            "rerunnable": False,
            "reason": "no_text_layer",
            "page_type_summary": {"text": 0, "toc": 0, "table": 0, "image_or_sparse": 0, "no_text_layer": 1, "unknown": 0},
            "missing_tokens": [],
            "markdown_path": str(md_path),
            "pages": [],
        })
        continue

    original_counter = Counter(original_tokens)
    markdown_counter = Counter(markdown_tokens)

    matched = 0
    for token, count in original_counter.items():
        matched += min(count, markdown_counter.get(token, 0))

    coverage = matched / sum(original_counter.values())

    missing = original_counter - markdown_counter
    missing_common = [
        (token, count)
        for token, count in missing.most_common(20)
        if token.strip()
    ]

    status = "通过" if coverage >= threshold else "可疑"
    log(f"[{status}] {segment.name}: 覆盖率 {coverage:.1%}, 原始token {sum(original_counter.values())}, Markdown token {sum(markdown_counter.values())}")

    if coverage < threshold:
        failed.append(segment.name)
        log("  缺失较多:", ", ".join(f"{token}({count})" for token, count in missing_common[:12]))

    # --- 逐页覆盖率 ---
    pages_data = []
    cl_path = md_path.parent / f"{md_path.stem}_content_list_v2.json"
    cl_data = None
    if cl_path.exists():
        try:
            cl_data = json.loads(cl_path.read_text(encoding="utf-8"))
        except Exception:
            cl_data = None

    for page_idx in range(start - 1, min(end, doc.page_count)):
        pdf_page_text = dedup_lines(doc[page_idx].get_text())
        pdf_page_tokens = tokens(pdf_page_text)

        # 从 content_list_v2.json 提取该页的 Markdown 文本
        md_page_text = ""
        if cl_data is not None:
            array_idx = page_idx - (start - 1)
            if array_idx < len(cl_data):
                for item in cl_data[array_idx]:
                    texts = _extract_texts(item)
                    md_page_text += " ".join(texts) + " "

        md_page_tokens = tokens(md_page_text)

        # 缺少 content_list_v2.json 时逐页覆盖率不可用
        if cl_data is None:
            page_cov = None
            page_missing = []
        elif pdf_page_tokens:
            pc = Counter(pdf_page_tokens)
            mc = Counter(md_page_tokens)
            matched = sum(min(count, mc.get(token, 0)) for token, count in pc.items())
            page_cov = matched / sum(pc.values())
            page_missing = [
                (t, c) for t, c in (pc - mc).most_common(10) if t.strip()
            ]
        else:
            page_cov = None
            page_missing = []

        # --- 页面类型检测与处理决策（阶段 3） ---
        cl_page = cl_data[array_idx] if (cl_data is not None and array_idx < len(cl_data)) else None
        page_type = detect_page_type(pdf_page_text, cl_data[array_idx:array_idx+1] if cl_data else None, md_page_text, len(pdf_page_tokens))

        # 基于页面类型和覆盖率确定处理决策
        if cl_data is None:
            page_decision = "pass"
            page_reason = "no_content_list"
            page_rerunnable = False
        elif page_type == "no_text_layer":
            # PDF 无文本层 → ocr 可活（渲染为图片后视觉识别）
            page_decision = "rerun"
            page_reason = "no_text_layer_rerun_with_ocr"
            page_rerunnable = True
        elif page_type in ("toc", "image_or_sparse"):
            # 目录页、图片稀疏页 → 覆盖率不可靠，不触发 high 重跑
            page_decision = "review_only"
            page_reason = f"{page_type}_page"
            page_rerunnable = False
        elif page_type == "table":
            # 表格页：覆盖率达标则通过，不达标进入人工复核（不重跑）
            if page_cov is not None and page_cov >= threshold:
                page_decision = "pass"
                page_reason = "table_coverage_ok"
                page_rerunnable = False
            else:
                page_decision = "review_only"
                page_reason = "table_low_coverage"
                page_rerunnable = False
        elif page_cov is None:
            page_decision = "skip"
            page_reason = "pdf_page_empty"
            page_rerunnable = False
        elif page_cov >= threshold:
            page_decision = "pass"
            page_reason = "coverage_ok"
            page_rerunnable = False
        else:
            # 纯文字页或未知页 → 低覆盖率时仍可重跑
            page_decision = "rerun"
            page_reason = "low_text_coverage"
            page_rerunnable = True

        pages_data.append({
            "page": page_idx,
            "coverage": round(page_cov, 4) if page_cov is not None else None,
            "status": "suspicious" if (page_cov is not None and page_cov < threshold) else "passed",
            "page_type": page_type,
            "decision": page_decision,
            "reason": page_reason,
            "rerunnable": page_rerunnable,
            "pdf_tokens": len(pdf_page_tokens),
            "md_tokens": len(md_page_tokens),
            "missing_tokens": [[t, c] for t, c in page_missing[:10]],
        })

    # --- 段级汇总：基于页面类型更新决策（阶段 3） ---
    seg_status = "suspicious" if coverage < threshold else "passed"
    seg_rerunnable = any(p.get("rerunnable", False) for p in pages_data)
    any_review_only = any(p.get("decision") == "review_only" for p in pages_data)

    # 段级决策：仅当有 rerunnable 页面时才触发重跑
    if seg_rerunnable:
        seg_decision = "rerun"
        seg_reason = "low_text_coverage"
    elif any_review_only and coverage < threshold:
        seg_decision = "review_only"
        seg_reason = "review_only_pages"
    elif coverage < threshold:
        seg_decision = "review_only"
        seg_reason = "non_rerunnable_low_coverage"
    else:
        seg_decision = "pass"
        seg_reason = "coverage_ok"

    # 页面类型计数
    page_type_summary = {"text": 0, "toc": 0, "table": 0, "image_or_sparse": 0, "no_text_layer": 0, "unknown": 0}
    for p in pages_data:
        pt = p.get("page_type", "unknown")
        if pt in page_type_summary:
            page_type_summary[pt] += 1
        else:
            page_type_summary["unknown"] += 1

    results.append({
        "name": segment.name,
        "start_page": start,
        "end_page": end,
        "coverage": round(coverage, 4),
        "status": seg_status,
        "decision": seg_decision,
        "rerunnable": seg_rerunnable,
        "reason": seg_reason,
        "page_type_summary": page_type_summary,
        "missing_tokens": [[t, c] for t, c in missing_common[:20]],
        "markdown_path": str(md_path),
        "pages": pages_data,
    })

log()
all_passed = len(failed) == 0

if json_mode:
    output = {
        "passed": all_passed,
        "threshold": threshold,
        "segments": results,
    }
    json.dump(output, sys.stdout, ensure_ascii=False, indent=2)
    sys.stdout.write("\n")
else:
    if failed:
        print("需要人工或模型重点复核的分段：")
        for name in failed:
            print(f"- {name}")
    else:
        print("文本覆盖率初筛通过。仍建议抽查图片、表格和复杂图文页。")

if not all_passed:
    raise SystemExit(1)
PY
