#!/usr/bin/env python3
"""生成入库候选文件 ingest_ready.csv + conflicts.csv。

用法:
  scripts/pdf-prepare-ingest <package>

输入:
  <package>/data/quick_lookup_draft.csv
  <package>/data/review_overrides.csv    (可选; 阶段 2 人工审核输入)

输出:
  <package>/data/ingest_ready.csv
  <package>/data/conflicts.csv

不写入数据库，不修改原草案文件。
"""

import csv
import hashlib
import sys
from collections import defaultdict
from pathlib import Path


INGEST_FIELDS = [
    "record_id", "source_pdf", "model", "section_path", "key", "value", "unit",
    "page_start", "page_end", "evidence_text", "confidence", "review_status", "ingest_status",
    "source_block_id", "table_id", "row_index", "parent_key", "key_role",
    "source_row_hash", "created_at", "notes",
]

DRAFT_FIELDS = [
    "source_pdf", "model", "section_path", "key", "value", "unit",
    "page_start", "page_end", "evidence_text", "confidence", "status", "notes",
]
# 注：阶段 1 新字段 (source_block_id/table_id/row_index/parent_key/key_role) 暂不纳入
# DRAFT_FIELDS hash，以保持 record_id 稳定。它们通过 INGEST_FIELDS 流入 ingest_ready.csv
# 并参与 build_conflicts 的上下文 identity。纳入 hash 的决策推迟到阶段 3。

CONFLICT_FIELDS = [
    "conflict_id", "model", "section_path", "page_start",
    "source_block_id", "table_id", "parent_key", "key",
    "record_ids", "values", "key_role_distribution",
    "resolution_status", "notes",
]

OVERRIDE_FIELDS = ["record_id", "review_status", "notes"]
VALID_REVIEW_STATUSES = {"approved", "rejected", "needs_review"}

STATUS_MAP = {
    "draft": ("draft", "not_ready"),
    "needs_review": ("needs_review", "not_ready"),
    "rejected": ("rejected", "skipped"),
}


def sha256(s: str) -> str:
    return hashlib.sha256(s.encode("utf-8")).hexdigest()


def compute_source_row_hash(row: dict) -> str:
    normalized = "|".join(row.get(f, "") for f in DRAFT_FIELDS)
    return sha256(normalized)


def compute_record_id(source_pdf: str, model: str, section_path: str,
                      key: str, value: str, unit: str, source_row_hash: str) -> str:
    raw = f"{source_pdf}|{model}|{section_path}|{key}|{value}|{unit}|{source_row_hash}"
    return sha256(raw)


def read_draft(path: Path) -> list[dict]:
    if not path.exists():
        sys.exit(f"错误：找不到草案文件: {path}")
    with open(path, newline="", encoding="utf-8") as f:
        return list(csv.DictReader(f))


def read_overrides(path: Path) -> dict[str, dict]:
    """读取审核覆盖文件，返回 {record_id: {review_status, notes}}.
    校验：字段合法、状态合法、无重复 record_id、不允许修改 key/value/unit/evidence_text。
    """
    if not path.exists():
        return {}
    with open(path, newline="", encoding="utf-8") as f:
        reader = csv.DictReader(f)
        if reader.fieldnames is None:
            return {}
        reader.fieldnames = [fn.strip() for fn in reader.fieldnames]
        for fn in OVERRIDE_FIELDS:
            if fn not in reader.fieldnames:
                sys.exit(f"错误：review_overrides.csv 缺少字段: {fn}")
        for fn in reader.fieldnames:
            if fn not in OVERRIDE_FIELDS:
                sys.exit(f"错误：review_overrides.csv 包含禁止字段: {fn}。只允许 {OVERRIDE_FIELDS}")
        overrides = {}
        rows = list(reader)
        for r in rows:
            rid = r.get("record_id", "").strip()
            if not rid:
                sys.exit("错误：review_overrides.csv 存在空 record_id")
            if rid in overrides:
                sys.exit(f"错误：review_overrides.csv 存在重复 record_id: {rid}")
            rs = r.get("review_status", "").strip()
            if rs not in VALID_REVIEW_STATUSES:
                sys.exit(f"错误：非法 review_status: '{rs}'。允许: {sorted(VALID_REVIEW_STATUSES)}")
            overrides[rid] = {
                "review_status": rs,
                "notes": r.get("notes", "").strip(),
            }
        return overrides


def generate_ingest_rows(draft_rows: list[dict]) -> list[dict]:
    rows = []
    for dr in draft_rows:
        source_row_hash = compute_source_row_hash(dr)
        review_status, ingest_status = STATUS_MAP.get(
            dr.get("status", "draft"), ("draft", "not_ready")
        )
        row = {
            "source_pdf": dr.get("source_pdf", ""),
            "model": dr.get("model", ""),
            "section_path": dr.get("section_path", ""),
            "key": dr.get("key", ""),
            "value": dr.get("value", ""),
            "unit": dr.get("unit", ""),
            "page_start": dr.get("page_start", ""),
            "page_end": dr.get("page_end", ""),
            "evidence_text": dr.get("evidence_text", ""),
            "confidence": dr.get("confidence", ""),
            "review_status": review_status,
            "ingest_status": ingest_status,
            "source_block_id": dr.get("source_block_id", ""),
            "table_id": dr.get("table_id", ""),
            "row_index": dr.get("row_index", ""),
            "parent_key": dr.get("parent_key", ""),
            "key_role": dr.get("key_role", "business_key"),
            "source_row_hash": source_row_hash,
            "created_at": "",
            "notes": dr.get("notes", ""),
        }
        row["record_id"] = compute_record_id(
            row["source_pdf"], row["model"], row["section_path"],
            row["key"], row["value"], row["unit"], row["source_row_hash"],
        )
        rows.append(row)
    return rows


def apply_overrides(rows: list[dict], overrides: dict[str, dict]):
    """应用审核覆盖，校验所有 record_id 必须存在."""
    valid_ids = {r["record_id"] for r in rows}
    for rid in overrides:
        if rid not in valid_ids:
            sys.exit(f"错误：review_overrides.csv 包含未知 record_id: {rid}")

    for r in rows:
        rid = r["record_id"]
        if rid in overrides:
            ov = overrides[rid]
            r["review_status"] = ov["review_status"]
            if ov["notes"]:
                existing = r["notes"]
                r["notes"] = (existing + "; " if existing else "") + ov["notes"]


def build_conflicts(rows: list[dict]) -> list[dict]:
    """上下文感知冲突检测。

    过滤规则:
    - key_role=marker → 不参与冲突检测（符号占位符）
    - key_role=spec_value → 不参与冲突检测（规格不是业务 key）
    - key_role=local_label → 必须有 table_id 或 source_block_id 才参与
    - 缺少上下文的行出现多值时标记为 needs_review_context

    identity: (model, section_path, page_start, source_block_id, table_id, parent_key, key)
    """
    # 过滤参与冲突检测的行
    candidates = []
    skipped_marker = 0
    skipped_spec = 0
    skipped_local = 0
    for r in rows:
        kr = r.get("key_role", "business_key")
        if kr == "marker":
            skipped_marker += 1
            continue
        if kr == "spec_value":
            skipped_spec += 1
            continue
        if kr == "local_label":
            if not r.get("table_id") and not r.get("source_block_id"):
                skipped_local += 1
                continue
        candidates.append(r)

    # 分组：上下文感知 identity
    groups: dict[tuple, list[dict]] = defaultdict(list)
    for r in candidates:
        identity = (
            r.get("model", ""),
            r.get("section_path", ""),
            r.get("page_start", ""),
            r.get("source_block_id", ""),
            r.get("table_id", ""),
            r.get("parent_key", ""),
            r.get("key", ""),
        )
        groups[identity].append(r)

    # 统计参与 identity 的实际维度
    used_dims = _identity_dims(candidates)

    conflicts = []
    # 按 (model, section_path, key) 做跨上下文汇总，检测 needs_review_context
    cross_groups: dict[tuple, list[dict]] = defaultdict(list)
    for r in candidates:
        cross_pk = (r.get("model", ""), r.get("section_path", ""), r.get("key", ""))
        cross_groups[cross_pk].append(r)

    for identity, members in groups.items():
        values = list({m["value"] for m in members})
        if len(values) <= 1:
            continue
        cid = sha256(
            f"conflict|{'|'.join(str(x) for x in identity)}|"
            f"{'|'.join(sorted(values))}"
        )
        key_roles = list({m.get("key_role", "business_key") for m in members})
        conflicts.append({
            "conflict_id": cid,
            "model": identity[0],
            "section_path": identity[1],
            "page_start": identity[2],
            "source_block_id": identity[3],
            "table_id": identity[4],
            "parent_key": identity[5],
            "key": identity[6],
            "record_ids": ";".join(m["record_id"] for m in members),
            "values": ";".join(sorted(values)),
            "key_role_distribution": ";".join(sorted(key_roles)),
            "resolution_status": "unresolved",
            "notes": (
                f"{len(members)} rows, identity_dims={used_dims}, "
                f"filtered_out: marker={skipped_marker} spec={skipped_spec} "
                f"local_no_context={skipped_local}"
            ),
        })

    # 检测跨上下文仍多值但缺少页段/块上下文的 key
    for cross_pk, cross_members in cross_groups.items():
        cross_values = list({m["value"] for m in cross_members})
        if len(cross_values) <= 1:
            continue
        # 如果有行缺少页段或块上下文，标记 needs_review_context
        missing_ctx = [
            m for m in cross_members
            if not m.get("page_start") and not m.get("source_block_id")
        ]
        if missing_ctx and len(cross_members) > 1:
            # 检查这个 cross_pk 是否已被现有 conflicts 覆盖
            already_covered = any(
                c["model"] == cross_pk[0]
                and c["section_path"] == cross_pk[1]
                and c["key"] == cross_pk[2]
                and c["resolution_status"] == "unresolved"
                for c in conflicts
            )
            if not already_covered:
                cid = sha256(
                    f"needs_review_context|{cross_pk[0]}|{cross_pk[1]}|{cross_pk[2]}"
                )
                key_roles = list({m.get("key_role", "business_key") for m in cross_members})
                conflicts.append({
                    "conflict_id": cid,
                    "model": cross_pk[0],
                    "section_path": cross_pk[1],
                    "page_start": "",
                    "source_block_id": "",
                    "table_id": "",
                    "parent_key": "",
                    "key": cross_pk[2],
                    "record_ids": ";".join(m["record_id"] for m in cross_members),
                    "values": ";".join(sorted(cross_values)),
                    "key_role_distribution": ";".join(sorted(key_roles)),
                    "resolution_status": "needs_review_context",
                    "notes": (
                        f"{len(cross_members)} rows across contexts, "
                        f"{len(missing_ctx)} rows missing page or block context. "
                        f"identity_dims={used_dims}"
                    ),
                })

    return conflicts


def _identity_dims(candidates: list[dict]) -> str:
    """返回实际参与 identity 的维度名（用于冲突 notes）。"""
    dims = []
    if any(r.get("page_start") for r in candidates):
        dims.append("page_start")
    if any(r.get("source_block_id") for r in candidates):
        dims.append("source_block_id")
    if any(r.get("table_id") for r in candidates):
        dims.append("table_id")
    if any(r.get("parent_key") for r in candidates):
        dims.append("parent_key")
    return "+".join(dims) if dims else "model+section_path+key"


def compute_ingest_status(rows: list[dict], conflicts: list[dict]):
    """阶段 2 状态流转：approved+完整+无冲突→ready."""
    # Build sets of record_ids in unresolved / needs_review_context conflicts
    unresolved_ids: set[str] = set()
    review_context_ids: set[str] = set()
    for c in conflicts:
        rids = [rid.strip() for rid in c["record_ids"].split(";")]
        if c["resolution_status"] == "unresolved":
            unresolved_ids.update(rids)
        elif c["resolution_status"] == "needs_review_context":
            review_context_ids.update(rids)

    for r in rows:
        rs = r["review_status"]
        # rejected → skipped
        if rs == "rejected":
            r["ingest_status"] = "skipped"
            continue
        # needs_review → not_ready
        if rs == "needs_review":
            r["ingest_status"] = "not_ready"
            continue
        # draft → not_ready (no override applied)
        if rs == "draft":
            r["ingest_status"] = "not_ready"
            continue

        # approved: check if can go to ready
        issues = []
        if not r.get("evidence_text"):
            issues.append("missing_evidence")
        if not r.get("key"):
            issues.append("missing_key")
        if not r.get("value"):
            issues.append("missing_value")
        if r["record_id"] in unresolved_ids:
            issues.append("unresolved_conflict")
        if r["record_id"] in review_context_ids:
            issues.append("needs_review_context")

        if issues:
            r["ingest_status"] = "not_ready"
            existing = r["notes"]
            r["notes"] = (existing + "; " if existing else "") + "; ".join(issues)
        else:
            r["ingest_status"] = "ready"


def write_csv(path: Path, fieldnames: list[str], rows: list[dict]):
    path.parent.mkdir(parents=True, exist_ok=True)
    with open(path, "w", newline="", encoding="utf-8") as f:
        w = csv.DictWriter(f, fieldnames=fieldnames, extrasaction="ignore")
        w.writeheader()
        w.writerows(rows)


def main():
    if len(sys.argv) != 2:
        print("用法: scripts/pdf-prepare-ingest <package>", file=sys.stderr)
        print("示例: scripts/pdf-prepare-ingest pdf/demo20", file=sys.stderr)
        sys.exit(1)

    pkg = Path(sys.argv[1]).resolve()
    draft_path = pkg / "data" / "quick_lookup_draft.csv"
    override_path = pkg / "data" / "review_overrides.csv"
    ingest_path = pkg / "data" / "ingest_ready.csv"
    conflict_path = pkg / "data" / "conflicts.csv"

    draft_rows = read_draft(draft_path)
    ingest_rows = generate_ingest_rows(draft_rows)

    # Apply review overrides if present
    has_overrides = override_path.exists()
    if has_overrides:
        overrides = read_overrides(override_path)
        apply_overrides(ingest_rows, overrides)

    # Build conflicts
    conflicts = build_conflicts(ingest_rows)

    # Carry forward previously resolved conflicts
    prev_conflicts: dict[str, str] = {}
    if conflict_path.exists():
        with open(conflict_path, newline="", encoding="utf-8") as f:
            for row in csv.DictReader(f):
                if row.get("resolution_status") == "resolved":
                    prev_conflicts[row["conflict_id"]] = row.get("notes", "")
    for c in conflicts:
        if c["conflict_id"] in prev_conflicts:
            c["resolution_status"] = "resolved"
            c["notes"] = prev_conflicts[c["conflict_id"]]

    # Compute ingest status
    compute_ingest_status(ingest_rows, conflicts)

    # Write outputs
    write_csv(ingest_path, INGEST_FIELDS, ingest_rows)
    write_csv(conflict_path, CONFLICT_FIELDS, conflicts)

    ready = sum(1 for r in ingest_rows if r["ingest_status"] == "ready")
    not_ready = sum(1 for r in ingest_rows if r["ingest_status"] == "not_ready")
    skipped = sum(1 for r in ingest_rows if r["ingest_status"] == "skipped")
    print(f"入库准备完成: {pkg}/data/")
    print(f"  ingest_ready.csv: {len(ingest_rows)} 行 (ready: {ready}, not_ready: {not_ready}, skipped: {skipped})")
    print(f"  conflicts.csv: {len(conflicts)} 组冲突")
    if has_overrides:
        print(f"  review_overrides 已应用")


if __name__ == "__main__":
    main()
