#!/usr/bin/env python3
"""生成入库候选文件 ingest_ready.csv + conflicts.csv。

用法:
  scripts/pdf-prepare-ingest <package>

输入:
  <package>/data/quick_lookup_draft.csv
  <package>/data/review_overrides.csv    (可选; 阶段 2 人工审核输入)
  <package>/data/review_decisions.jsonl (可选; LLM/用户富结构审核输入)
  <package>/data/manual_fixes.jsonl      (可选; 阶段 3 fix_data 修正输入)

输出:
  <package>/data/ingest_ready.csv
  <package>/data/conflicts.csv
  <package>/data/escalation_queue.jsonl

不写入数据库，不修改原草案文件。fix_data 修正仅在内存在成时生效。
"""

import csv
import hashlib
import json
import sys
from collections import defaultdict
from pathlib import Path


INGEST_FIELDS = [
    "record_id", "source_pdf", "model", "section_path", "key", "value", "unit",
    "page_start", "page_end", "evidence_text", "confidence", "review_status", "ingest_status",
    "source_block_id", "table_id", "row_index", "parent_key", "key_role",
    "source_row_hash", "created_at", "notes",
    "correction_fix_id", "supersedes_record_id", "superseded_by",
    "candidate_id", "review_actor", "decision_basis", "review_rule_version",
    "candidate_hash", "reviewed_at",
]

DRAFT_FIELDS = [
    "source_pdf", "model", "section_path", "key", "value", "unit",
    "page_start", "page_end", "evidence_text", "confidence", "status", "notes",
]
# 注：阶段 1 新字段 (source_block_id/table_id/row_index/parent_key/key_role) 暂不纳入
# DRAFT_FIELDS hash，以保持 record_id 稳定。它们通过 INGEST_FIELDS 流入 ingest_ready.csv
# 并参与 build_conflicts 的上下文 identity。纳入 hash 的决策推迟到阶段 3。

CONFLICT_FIELDS = [
    "conflict_id", "model", "section_path", "page_start",
    "source_block_id", "table_id", "row_index", "parent_key", "key",
    "record_ids", "values", "key_role_distribution",
    "resolution_status", "notes",
]

OVERRIDE_FIELDS = ["record_id", "review_status", "notes"]
VALID_REVIEW_STATUSES = {"approved", "rejected", "needs_review"}
VALID_REVIEW_ACTORS = {"llm", "user"}
VALID_DECISION_BASES = {
    "evidence_exact",
    "rule_based_non_business",
    "user_confirmed",
    "ambiguous",
    "conflicting_evidence",
    "missing_evidence",
    "source_identity_ambiguous",
}
DECISION_FIELDS = {
    "candidate_id",
    "record_id",
    "review_status",
    "review_actor",
    "decision_basis",
    "review_rule_version",
    "candidate_hash",
    "reason",
    "reviewed_at",
}
ESCALATION_FIELDS = [
    "candidate_id", "record_id", "page_start", "page_end", "key", "value",
    "evidence_text", "candidate_hash", "current_candidate", "review_status",
    "ingest_status", "ambiguity_type", "requires_user", "recommended_action",
    "reason", "conflict_ids",
]

STATUS_MAP = {
    "draft": ("draft", "not_ready"),
    "needs_review": ("needs_review", "not_ready"),
    "rejected": ("rejected", "skipped"),
}


def sha256(s: str) -> str:
    return hashlib.sha256(s.encode("utf-8")).hexdigest()


def file_sha256(path: Path) -> str:
    """计算文件内容的 SHA-256。"""
    return hashlib.sha256(path.read_bytes()).hexdigest()


def compute_source_row_hash(row: dict) -> str:
    normalized = "|".join(row.get(f, "") for f in DRAFT_FIELDS)
    return sha256(normalized)


def compute_record_id(source_pdf: str, model: str, section_path: str,
                      key: str, value: str, unit: str, source_row_hash: str) -> str:
    raw = f"{source_pdf}|{model}|{section_path}|{key}|{value}|{unit}|{source_row_hash}"
    return sha256(raw)


def compute_candidate_id(row: dict, source_row_hash: str) -> str:
    """按来源位置生成候选身份，不把 key/value 纳入主身份。

    这样同一来源位置在内容修正后仍能关联到原候选；内容变化由
    candidate_hash 另行阻断过期审核决定。缺少来源位置时退回 source_row_hash，
    并由 duplicate candidate identity 检查阻止静默批量应用。
    """
    location = [
        row.get("source_pdf", ""),
        row.get("model", ""),
        row.get("section_path", ""),
        row.get("page_start", ""),
        row.get("page_end", ""),
        row.get("source_block_id", ""),
        row.get("table_id", ""),
        row.get("row_index", ""),
        row.get("parent_key", ""),
        row.get("key_role", ""),
        row.get("pair_index", row.get("subrow_index", "")),
    ]
    if not any(location[3:]):
        location.append(source_row_hash)
    return sha256("candidate-v1|" + "|".join(str(part) for part in location))


def compute_candidate_hash(row: dict, source_row_hash: str) -> str:
    """计算审核决定绑定的候选内容 hash。"""
    content = "|".join([
        row.get("source_pdf", ""), row.get("model", ""),
        row.get("section_path", ""), row.get("key", ""),
        row.get("value", ""), row.get("unit", ""),
        row.get("evidence_text", ""), source_row_hash,
    ])
    return sha256("candidate-content-v1|" + content)


def read_draft(path: Path) -> list[dict]:
    if not path.exists():
        sys.exit(f"错误：找不到草案文件: {path}")
    with open(path, newline="", encoding="utf-8") as f:
        return list(csv.DictReader(f))


def read_overrides(path: Path) -> dict[str, dict]:
    """读取审核覆盖文件，返回 {record_id: {review_status, notes}}.
    校验：字段合法、状态合法、无重复 record_id、不允许修改 key/value/unit/evidence_text。
    """
    if not path.exists():
        return {}
    with open(path, newline="", encoding="utf-8") as f:
        reader = csv.DictReader(f)
        if reader.fieldnames is None:
            return {}
        reader.fieldnames = [fn.strip() for fn in reader.fieldnames]
        for fn in OVERRIDE_FIELDS:
            if fn not in reader.fieldnames:
                sys.exit(f"错误：review_overrides.csv 缺少字段: {fn}")
        for fn in reader.fieldnames:
            if fn not in OVERRIDE_FIELDS:
                sys.exit(f"错误：review_overrides.csv 包含禁止字段: {fn}。只允许 {OVERRIDE_FIELDS}")
        overrides = {}
        rows = list(reader)
        for r in rows:
            rid = r.get("record_id", "").strip()
            if not rid:
                sys.exit("错误：review_overrides.csv 存在空 record_id")
            if rid in overrides:
                sys.exit(f"错误：review_overrides.csv 存在重复 record_id: {rid}")
            rs = r.get("review_status", "").strip()
            if rs not in VALID_REVIEW_STATUSES:
                sys.exit(f"错误：非法 review_status: '{rs}'。允许: {sorted(VALID_REVIEW_STATUSES)}")
            overrides[rid] = {
                "review_status": rs,
                "notes": r.get("notes", "").strip(),
            }
        return overrides


def read_review_decisions(path: Path) -> dict[str, dict]:
    """读取富结构审核决定，按 candidate_id 返回。

    该文件由 LLM/用户协作层产生，脚本只做契约、来源 hash 和安全边界校验，
    不自行推断 approved。"""
    if not path.exists():
        return {}

    decisions: dict[str, dict] = {}
    with path.open(encoding="utf-8") as f:
        for line_no, line in enumerate(f, 1):
            line = line.strip()
            if not line:
                continue
            try:
                decision = json.loads(line)
            except json.JSONDecodeError as exc:
                sys.exit(f"错误：review_decisions.jsonl 第 {line_no} 行不是合法 JSON: {exc}")
            if not isinstance(decision, dict):
                sys.exit(f"错误：review_decisions.jsonl 第 {line_no} 行必须是 JSON 对象")

            unknown = sorted(set(decision) - DECISION_FIELDS)
            if unknown:
                sys.exit(
                    f"错误：review_decisions.jsonl 第 {line_no} 行包含未知字段: "
                    f"{', '.join(unknown)}"
                )

            missing = sorted(
                field for field in ("candidate_id", "record_id", "review_status", "review_actor",
                                    "decision_basis", "review_rule_version",
                                    "candidate_hash", "reason")
                if not str(decision.get(field, "")).strip()
            )
            if missing:
                sys.exit(
                    f"错误：review_decisions.jsonl 第 {line_no} 行缺少字段: {', '.join(missing)}"
                )

            candidate_id = str(decision["candidate_id"]).strip()
            if candidate_id in decisions:
                sys.exit(f"错误：review_decisions.jsonl 存在重复 candidate_id: {candidate_id}")

            review_status = str(decision["review_status"]).strip()
            actor = str(decision["review_actor"]).strip()
            basis = str(decision["decision_basis"]).strip()
            if review_status not in VALID_REVIEW_STATUSES:
                sys.exit(f"错误：非法 review_status: '{review_status}'")
            if actor not in VALID_REVIEW_ACTORS:
                sys.exit(f"错误：非法 review_actor: '{actor}'，允许: {sorted(VALID_REVIEW_ACTORS)}")
            if basis not in VALID_DECISION_BASES:
                sys.exit(f"错误：非法 decision_basis: '{basis}'")
            if actor == "llm" and review_status == "approved" and basis != "evidence_exact":
                sys.exit("错误：LLM 只有 decision_basis=evidence_exact 才能 approved")
            if actor == "llm" and review_status == "rejected" and basis != "rule_based_non_business":
                sys.exit("错误：LLM 只有 decision_basis=rule_based_non_business 才能 rejected")
            if actor == "user" and review_status in {"approved", "rejected"} and basis != "user_confirmed":
                sys.exit("错误：用户批准/拒绝必须使用 decision_basis=user_confirmed")

            normalized = dict(decision)
            normalized["candidate_id"] = candidate_id
            normalized["review_status"] = review_status
            normalized["review_actor"] = actor
            normalized["decision_basis"] = basis
            normalized["review_rule_version"] = str(decision["review_rule_version"]).strip()
            normalized["candidate_hash"] = str(decision["candidate_hash"]).strip()
            normalized["reason"] = str(decision["reason"]).strip()
            normalized["record_id"] = str(decision.get("record_id", "")).strip()
            normalized["reviewed_at"] = str(decision.get("reviewed_at", "")).strip()
            decisions[candidate_id] = normalized
    return decisions


def _check_page_numbering_gate(pkg: Path, rows: list[dict]) -> list[dict]:
    """页码坐标系安全门禁。

    当 manifest.page_numbering.status 不是 verified 或 page_numbering 块缺失时，
    阻止所有记录进入 ready 状态。原地修改 rows，返回 rows。

    不修改 review_status 或 record_id — 只阻止 ready 状态并追加 notes。
    """
    manifest_path = pkg / "manifest.json"
    blocked = False
    reason = ""

    if not manifest_path.exists():
        blocked = True
        reason = "manifest.json 缺失"
    else:
        try:
            manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
        except (json.JSONDecodeError, OSError):
            blocked = True
            reason = "manifest.json 解析失败"
        else:
            pn = manifest.get("page_numbering")
            if not isinstance(pn, dict):
                blocked = True
                reason = "缺少 page_numbering 块（旧格式输出包或页码检测未运行）"
            else:
                status = pn.get("status", "needs_review")
                if status == "verified":
                    return rows  # 安全，放行（需人工确认）
                blocked = True
                mapping_type = pn.get("mapping_type", "unknown")
                if mapping_type == "unknown":
                    reason = "page_numbering.status=needs_review（mapping_type=unknown）"
                else:
                    offset = pn.get("printed_to_physical_offset", "?")
                    reason = (
                        f"page_numbering.status=needs_review（偏移={offset}，来源歧义）"
                    )

    if not blocked:
        return rows

    # 阻断：所有非终态记录 → not_ready
    blocked_count = 0
    for r in rows:
        if r.get("ingest_status") in ("superseded", "suppressed", "skipped"):
            continue
        if r["ingest_status"] != "ready":
            continue
        r["ingest_status"] = "not_ready"
        existing = r.get("notes", "")
        r["notes"] = (existing + "; " if existing else "") + (
            f"unverified_page_numbering: {reason}"
        )
        blocked_count += 1

    if blocked_count > 0:
        print(
            f"  ⚠ 入库阻断: {reason}（{blocked_count} 条 ready 降级为 not_ready）",
            file=sys.stderr,
        )
    else:
        print(f"  ⚠ 入库阻断: {reason}（无 ready 记录受影响）", file=sys.stderr)

    return rows


def generate_ingest_rows(draft_rows: list[dict]) -> list[dict]:
    rows = []
    for dr in draft_rows:
        source_row_hash = compute_source_row_hash(dr)
        review_status, ingest_status = STATUS_MAP.get(
            dr.get("status", "draft"), ("draft", "not_ready")
        )
        row = {
            "source_pdf": dr.get("source_pdf", ""),
            "model": dr.get("model", ""),
            "section_path": dr.get("section_path", ""),
            "key": dr.get("key", ""),
            "value": dr.get("value", ""),
            "unit": dr.get("unit", ""),
            "page_start": dr.get("page_start", ""),
            "page_end": dr.get("page_end", ""),
            "evidence_text": dr.get("evidence_text", ""),
            "confidence": dr.get("confidence", ""),
            "review_status": review_status,
            "ingest_status": ingest_status,
            "source_block_id": dr.get("source_block_id", ""),
            "table_id": dr.get("table_id", ""),
            "row_index": dr.get("row_index", ""),
            "parent_key": dr.get("parent_key", ""),
            "key_role": dr.get("key_role", "business_key"),
            "source_row_hash": source_row_hash,
            "created_at": "",
            "notes": dr.get("notes", ""),
        }
        row["candidate_id"] = compute_candidate_id(row, source_row_hash)
        row["candidate_hash"] = compute_candidate_hash(row, source_row_hash)
        row["review_actor"] = ""
        row["decision_basis"] = ""
        row["review_rule_version"] = ""
        row["reviewed_at"] = ""
        row["record_id"] = compute_record_id(
            row["source_pdf"], row["model"], row["section_path"],
            row["key"], row["value"], row["unit"], row["source_row_hash"],
        )
        rows.append(row)
    return rows


def refresh_candidate_hashes(rows: list[dict]) -> None:
    """在 fix_data 修正后重新计算内容 hash，阻断过期审核决定。"""
    for row in rows:
        row["candidate_hash"] = compute_candidate_hash(row, row["source_row_hash"])


def apply_overrides(rows: list[dict], overrides: dict[str, dict]):
    """应用旧 CSV 覆盖；record_id 必须唯一，禁止静默批量应用。"""
    record_rows: dict[str, list[dict]] = defaultdict(list)
    for row in rows:
        record_rows[row["record_id"]].append(row)

    for rid in overrides:
        matches = record_rows.get(rid, [])
        if not matches:
            sys.exit(f"错误：review_overrides.csv 包含未知 record_id: {rid}")
        if len(matches) != 1:
            sys.exit(
                "错误：review_overrides.csv 的 record_id 对应 "
                f"{len(matches)} 条候选，拒绝静默批量应用: {rid}；"
                "请改用 review_decisions.jsonl 的 candidate_id"
            )

    for rid, ov in overrides.items():
        row = record_rows[rid][0]
        row["review_status"] = ov["review_status"]
        if ov["notes"]:
            existing = row["notes"]
            row["notes"] = (existing + "; " if existing else "") + ov["notes"]


def apply_review_decisions(rows: list[dict], decisions: dict[str, dict]):
    """按 candidate_id 应用富结构审核决定，并拒绝歧义或过期绑定。"""
    if not decisions:
        return

    candidate_rows: dict[str, list[dict]] = defaultdict(list)
    for row in rows:
        if row.get("ingest_status") in {"superseded", "suppressed"}:
            continue
        candidate_rows[row["candidate_id"]].append(row)

    for candidate_id, decision in decisions.items():
        matches = candidate_rows.get(candidate_id, [])
        if not matches:
            sys.exit(f"错误：review_decisions.jsonl 包含未知 candidate_id: {candidate_id}")
        if len(matches) != 1:
            sys.exit(
                f"错误：candidate_id 对应 {len(matches)} 条候选，拒绝静默批量应用: {candidate_id}"
            )

        row = matches[0]
        supplied_record_id = decision.get("record_id", "")
        if supplied_record_id and supplied_record_id != row["record_id"]:
            sys.exit(
                f"错误：candidate_id 与 record_id 不匹配: {candidate_id}"
            )
        if decision["candidate_hash"] != row["candidate_hash"]:
            sys.exit(
                f"错误：candidate_hash 已过期，拒绝应用审核决定: {candidate_id}"
            )

        # 旧 review_overrides 若已写入不同状态，必须显式解决冲突。
        if row.get("review_status") not in {"draft", decision["review_status"]}:
            sys.exit(
                f"错误：review_decisions 与 review_overrides 状态冲突: {candidate_id}"
            )

        row["review_status"] = decision["review_status"]
        row["review_actor"] = decision["review_actor"]
        row["decision_basis"] = decision["decision_basis"]
        row["review_rule_version"] = decision["review_rule_version"]
        row["reviewed_at"] = decision["reviewed_at"]
        reason = decision["reason"]
        if reason:
            existing = row["notes"]
            marker = f"review_reason={reason}"
            row["notes"] = (existing + "; " if existing else "") + marker


def _write_jsonl(path: Path, rows: list[dict]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as f:
        for row in rows:
            f.write(json.dumps(row, ensure_ascii=False) + "\n")


def build_escalation_queue(rows: list[dict], conflicts: list[dict]) -> list[dict]:
    """生成只读升级队列；不改变任何审核或入库状态。"""
    conflict_by_record: dict[str, list[str]] = defaultdict(list)
    for conflict in conflicts:
        for record_id in conflict["record_ids"].split(";"):
            record_id = record_id.strip()
            if record_id:
                conflict_by_record[record_id].append(conflict["conflict_id"])

    candidate_counts = defaultdict(int)
    record_counts = defaultdict(int)
    for row in rows:
        candidate_counts[row["candidate_id"]] += 1
        record_counts[row["record_id"]] += 1

    queue = []
    for row in rows:
        if row.get("ingest_status") in {"superseded", "suppressed", "skipped"}:
            continue

        reasons: list[str] = []
        recommended_action = "llm_review"
        requires_user = False
        conflict_ids = conflict_by_record.get(row["record_id"], [])
        if row.get("review_status") == "draft":
            reasons.append("llm_review_pending")
        elif row.get("review_status") == "needs_review":
            reasons.append("review_needs_user")
            requires_user = True
            recommended_action = "user_confirm"
        if candidate_counts[row["candidate_id"]] > 1:
            reasons.append("duplicate_candidate_identity")
            requires_user = True
            recommended_action = "user_confirm"
        if record_counts[row["record_id"]] > 1:
            reasons.append("duplicate_record_identity")
            requires_user = True
            recommended_action = "user_confirm"
        if conflict_ids:
            reasons.append("unresolved_conflict")
            requires_user = True
            recommended_action = "user_confirm"
        for field in ("evidence_text", "key", "value"):
            if not row.get(field):
                reasons.append(f"missing_{field}")
                requires_user = True
                recommended_action = "user_confirm"

        if row.get("ingest_status") == "not_ready" and not reasons:
            reasons.append("ingest_gate_blocked")
            requires_user = True
            recommended_action = "user_confirm"

        if not reasons:
            continue
        queue.append({
            "candidate_id": row["candidate_id"],
            "record_id": row["record_id"],
            "page_start": row.get("page_start", ""),
            "page_end": row.get("page_end", ""),
            "key": row.get("key", ""),
            "value": row.get("value", ""),
            "evidence_text": row.get("evidence_text", ""),
            "candidate_hash": row.get("candidate_hash", ""),
            "current_candidate": {
                "key": row.get("key", ""),
                "value": row.get("value", ""),
                "unit": row.get("unit", ""),
            },
            "review_status": row.get("review_status", ""),
            "ingest_status": row.get("ingest_status", ""),
            "ambiguity_type": ";".join(reasons),
            "requires_user": requires_user,
            "recommended_action": recommended_action,
            "reason": row.get("notes", ""),
            "conflict_ids": ";".join(conflict_ids),
        })
    return queue


def build_conflicts(rows: list[dict]) -> list[dict]:
    """上下文感知冲突检测。

    过滤规则:
    - key_role=marker → 不参与冲突检测（符号占位符）
    - key_role=spec_value → 不参与冲突检测（规格不是业务 key）
    - key_role=local_label → 必须有 table_id 或 source_block_id 才参与
    - 缺少上下文的行出现多值时标记为 needs_review_context

    identity: (model, section_path, page_start, source_block_id, table_id,
               row_index, parent_key, key)
    """
    # 过滤参与冲突检测的行
    candidates = []
    skipped_marker = 0
    skipped_spec = 0
    skipped_local = 0
    for r in rows:
        kr = r.get("key_role", "business_key")
        if kr == "marker":
            skipped_marker += 1
            continue
        if kr == "spec_value":
            skipped_spec += 1
            continue
        if kr == "local_label":
            if not r.get("table_id") and not r.get("source_block_id"):
                skipped_local += 1
                continue
        candidates.append(r)

    # 分组：上下文感知 identity
    groups: dict[tuple, list[dict]] = defaultdict(list)
    for r in candidates:
        identity = (
            r.get("model", ""),
            r.get("section_path", ""),
            r.get("page_start", ""),
            r.get("source_block_id", ""),
            r.get("table_id", ""),
            r.get("row_index", ""),
            r.get("parent_key", ""),
            r.get("key", ""),
        )
        groups[identity].append(r)

    # 统计参与 identity 的实际维度
    used_dims = _identity_dims(candidates)

    conflicts = []
    # 按 (model, section_path, key) 做跨上下文汇总，检测 needs_review_context
    cross_groups: dict[tuple, list[dict]] = defaultdict(list)
    for r in candidates:
        cross_pk = (r.get("model", ""), r.get("section_path", ""), r.get("key", ""))
        cross_groups[cross_pk].append(r)

    for identity, members in groups.items():
        values = list({m["value"] for m in members})
        if len(values) <= 1:
            continue
        cid = sha256(
            f"conflict|{'|'.join(str(x) for x in identity)}|"
            f"{'|'.join(sorted(values))}"
        )
        key_roles = list({m.get("key_role", "business_key") for m in members})
        conflicts.append({
            "conflict_id": cid,
            "model": identity[0],
            "section_path": identity[1],
            "page_start": identity[2],
            "source_block_id": identity[3],
            "table_id": identity[4],
            "row_index": identity[5],
            "parent_key": identity[6],
            "key": identity[7],
            "record_ids": ";".join(m["record_id"] for m in members),
            "values": ";".join(sorted(values)),
            "key_role_distribution": ";".join(sorted(key_roles)),
            "resolution_status": "unresolved",
            "notes": (
                f"{len(members)} rows, identity_dims={used_dims}+row_index, "
                f"filtered_out: marker={skipped_marker} spec={skipped_spec} "
                f"local_no_context={skipped_local}"
            ),
        })

    # 检测跨上下文仍多值但缺少页段/块上下文的 key
    for cross_pk, cross_members in cross_groups.items():
        cross_values = list({m["value"] for m in cross_members})
        if len(cross_values) <= 1:
            continue
        # 如果有行缺少页段或块上下文，标记 needs_review_context
        missing_ctx = [
            m for m in cross_members
            if not m.get("page_start") and not m.get("source_block_id")
        ]
        if missing_ctx and len(cross_members) > 1:
            # 检查这个 cross_pk 是否已被现有 conflicts 覆盖
            already_covered = any(
                c["model"] == cross_pk[0]
                and c["section_path"] == cross_pk[1]
                and c["key"] == cross_pk[2]
                and c["resolution_status"] == "unresolved"
                for c in conflicts
            )
            if not already_covered:
                cid = sha256(
                    f"needs_review_context|{cross_pk[0]}|{cross_pk[1]}|{cross_pk[2]}"
                )
                key_roles = list({m.get("key_role", "business_key") for m in cross_members})
                conflicts.append({
                    "conflict_id": cid,
                    "model": cross_pk[0],
                    "section_path": cross_pk[1],
                    "page_start": "",
                    "source_block_id": "",
                    "table_id": "",
                    "parent_key": "",
                    "key": cross_pk[2],
                    "record_ids": ";".join(m["record_id"] for m in cross_members),
                    "values": ";".join(sorted(cross_values)),
                    "key_role_distribution": ";".join(sorted(key_roles)),
                    "resolution_status": "needs_review_context",
                    "notes": (
                        f"{len(cross_members)} rows across contexts, "
                        f"{len(missing_ctx)} rows missing page or block context. "
                        f"identity_dims={used_dims}"
                    ),
                })

    return conflicts


def _identity_dims(candidates: list[dict]) -> str:
    """返回实际参与 identity 的维度名（用于冲突 notes）。"""
    dims = []
    if any(r.get("page_start") for r in candidates):
        dims.append("page_start")
    if any(r.get("source_block_id") for r in candidates):
        dims.append("source_block_id")
    if any(r.get("table_id") for r in candidates):
        dims.append("table_id")
    if any(r.get("parent_key") for r in candidates):
        dims.append("parent_key")
    return "+".join(dims) if dims else "model+section_path+key"


def compute_ingest_status(rows: list[dict], conflicts: list[dict]):
    """阶段 2 状态流转：approved+完整+无冲突→ready."""
    # Build sets of record_ids in unresolved / needs_review_context conflicts
    unresolved_ids: set[str] = set()
    review_context_ids: set[str] = set()
    for c in conflicts:
        rids = [rid.strip() for rid in c["record_ids"].split(";")]
        if c["resolution_status"] == "unresolved":
            unresolved_ids.update(rids)
        elif c["resolution_status"] == "needs_review_context":
            review_context_ids.update(rids)

    for r in rows:
        # 保留 apply_corrections() 设置的终态（rekey/suppress）
        if r.get("ingest_status") in ("superseded", "suppressed"):
            continue
        rs = r["review_status"]
        # rejected → skipped
        if rs == "rejected":
            r["ingest_status"] = "skipped"
            continue
        # needs_review → not_ready
        if rs == "needs_review":
            r["ingest_status"] = "not_ready"
            continue
        # draft → not_ready (no override applied)
        if rs == "draft":
            r["ingest_status"] = "not_ready"
            continue

        # 阶段 3：有 fix_data 修正的记录强制 not_ready（需重新审核）
        if r.get("correction_fix_id"):
            r["ingest_status"] = "not_ready"
            existing = r["notes"]
            r["notes"] = (existing + "; " if existing else "") + "data_corrected"
            continue

        # approved: check if can go to ready
        issues = []
        if not r.get("evidence_text"):
            issues.append("missing_evidence")
        if not r.get("key"):
            issues.append("missing_key")
        if not r.get("value"):
            issues.append("missing_value")
        if r["record_id"] in unresolved_ids:
            issues.append("unresolved_conflict")
        if r["record_id"] in review_context_ids:
            issues.append("needs_review_context")

        if issues:
            r["ingest_status"] = "not_ready"
            existing = r["notes"]
            r["notes"] = (existing + "; " if existing else "") + "; ".join(issues)
        else:
            r["ingest_status"] = "ready"


# ── 阶段 3：fix_data 修正加载与应用 ──────────────────────────


def load_fix_data_entries(pkg_dir: Path) -> dict[str, list[dict]]:
    """从 manual_fixes.jsonl 读取 review_action=fix_data 且 status=applied 的条目。

    返回 {record_id: [{field, new_value, action, fix_id}, ...]} 映射。
    同一 record_id 可有多个修正（如同时修正 value 和 unit）。
    manual_fixes.jsonl 不存在或无 fix_data 条目时返回空 dict。
    """
    fixes_path = pkg_dir / "data" / "manual_fixes.jsonl"
    if not fixes_path.exists():
        return {}

    entries: dict[str, list[dict]] = {}
    with fixes_path.open(encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue
            if (obj.get("review_action") != "fix_data"
                    or obj.get("status") != "applied"):
                continue
            rid = obj.get("target_record_id", "").strip()
            fa = obj.get("field_action", "amend").strip()
            tf = obj.get("target_field", "").strip()
            nv = obj.get("new_value", "")
            fix_id = obj.get("fix_id", "").strip()
            if not rid or not tf or not fix_id:
                continue
            entries.setdefault(rid, []).append({
                "field": tf,
                "new_value": nv,
                "action": fa,
                "fix_id": fix_id,
            })
    return entries


def apply_corrections(rows: list[dict],
                      corrections: dict[str, list[dict]]) -> list[dict]:
    """在内存中对 ingest 行应用 fix_data 修正。

    - amend: 更新字段值，保持 record_id，设置 correction_fix_id
    - rekey: 旧行标记 superseded，创建新行（新 record_id）
    - suppress: 标记 suppressed
    - 同一 record_id 的多条修正按加载顺序依次应用

    返回修改后的行列表（rekey 会增加行数）。
    """
    if not corrections:
        return rows

    # 构建 record_id → row_index 快速查找
    row_index: dict[str, int] = {}
    for i, r in enumerate(rows):
        row_index[r["record_id"]] = i

    new_rows: list[dict] = []  # rekey 产生的新行，先收集后追加

    for rid, corr_list in corrections.items():
        if rid not in row_index:
            continue  # record_id 不在当前 ingest 中，跳过
        idx = row_index[rid]
        r = rows[idx]

        for corr in corr_list:
            action = corr["action"]
            field = corr["field"]
            new_value = corr["new_value"]
            fix_id = corr["fix_id"]

            if action == "amend":
                # 更新目标字段值，保持 record_id
                r[field] = new_value
                r["correction_fix_id"] = fix_id

            elif action == "rekey":
                # 先拷贝旧行，再标记旧行为 superseded
                new_row = dict(r)
                r["ingest_status"] = "superseded"
                new_row[field] = new_value
                new_row["ingest_status"] = "not_ready"
                new_row["correction_fix_id"] = fix_id
                new_row["supersedes_record_id"] = rid
                new_row["superseded_by"] = ""
                # 重新计算 record_id（基于新 key）
                new_row["record_id"] = compute_record_id(
                    new_row["source_pdf"], new_row["model"],
                    new_row["section_path"], new_row["key"],
                    new_row["value"], new_row["unit"],
                    new_row["source_row_hash"],
                )
                # 旧行记录 superseded_by
                r["superseded_by"] = new_row["record_id"]
                new_rows.append(new_row)

            elif action == "suppress":
                r["ingest_status"] = "suppressed"
                existing = r["notes"]
                r["notes"] = (existing + "; " if existing else ""
                             ) + f"suppressed_by: {fix_id}"

    if new_rows:
        rows.extend(new_rows)
    return rows


def write_csv(path: Path, fieldnames: list[str], rows: list[dict]):
    path.parent.mkdir(parents=True, exist_ok=True)
    with open(path, "w", newline="", encoding="utf-8") as f:
        w = csv.DictWriter(f, fieldnames=fieldnames, extrasaction="ignore",
                          lineterminator='\n')
        w.writeheader()
        w.writerows(rows)


def main():
    if len(sys.argv) != 2:
        print("用法: scripts/pdf-prepare-ingest <package>", file=sys.stderr)
        print("示例: scripts/pdf-prepare-ingest pdf/demo20", file=sys.stderr)
        sys.exit(1)

    pkg = Path(sys.argv[1]).resolve()
    draft_path = pkg / "data" / "quick_lookup_draft.csv"
    override_path = pkg / "data" / "review_overrides.csv"
    decision_path = pkg / "data" / "review_decisions.jsonl"
    ingest_path = pkg / "data" / "ingest_ready.csv"
    conflict_path = pkg / "data" / "conflicts.csv"
    escalation_path = pkg / "data" / "escalation_queue.jsonl"

    draft_rows = read_draft(draft_path)
    ingest_rows = generate_ingest_rows(draft_rows)

    # 阶段 3：加载并应用 fix_data 修正
    fix_entries = load_fix_data_entries(pkg)
    has_fix_data = bool(fix_entries)
    ingest_before_sha256 = ""
    if has_fix_data and ingest_path.exists():
        ingest_before_sha256 = file_sha256(ingest_path)

    if has_fix_data:
        ingest_rows = apply_corrections(ingest_rows, fix_entries)
        refresh_candidate_hashes(ingest_rows)

    # Apply review overrides if present
    has_overrides = override_path.exists()
    if has_overrides:
        overrides = read_overrides(override_path)
        apply_overrides(ingest_rows, overrides)

    # Apply rich LLM/user decisions if present. The file is an input and is
    # never inferred or rewritten by this deterministic script.
    has_decisions = decision_path.exists()
    if has_decisions:
        decisions = read_review_decisions(decision_path)
        apply_review_decisions(ingest_rows, decisions)

    # Build conflicts
    conflicts = build_conflicts(ingest_rows)

    # Carry forward previously resolved conflicts
    prev_conflicts: dict[str, str] = {}
    if conflict_path.exists():
        with open(conflict_path, newline="", encoding="utf-8") as f:
            for row in csv.DictReader(f):
                if row.get("resolution_status") == "resolved":
                    prev_conflicts[row["conflict_id"]] = row.get("notes", "")
    for c in conflicts:
        if c["conflict_id"] in prev_conflicts:
            c["resolution_status"] = "resolved"
            c["notes"] = prev_conflicts[c["conflict_id"]]

    # Compute ingest status
    compute_ingest_status(ingest_rows, conflicts)

    # ── 页码坐标系安全门禁 ──
    # 当 page_numbering 未验证时，阻止所有 ready 记录（最终安全检查）
    ingest_rows = _check_page_numbering_gate(pkg, ingest_rows)

    escalation_queue = build_escalation_queue(ingest_rows, conflicts)

    # Write outputs
    write_csv(ingest_path, INGEST_FIELDS, ingest_rows)
    write_csv(conflict_path, CONFLICT_FIELDS, conflicts)
    _write_jsonl(escalation_path, escalation_queue)

    # 阶段 3：同步 manifest.json 的 fixes 块
    if has_fix_data:
        ingest_after_sha256 = file_sha256(ingest_path)
        manifest_path = pkg / "manifest.json"
        if manifest_path.exists():
            with open(manifest_path, encoding="utf-8") as f:
                manifest = json.load(f)
            fixes = manifest.setdefault("fixes", {})
            fixes["data_fixes_applied"] = True
            fixes["data_fix_count"] = sum(len(v) for v in fix_entries.values())
            if ingest_before_sha256:
                fixes["ingest_before_sha256"] = ingest_before_sha256
            fixes["ingest_after_sha256"] = ingest_after_sha256
            # 同步 manual_fixes.jsonl hash（如果存在）
            fixes_path = pkg / "data" / "manual_fixes.jsonl"
            if fixes_path.exists():
                fixes["manual_fixes_sha256"] = file_sha256(fixes_path)
            with open(manifest_path, "w", encoding="utf-8") as f:
                json.dump(manifest, f, ensure_ascii=False, indent=2)
                f.write("\n")

    ready = sum(1 for r in ingest_rows if r["ingest_status"] == "ready")
    not_ready = sum(1 for r in ingest_rows if r["ingest_status"] == "not_ready")
    skipped = sum(1 for r in ingest_rows if r["ingest_status"] == "skipped")
    suppressed = sum(1 for r in ingest_rows if r["ingest_status"] == "suppressed")
    superseded = sum(1 for r in ingest_rows if r["ingest_status"] == "superseded")
    print(f"入库准备完成: {pkg}/data/")
    print(f"  ingest_ready.csv: {len(ingest_rows)} 行 (ready: {ready}, not_ready: {not_ready}, skipped: {skipped}"
          f"{', suppressed: ' + str(suppressed) if suppressed else ''}"
          f"{', superseded: ' + str(superseded) if superseded else ''})")
    print(f"  conflicts.csv: {len(conflicts)} 组冲突")
    if has_overrides:
        print(f"  review_overrides 已应用")
    if has_decisions:
        llm_count = sum(1 for r in ingest_rows if r.get("review_actor") == "llm")
        user_count = sum(1 for r in ingest_rows if r.get("review_actor") == "user")
        print(f"  review_decisions 已应用 (LLM: {llm_count}, 用户: {user_count})")
    print(
        f"  escalation_queue.jsonl: {len(escalation_queue)} 条 "
        f"(需用户确认: {sum(1 for r in escalation_queue if r['requires_user'])})"
    )
    if has_fix_data:
        total_corrections = sum(len(v) for v in fix_entries.values())
        print(f"  fix_data 修正已应用: {total_corrections} 条")


if __name__ == "__main__":
    main()
