#!/usr/bin/env python3
"""pdf2md-fix 修复记录与 manifest 校验工具。

验证 manual_fixes.jsonl、manifest.json.fixes、manifest.json.formatting 的
格式完整性和一致性。在应用修复前后运行，确保修复产物符合契约。

用法:
  scripts/pdf-check-fixes [--verbose] <package_dir>

退出码:
  0 = 全部校验通过
  1 = 校验失败（stderr 输出具体错误）
"""

import hashlib
import json
import re
import sys
from html.parser import HTMLParser
from pathlib import Path

# ── 枚举常量 ───────────────────────────────────────────────
FIX_TYPES = frozenset({
    "rebuild_table", "fix_header", "fill_content", "cross_page_table",
    "table_layout", "missing_text", "section_attribution",
    "field_correction", "image_ocr",
})
REVIEW_ACTIONS = frozenset({"pass", "fix_md", "rerun", "fix_data"})
FIX_STATUSES = frozenset({"proposed", "applied", "verified", "rejected"})
MANIFEST_FIX_STATUSES = frozenset({"none", "pending", "applied", "verified"})
FORMATTING_STATUSES = frozenset({"none", "applied", "verified"})
FIX_SCHEMA_VERSION = 1
FORMATTING_SCHEMA_VERSION = 1
FIELD_ACTIONS = frozenset({"amend", "rekey", "suppress"})
FIXDATA_TARGET_FIELDS = frozenset({"key", "value", "unit", "section_path"})

# ── HTML 表格解析器（复用 table_eval.py 的 _TableStructParser） ──


class _TableStructParser(HTMLParser):
    """收集表格为 rows=[[cell, ...], ...]，每个 cell 记录 colspan/rowspan/text。

    直接从 scripts/lib/table_eval.py 复制，避免运行时依赖 scripts/lib 路径。
    """

    def __init__(self):
        super().__init__(convert_charrefs=True)
        self.rows = []
        self._cur_row = None
        self._cur_cell = None
        self._cur_text = []

    @staticmethod
    def _span(attrs, name):
        d = dict(attrs)
        try:
            v = int(d.get(name, 1) or 1)
        except (TypeError, ValueError):
            v = 1
        return max(v, 1)

    def handle_starttag(self, tag, attrs):
        if tag == "tr":
            self._cur_row = []
        elif tag in ("td", "th") and self._cur_row is not None:
            self._cur_cell = {
                "colspan": self._span(attrs, "colspan"),
                "rowspan": self._span(attrs, "rowspan"),
            }
            self._cur_text = []

    def handle_data(self, data):
        if self._cur_cell is not None:
            self._cur_text.append(data)

    def handle_endtag(self, tag):
        if tag in ("td", "th") and self._cur_cell is not None:
            self._cur_cell["text"] = "".join(self._cur_text).strip()
            self._cur_row.append(self._cur_cell)
            self._cur_cell = None
            self._cur_text = []
        elif tag == "tr" and self._cur_row is not None:
            self.rows.append(self._cur_row)
            self._cur_row = None

    def close(self):
        super().close()
        if self._cur_cell is not None and self._cur_row is not None:
            self._cur_cell["text"] = "".join(self._cur_text).strip()
            self._cur_row.append(self._cur_cell)
        if self._cur_row is not None:
            self.rows.append(self._cur_row)


def parse_html_tables(md_text: str) -> list[list[list[dict]]]:
    """从 Markdown 文本中提取所有 HTML 表格，返回 tables = [rows = [cell, ...], ...]。

    每个 cell: {"colspan": int, "rowspan": int, "text": str}
    """
    tables = []
    parser = _TableStructParser()
    in_table = False
    for line in md_text.split("\n"):
        if "<table" in line.lower():
            in_table = True
            parser = _TableStructParser()
        if in_table:
            parser.feed(line + "\n")
        if in_table and "</table>" in line.lower():
            parser.close()
            tables.append(parser.rows)
            in_table = False
    return tables


def cell_texts_equal(a: str, b: str) -> bool:
    """比较两个单元格文本是否相等，忽略空白差异。"""
    return re.sub(r"\s+", "", a) == re.sub(r"\s+", "", b)


# ── 工具函数 ───────────────────────────────────────────────


def file_sha256(path: Path) -> str:
    """计算文件内容 SHA-256。"""
    return hashlib.sha256(path.read_bytes()).hexdigest()


def _log(msg: str, kind: str = "ERROR"):
    print(f"{kind}: {msg}", file=sys.stderr)


# ── 校验函数（各返回 str 列表，每项一条错误） ──────────────────


def validate_manual_fixes(path: Path, manifest: dict | None = None) -> list[str]:
    """校验 manual_fixes.jsonl 格式。

    文件不存在时：
    - 若 manifest.fixes.status 为 applied/verified → 错误（应有修复记录）
    - 否则 → 跳过（新包尚未有修复记录）
    """
    errors = []
    if not path.exists():
        # 只有确认应有修复记录时才报错
        fixes = (manifest or {}).get("fixes")
        if isinstance(fixes, dict) and fixes.get("status") in ("applied", "verified"):
            errors.append(f"manual_fixes.jsonl 不存在但 fixes.status 为 {fixes['status']}")
        return errors
    if path.stat().st_size == 0:
        errors.append(f"manual_fixes.jsonl 为空文件：{path}")
        return errors

    with path.open(encoding="utf-8") as f:
        for lineno, line in enumerate(f, start=1):
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except json.JSONDecodeError as e:
                errors.append(f"第 {lineno} 行 JSON 解析失败：{e}")
                continue

            if not isinstance(obj, dict):
                errors.append(f"第 {lineno} 行不是 JSON 对象")
                continue

            # 必含字段
            for field in ("fix_id", "fix_type", "review_action", "status", "pages"):
                if field not in obj:
                    errors.append(f"第 {lineno} 行缺少必含字段：{field}")

            # 枚举校验
            if "fix_type" in obj and obj["fix_type"] not in FIX_TYPES:
                errors.append(
                    f"第 {lineno} 行 fix_type 不合法：{obj['fix_type']}"
                    f"（允许：{', '.join(sorted(FIX_TYPES))}）"
                )
            if "review_action" in obj and obj["review_action"] not in REVIEW_ACTIONS:
                errors.append(
                    f"第 {lineno} 行 review_action 不合法：{obj['review_action']}"
                    f"（允许：{', '.join(sorted(REVIEW_ACTIONS))}）"
                )
            if "status" in obj and obj["status"] not in FIX_STATUSES:
                errors.append(
                    f"第 {lineno} 行 status 不合法：{obj['status']}"
                    f"（允许：{', '.join(sorted(FIX_STATUSES))}）"
                )

            # pages 校验
            pages = obj.get("pages")
            if pages is not None:
                if not isinstance(pages, list) or not pages:
                    errors.append(f"第 {lineno} 行 pages 必须是非空列表")
                else:
                    for i, p in enumerate(pages):
                        if not isinstance(p, int) or p < 1:
                            errors.append(
                                f"第 {lineno} 行 pages[{i}] 不是正整数：{p}"
                            )

            # before / after / evidence 非空
            for field in ("before", "after", "evidence"):
                val = obj.get(field)
                if not val or not isinstance(val, str) or not val.strip():
                    errors.append(f"第 {lineno} 行 {field} 不能为空")

            # fix_data 专属字段校验（仅 review_action=fix_data 时触发）
            if obj.get("review_action") == "fix_data":
                for field in ("target_record_id", "target_field", "field_action"):
                    val = obj.get(field)
                    if not val or not isinstance(val, str) or not val.strip():
                        errors.append(
                            f"第 {lineno} 行 review_action=fix_data 缺少字段：{field}"
                        )
                # old_value / new_value 允许空字符串（suppress、清除字段等场景）
                for field in ("old_value", "new_value"):
                    val = obj.get(field)
                    if val is None or not isinstance(val, str):
                        errors.append(
                            f"第 {lineno} 行 review_action=fix_data 缺少字段：{field}"
                        )
                fa = obj.get("field_action")
                if fa and fa not in FIELD_ACTIONS:
                    errors.append(
                        f"第 {lineno} 行 field_action 不合法：{fa}"
                        f"（允许：{', '.join(sorted(FIELD_ACTIONS))}）"
                    )
                tf = obj.get("target_field")
                if tf and tf not in FIXDATA_TARGET_FIELDS:
                    errors.append(
                        f"第 {lineno} 行 target_field 不合法：{tf}"
                        f"（允许：{', '.join(sorted(FIXDATA_TARGET_FIELDS))}）"
                    )

    return errors


def validate_vlm_evidence(path: Path) -> list[str]:
    """校验 manual_fixes.jsonl 中的 VLM 证据引用。"""
    errors = []
    if not path.exists():
        return errors  # 文件不存在由 validate_manual_fixes 报错

    with path.open(encoding="utf-8") as f:
        for lineno, line in enumerate(f, start=1):
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue
            if not isinstance(obj, dict):
                continue

            vlm = obj.get("vlm_evidence")
            if not vlm:
                continue
            if not isinstance(vlm, dict):
                errors.append(f"第 {lineno} 行 vlm_evidence 必须是对象")
                continue
            for field in ("model", "input_pages", "human_conclusion"):
                if field not in vlm:
                    errors.append(
                        f"第 {lineno} 行 vlm_evidence 缺少字段：{field}"
                    )

    return errors


def validate_manifest_fixes(manifest: dict, pkg_dir: Path) -> list[str]:
    """校验 manifest.json 中的 fixes 块。

    缺少 fixes 块时：
    - 若 manual_fixes.jsonl 存在且有 applied/verified 记录 → 错误
    - 否则 → 跳过（新包尚未有修复记录）
    """
    errors = []
    fixes = manifest.get("fixes")
    if fixes is None:
        # 检查是否实际有修复记录需要追踪
        fixes_path = pkg_dir / "data" / "manual_fixes.jsonl"
        if fixes_path.exists() and fixes_path.stat().st_size > 0:
            errors.append("manifest.json 缺少 fixes 块但 manual_fixes.jsonl 存在")
        return errors

    if not isinstance(fixes, dict):
        errors.append("manifest.json.fixes 必须是对象")
        return errors

    # schema_version
    sv = fixes.get("schema_version")
    if sv != FIX_SCHEMA_VERSION:
        errors.append(
            f"fixes.schema_version 应为 {FIX_SCHEMA_VERSION}，实际：{sv}"
        )

    # status
    status = fixes.get("status")
    if status not in MANIFEST_FIX_STATUSES:
        errors.append(
            f"fixes.status 不合法：{status}"
            f"（允许：{', '.join(sorted(MANIFEST_FIX_STATUSES))}）"
        )

    # source_manifest_sha256 — 审计字段，记录修复时的 manifest hash，不比较当前值

    # manual_fixes_sha256 — 如果 manual_fixes.jsonl 存在
    fixes_path = pkg_dir / "data" / "manual_fixes.jsonl"
    if fixes_path.exists():
        expected_mf_hash = file_sha256(fixes_path)
        actual_mf_hash = fixes.get("manual_fixes_sha256")
        if actual_mf_hash != expected_mf_hash:
            errors.append(
                f"fixes.manual_fixes_sha256 不匹配"
                f"（期望：{expected_mf_hash}，实际：{actual_mf_hash}）"
            )

    # markdown_sha256 — 校验当前 canonical Markdown
    md_rel = manifest.get("files", {}).get("markdown")
    if md_rel:
        md_path = pkg_dir / md_rel
        if md_path.exists():
            expected_md_hash = file_sha256(md_path)
            actual_md_hash = fixes.get("markdown_sha256")
            if actual_md_hash != expected_md_hash:
                errors.append(
                    f"fixes.markdown_sha256 不匹配"
                    f"（期望：{expected_md_hash}，实际：{actual_md_hash}）"
                )

    # 阶段 3：data_fixes 字段
    df_applied = fixes.get("data_fixes_applied")
    if df_applied is True:
        df_count = fixes.get("data_fix_count")
        if not isinstance(df_count, int) or df_count < 1:
            errors.append(
                "fixes.data_fixes_applied=true 但 data_fix_count 缺失或无效"
            )
        # ingest_after_sha256 必须匹配当前 ingest_ready.csv
        ingest_path = pkg_dir / "data" / "ingest_ready.csv"
        if ingest_path.exists():
            expected_ingest_hash = file_sha256(ingest_path)
            after_hash = fixes.get("ingest_after_sha256")
            if after_hash and after_hash != expected_ingest_hash:
                errors.append(
                    f"fixes.ingest_after_sha256 不匹配"
                    f"（期望：{expected_ingest_hash}，实际：{after_hash}）"
                )
            elif not after_hash:
                errors.append(
                    "fixes.data_fixes_applied=true 但 ingest_after_sha256 缺失"
                )
        # ingest_before_sha256 是审计字段，不验证当前值
        ib_hash = fixes.get("ingest_before_sha256")
        if not ib_hash:
            errors.append(
                "fixes.data_fixes_applied=true 但 ingest_before_sha256 缺失"
            )
    elif df_applied is False or df_applied is None:
        # 无 fix_data 时不应有残留字段
        if fixes.get("data_fix_count", 0) != 0:
            errors.append(
                "fixes.data_fixes_applied 未设置但 data_fix_count 非零"
            )

    return errors


def validate_formatting(manifest: dict, pkg_dir: Path) -> list[str]:
    """校验 manifest.json 中的 formatting 块（升级版：验证 hash 一致性）。"""
    errors = []
    fmt = manifest.get("formatting")
    if fmt is None:
        errors.append("manifest.json 缺少 formatting 块")
        return errors

    if not isinstance(fmt, dict):
        errors.append("manifest.json.formatting 必须是对象")
        return errors

    # schema_version
    sv = fmt.get("schema_version")
    if sv != FORMATTING_SCHEMA_VERSION:
        errors.append(
            f"formatting.schema_version 应为 {FORMATTING_SCHEMA_VERSION}，实际：{sv}"
        )

    # mode
    mode = fmt.get("mode")
    if mode != "merge_time":
        errors.append(f"formatting.mode 应为 merge_time，实际：{mode}")

    # status
    status = fmt.get("status")
    if status not in FORMATTING_STATUSES:
        errors.append(
            f"formatting.status 不合法：{status}"
            f"（允许：{', '.join(sorted(FORMATTING_STATUSES))}）"
        )

    # source_markdown_sha256 非空（applied/verified 时必须）
    source_hash = fmt.get("source_markdown_sha256")
    if status in ("applied", "verified") and not source_hash:
        errors.append(
            f"formatting.status={status} 但 source_markdown_sha256 为空"
        )

    # formatted_markdown_sha256 必须与当前 Markdown 一致（applied/verified 时）
    formatted_hash = fmt.get("formatted_markdown_sha256")
    if status in ("applied", "verified"):
        md_rel = manifest.get("files", {}).get("markdown")
        if md_rel:
            md_path = pkg_dir / md_rel
            if md_path.exists():
                current_hash = file_sha256(md_path)
                if formatted_hash and formatted_hash != current_hash:
                    errors.append(
                        f"formatting.formatted_markdown_sha256 不匹配"
                        f"（当前文件: {current_hash[:16]}...，"
                        f"记录: {formatted_hash[:16]}...）"
                    )
                elif not formatted_hash:
                    errors.append(
                        f"formatting.status={status} 但 "
                        f"formatted_markdown_sha256 为空"
                    )

    # 备份文件必须存在（applied/verified 时）
    if status in ("applied", "verified") and source_hash:
        backup_path = pkg_dir / "data" / f"pre_format_md_{source_hash[:16]}.md"
        if not backup_path.exists():
            errors.append(
                f"格式化前备份不存在: {backup_path}"
            )
        elif file_sha256(backup_path) != source_hash:
            errors.append(
                f"格式化前备份 hash 不匹配: {backup_path}"
            )

    # fixes.markdown_sha256 必须与 formatted_markdown_sha256 一致
    fixes = manifest.get("fixes")
    if isinstance(fixes, dict) and formatted_hash:
        fixes_md_hash = fixes.get("markdown_sha256")
        if fixes_md_hash and fixes_md_hash != formatted_hash:
            errors.append(
                f"fixes.markdown_sha256 与 formatting.formatted_markdown_sha256 不一致"
            )

    return errors


def validate_manifest_files(manifest: dict, pkg_dir: Path) -> list[str]:
    """校验 manifest.files 引用文件的路径存在性。"""
    errors = []
    files = manifest.get("files")
    if not isinstance(files, dict):
        return errors  # 没有 files 块时跳过

    # 始终校验 files.markdown
    md_rel = files.get("markdown")
    if md_rel:
        md_path = pkg_dir / md_rel
        if not md_path.exists():
            errors.append(f"files.markdown 指向的文件不存在：{md_path}")

    # 校验 files.manual_fixes（如果配置了）
    mf_rel = files.get("manual_fixes")
    if mf_rel:
        mf_path = pkg_dir / mf_rel
        if not mf_path.exists():
            errors.append(f"files.manual_fixes 指向的文件不存在：{mf_path}")

    # 校验其他 files.* 路径（不校验 data/ 目录本身、images/ 等目录类型条目）
    for key, rel in files.items():
        if key in ("markdown", "manual_fixes", "pdf", "segments") or not isinstance(rel, str):
            continue
        fpath = pkg_dir / rel
        # 只有明确文件路径（不含目录分隔符末尾或无扩展名）才校验
        if not rel.endswith("/"):
            # 只校验带扩展名的文件条目
            if "." in rel and not fpath.exists():
                errors.append(f"files.{key} 指向的文件不存在：{fpath}")

    return errors


def check_table_consistency(manifest: dict, pkg_dir: Path) -> list[str]:
    """校验表格格式化前后一致性（门禁级别，升级版）。

    当 formatting.status 为 applied 或 verified 时：
    - 备份文件必须存在
    - 使用 markdown_table_formatter.validate_structure 做逐格校验
    备份不存在时跳过（status=none 或无 source_hash）。

    校验项（逐格）：
    - 表格数量、行数、逐行列数
    - 单元格文本、colspan、rowspan
    - <img> 数量
    """
    errors = []
    fmt = manifest.get("formatting")
    if not isinstance(fmt, dict):
        return errors

    status = fmt.get("status", "")
    source_hash = fmt.get("source_markdown_sha256")
    if not source_hash or status in ("none",):
        return errors

    # 获取当前 canonical Markdown（升级版格式器需从 scripts/lib 导入）
    md_rel = manifest.get("files", {}).get("markdown")
    if not md_rel:
        return errors
    current_md_path = pkg_dir / md_rel
    if not current_md_path.exists():
        return errors

    # 找备份文件
    backup_path = pkg_dir / "data" / f"pre_format_md_{source_hash[:16]}.md"
    # 兼容旧命名规则
    stem = current_md_path.stem
    alt_backup = current_md_path.parent / f"{stem}-pre-format.md"

    source_md_path = None
    if backup_path.exists() and file_sha256(backup_path) == source_hash:
        source_md_path = backup_path
    elif alt_backup.exists() and file_sha256(alt_backup) == source_hash:
        source_md_path = alt_backup

    if source_md_path is None:
        if status in ("applied", "verified"):
            errors.append(
                f"表格一致性：formatting.status={status} 但备份文件不存在"
                f"或 hash 不匹配"
            )
        return errors

    source_text = source_md_path.read_text(encoding="utf-8")
    current_text = current_md_path.read_text(encoding="utf-8")

    # 使用格式化器的 validate_structure 做完整校验
    try:
        import sys as _sys
        _sys.path.insert(0, str(Path(__file__).resolve().parent / "lib"))
        from markdown_table_formatter import validate_structure as fmt_validate
        struct_errors = fmt_validate(source_text, current_text)
    except ImportError:
        # fallback：使用旧版 parse_html_tables 校验
        struct_errors = _legacy_table_check(source_text, current_text)

    for e in struct_errors:
        errors.append(f"表格一致性：{e}")

    return errors


def _legacy_table_check(source_text: str, current_text: str) -> list[str]:
    """旧版表格结构校验（parse_html_tables 方式，fallback 用）。"""
    errors: list[str] = []
    source_tables = parse_html_tables(source_text)
    current_tables = parse_html_tables(current_text)

    if len(source_tables) != len(current_tables):
        errors.append(
            f"表格数量不一致（{len(source_tables)} → {len(current_tables)}）"
        )
        return errors

    for i, (st, ct) in enumerate(zip(source_tables, current_tables)):
        if len(st) != len(ct):
            errors.append(
                f"表格 {i+1} 行数不一致（{len(st)} → {len(ct)}）"
            )
            continue
        for ri, (sr, cr) in enumerate(zip(st, ct)):
            if len(sr) != len(cr):
                errors.append(
                    f"表格 {i+1} 第 {ri+1} 行列数不一致"
                    f"（{len(sr)} → {len(cr)}）"
                )
                continue
            for ci, (sc, cc) in enumerate(zip(sr, cr)):
                if not cell_texts_equal(sc["text"], cc["text"]):
                    errors.append(
                        f"表格 {i+1} ({ri+1},{ci+1}) 文本不一致"
                        f"（'{sc['text']}' → '{cc['text']}'）"
                    )

    return errors


# ── 幂等性校验 ──────────────────────────────────────────────


def check_idempotent(manifest: dict, pkg_dir: Path) -> list[str]:
    """检查 fixes.status=applied 的包中修复记录是否幂等。

    对 data/manual_fixes.jsonl 中每条 status=applied 的修复记录：
    1. 在目标页块中检查 before 文本是否已被替换（不应再出现）
    2. 检查 after 文本是否存在于目标页块中
    3. 检查 manifest 记录的 markdown_sha256 与当前文件是否一致

    如果 before 仍出现在目标页块中而 after 不存在，说明修复未正确应用。
    """
    import re as _re
    errors = []

    # 校验 fixes 状态
    fixes = manifest.get("fixes")
    if not isinstance(fixes, dict):
        return errors  # 没有 fixes 块时不检查
    if fixes.get("status") not in ("applied", "verified"):
        return errors  # 非已应用状态不检查幂等性

    # 检查 manifest 记录的 markdown_sha256
    md_rel = manifest.get("files", {}).get("markdown")
    if md_rel:
        md_path = pkg_dir / md_rel
        if md_path.exists():
            actual_md_hash = file_sha256(md_path)
            recorded_md_hash = fixes.get("markdown_sha256")
            if recorded_md_hash and actual_md_hash != recorded_md_hash:
                errors.append(
                    f"幂等性：manifest 记录的 markdown_sha256"
                    f"（{recorded_md_hash[:16]}...）"
                    f"与当前文件不匹配（{actual_md_hash[:16]}...）"
                )

    # 检查 manual_fixes.jsonl 中的记录是否已正确应用
    fixes_path = pkg_dir / "data" / "manual_fixes.jsonl"
    if not fixes_path.exists():
        return errors  # 无修复记录时不检查

    md_text = None
    if md_rel:
        md_path = pkg_dir / md_rel
        if md_path.exists():
            md_text = md_path.read_text(encoding="utf-8")

    # 页锚点模式
    anchor_pattern = _re.compile(
        r'^<!-- pages (\d+)-(\d+) -->\s*$', _re.MULTILINE
    )

    with fixes_path.open(encoding="utf-8") as f:
        for lineno, line in enumerate(f, start=1):
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue
            if not isinstance(obj, dict):
                continue
            if obj.get("status") != "applied":
                continue
            # fix_data 条目修改结构化字段，不涉及 Markdown 页块
            if obj.get("review_action") == "fix_data":
                continue

            fix_id = obj.get("fix_id", f"第 {lineno} 行")
            before = obj.get("before", "")
            after = obj.get("after", "")
            pages = obj.get("pages", [])

            if not before or not after or before == after:
                continue
            if not pages or md_text is None:
                continue

            # 在目标页块中检查
            for page in pages:
                # 用正则找页锚点
                found = False
                for m in anchor_pattern.finditer(md_text):
                    sp = int(m.group(1))
                    ep = int(m.group(2))
                    if sp <= page <= ep:
                        # 找到目标页块
                        blk_start = m.start()
                        # 找下一个锚点
                        next_m = None
                        for nm in anchor_pattern.finditer(md_text):
                            if nm.start() > blk_start:
                                next_m = nm
                                break
                        blk_end = next_m.start() if next_m else len(md_text)
                        block = md_text[blk_start:blk_end]

                        before_count = block.count(before)
                        after_count = block.count(after)

                        if before_count > 0 and after_count == 0:
                            errors.append(
                                f"幂等性：修复 {fix_id} page {page} 的 before 文本"
                                f"仍存在于页块中（{before_count} 次），"
                                f"但 after 文本不存在——修复未被应用"
                            )
                        elif before_count > 0 and after_count > 0:
                            # 注释追加型修复：before 是 after 的子串时，共存是预期行为
                            if before in after:
                                pass  # 已正确应用
                            else:
                                errors.append(
                                    f"幂等性：修复 {fix_id} page {page} 的 before 和 after"
                                    f"文本同时存在于页块中——可能重复应用或部分覆盖"
                                )
                        # before_count == 0 and after_count > 0 → 正确已应用

                        found = True
                        break

                if not found:
                    errors.append(
                        f"幂等性：修复 {fix_id} 的页 {page} 锚点不存在"
                    )

    return errors


# ── 主入口 ──────────────────────────────────────────────────


def validate_table_candidates(manifest: dict, pkg_dir: Path) -> list[str]:
    """校验 table_candidates.jsonl 的 manifest 登记和格式完整性。"""
    errors: list[str] = []
    files = manifest.get("files", {})
    hashes = manifest.get("hash", {})

    tc_registered = files.get("table_candidates")
    default_path = pkg_dir / "data" / "table_candidates.jsonl"
    file_exists = default_path.exists()

    # 1. 登记了但文件不存在
    if tc_registered:
        tc_path = pkg_dir / tc_registered
        if not tc_path.exists():
            errors.append(f"files.table_candidates 指向的文件不存在：{tc_path}")
            return errors
    else:
        tc_path = default_path

    # 2. 文件存在但未登记
    if file_exists and not tc_registered:
        errors.append("table_candidates.jsonl 存在但 manifest.files.table_candidates 未登记")
        return errors

    if not file_exists:
        return errors  # 无候选文件，跳过后续检查

    # 3. hash 为空
    tc_hash = hashes.get("table_candidates_sha256")
    if not tc_hash:
        errors.append("hash.table_candidates_sha256 为空")
    else:
        actual_hash = file_sha256(tc_path)
        if tc_hash != actual_hash:
            errors.append(
                f"table_candidates_sha256 不匹配"
                f"（期望：{actual_hash[:16]}...，实际：{tc_hash[:16]}...）"
            )

    # 4. 逐行校验 JSONL 格式
    anchor_re = re.compile(r"^<!-- pages \d+-\d+ -->$")
    ids_seen: set[str] = set()
    anchors_seen: set[str] = set()
    try:
        with tc_path.open(encoding="utf-8") as f:
            for lineno, line in enumerate(f, start=1):
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError as e:
                    errors.append(f"table_candidates 第 {lineno} 行 JSON 解析失败：{e}")
                    continue
                if not isinstance(obj, dict):
                    errors.append(f"table_candidates 第 {lineno} 行不是 JSON 对象")
                    continue

                # schema_version
                sv = obj.get("schema_version")
                if not isinstance(sv, int) or sv < 2:
                    errors.append(
                        f"table_candidates 第 {lineno} 行 schema_version 应为 >=2，"
                        f"实际：{sv}"
                    )

                # candidate_id
                cid = obj.get("candidate_id")
                if not cid or not isinstance(cid, str):
                    errors.append(f"table_candidates 第 {lineno} 行缺少 candidate_id")
                elif cid in ids_seen:
                    errors.append(
                        f"table_candidates 第 {lineno} 行 candidate_id 重复：{cid}"
                    )
                else:
                    ids_seen.add(cid)

                # page
                pg = obj.get("page")
                if not isinstance(pg, int) or pg < 1:
                    errors.append(
                        f"table_candidates 第 {lineno} 行 page 不是正整数：{pg}"
                    )

                # page_anchor（格式 + 去重）
                pa = obj.get("page_anchor", "")
                if not anchor_re.match(pa or ""):
                    errors.append(
                        f"table_candidates 第 {lineno} 行 page_anchor 格式不合法：{pa}"
                    )
                elif pa in anchors_seen:
                    errors.append(
                        f"table_candidates 第 {lineno} 行 page_anchor 重复：{pa}"
                    )
                else:
                    anchors_seen.add(pa)

                # needs_human
                if obj.get("needs_human") is not True:
                    errors.append(
                        f"table_candidates 第 {lineno} 行 needs_human 必须为 true"
                    )

                # signals
                sigs = obj.get("signals")
                if not sigs or not isinstance(sigs, list):
                    errors.append(
                        f"table_candidates 第 {lineno} 行 signals 为空或缺失"
                    )
    except OSError as e:
        errors.append(f"读取 table_candidates 失败：{e}")

    return errors


def main() -> None:
    verbose = False
    args = []
    for a in sys.argv[1:]:
        if a == "--verbose":
            verbose = True
        else:
            args.append(a)

    if not args:
        print("用法: pdf-check-fixes [--verbose] <package_dir>", file=sys.stderr)
        sys.exit(1)

    pkg_dir = Path(args[0])
    if not pkg_dir.is_dir():
        _log(f"输出包目录不存在：{pkg_dir}")
        sys.exit(1)

    manifest_path = pkg_dir / "manifest.json"
    if not manifest_path.exists():
        _log(f"manifest.json 不存在：{manifest_path}")
        sys.exit(1)

    try:
        manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError) as e:
        _log(f"manifest.json 解析失败：{e}")
        sys.exit(1)

    all_errors: list[str] = []
    all_warnings: list[str] = []

    # -- 文件存在性 --
    fe = validate_manifest_files(manifest, pkg_dir)
    all_errors.extend(fe)

    # -- manual_fixes.jsonl --
    fixes_path = pkg_dir / "data" / "manual_fixes.jsonl"
    mf_errors = validate_manual_fixes(fixes_path, manifest)
    all_errors.extend(mf_errors)

    # -- VLM 引用 --
    vlm_errors = validate_vlm_evidence(fixes_path)
    all_errors.extend(vlm_errors)

    # -- manifest.fixes --
    fix_errors = validate_manifest_fixes(manifest, pkg_dir)
    all_errors.extend(fix_errors)

    # -- manifest.formatting --
    fmt_errors = validate_formatting(manifest, pkg_dir)
    all_errors.extend(fmt_errors)

    # -- table_candidates --
    tc_errors = validate_table_candidates(manifest, pkg_dir)
    all_errors.extend(tc_errors)

    # -- 幂等性 --
    idem_errors = check_idempotent(manifest, pkg_dir)
    all_errors.extend(idem_errors)

    # -- 表格一致性（门禁级别，备份存在时致命错误） --
    tbl_errors = check_table_consistency(manifest, pkg_dir)
    all_errors.extend(tbl_errors)

    # -- 输出 --
    if all_errors:
        for e in all_errors:
            _log(e, "ERROR")
        if verbose:
            print(f"\n校验失败：{len(all_errors)} 个错误", file=sys.stderr)
        sys.exit(1)

    if all_warnings:
        for w in all_warnings:
            _log(w, "WARNING")

    if verbose:
        md_rel = manifest.get("files", {}).get("markdown", "?")
        print(
            f"校验通过：{pkg_dir.name}/{md_rel}"
            f"（{len(all_warnings)} 个 warning）" if all_warnings
            else f"校验通过：{pkg_dir.name}/{md_rel}",
            file=sys.stderr,
        )

    sys.exit(0)


if __name__ == "__main__":
    main()
