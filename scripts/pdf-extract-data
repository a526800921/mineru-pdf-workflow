#!/usr/bin/env python3
"""生成输出包结构化数据草案。

用法:
  scripts/pdf-extract-data <package>

示例:
  scripts/pdf-extract-data /path/to/package
  scripts/pdf-extract-data pdf/demo20
"""

import csv
import json
import re
import sys
from collections import Counter
from datetime import datetime
from html.parser import HTMLParser
from io import StringIO
from pathlib import Path


SECTION_RE = re.compile(r"^(#{1,3})\s+(.+)$", re.MULTILINE)
COLON_RE = re.compile(r"^(.{2,40})[：:]\s*(.{1,200})$")
COLON_BAD_PATTERNS = [
    re.compile(r"^注意[：:]"), re.compile(r"^警告[：:]"), re.compile(r"^提示[：:]"),
    re.compile(r"^注[：:]"), re.compile(r"信号词"), re.compile(r"信号"),
    re.compile(r"http[s]?://"), re.compile(r"^[\.\s…]+"),
    re.compile(r"^\d+\.\d+"), re.compile(r"请.{5,}"),
]
UNIT_RE = re.compile(r"[\s]*[（(]?([a-zA-Z·/℃²³%]+(?:·[a-zA-Z]+)?)[\s）)]?$")
DIGIT_RE = re.compile(r"\d+\.?\d*")

# 阶段 1：页段注释和 key_role 分类
PAGE_COMMENT_RE = re.compile(r"<!--\s*pages?\s*(\d+)\s*[-–—]\s*(\d+)\s*-->")
# PAGE_ANCHOR_RE 已移除：逐页锚点 <!-- page N --> 已在阶段 4 收敛
# 段级锚点 `<!-- pages N-M -->` 足以为每条数据行精确定位页码
MARKER_KEY_RE = re.compile(r"^[\s■▲●○◆◇★☆※\-—/\\|·]+$")
SPEC_KEY_RE = re.compile(r"^M\d+")
DIGIT_ONLY_RE = re.compile(r"^\d+$")
DIGIT_UNIT_RE = re.compile(r"^\d+\s*[a-zA-Z·/℃²³%]+$")

STATE_LABELS = {
    "主界面", "电话", "菜单音乐", "音乐", "导航", "设置", "蓝牙",
    "FM", "AM", "USB", "AUX", "收音机", "通话", "联系人", "消息",
    "菜单", "返回", "确认", "取消", "音量", "静音", "语音",
}


def parse_page_comments(md_text: str) -> dict:
    """返回 {line_no: (page_start, page_end)} — 段级锚点 `<!-- pages N-M -->`。
    逐页锚点 <!-- page N --> 已在阶段 4 收敛，不再解析。
    """
    page_map: dict = {}
    for i, line in enumerate(md_text.split("\n"), 1):
        m = PAGE_COMMENT_RE.search(line)
        if m:
            page_map[i] = (int(m.group(1)), int(m.group(2)))
    return page_map


def get_page_range(line_no: int, page_map: dict) -> tuple:
    """返回 (page_start_str, page_end_str)。

    从段级锚点 `<!-- pages N-M -->` 解析页码范围。
    逐页锚点 <!-- page N --> 已在阶段 4 收敛，不再使用。
    """
    page_map_sorted = sorted(page_map.keys())
    best = (0, 0)
    for seg_line in page_map_sorted:
        if seg_line <= line_no:
            best = page_map[seg_line]
        else:
            break
    if best == (0, 0):
        return ("", "")
    return (str(best[0]), str(best[1]))


def classify_key_role(key: str) -> str:
    """对 key 做最小分类，用于后续冲突判定。"""
    if not key or not key.strip():
        return "marker"
    key = key.strip()
    if MARKER_KEY_RE.match(key):
        return "marker"
    if key in STATE_LABELS:
        return "state_label"
    if SPEC_KEY_RE.match(key):
        return "spec_value"
    if DIGIT_ONLY_RE.match(key):
        return "local_label"
    if DIGIT_UNIT_RE.match(key):
        return "local_label"
    return "business_key"


def should_skip_numeric_key(key: str, numeric_key_policy: str = "keep") -> bool:
    """按包内策略过滤纯数字 key；默认保留以兼容既有抽取行为。"""
    return numeric_key_policy == "skip" and bool(DIGIT_ONLY_RE.fullmatch(key.strip()))


def new_block_counters() -> dict:
    return {"paragraph": 0, "md_table": 0, "html_table": 0}


def refine_page_numbers(draft_rows: list[dict], pdf_path: Path) -> None:
    """用 PyMuPDF 逐页搜索，把页段级 page_start/page_end 精确定位到单页。

    对于每个 draft 行，在 PDF 文本层中搜索 key，找到匹配的精确页码。
    如果 key 跨多页出现，用 evidence_text 进一步消歧。
    """
    try:
        import fitz
    except Exception:
        return  # PyMuPDF 不可用时保持页段级定位

    if not pdf_path.exists():
        return

    doc = fitz.open(pdf_path)
    # 构建每页文本索引
    page_texts: dict[int, str] = {}
    for i in range(doc.page_count):
        page_texts[i + 1] = doc[i].get_text()
    doc.close()

    # 对每个 draft 行精确定位
    for row in draft_rows:
        key = row.get("key", "")
        if not key:
            continue

        # 找到包含 key 的候选页；优先限制在 Markdown 行锚点给出的原始页段，
        # 避免“冷却液”“制动液”等重复项目被定位到更早页面。
        candidates = [
            p for p, text in page_texts.items()
            if key in text
        ]
        try:
            original_start = int(row.get("page_start", ""))
            original_end = int(row.get("page_end", ""))
        except (TypeError, ValueError):
            original_start = original_end = 0
        scoped_candidates = [
            p for p in candidates
            if original_start and original_end and original_start <= p <= original_end
        ]
        if scoped_candidates:
            candidates = scoped_candidates

        if not candidates:
            # 无法在 PDF 中找到 key，保留页段级定位
            continue

        if len(candidates) == 1:
            row["page_start"] = str(candidates[0])
            row["page_end"] = str(candidates[0])
            continue

        # 多页候选：用 evidence_text 消歧
        evidence = row.get("evidence_text", "")
        best_page = None
        best_score = 0
        for p in candidates:
            # 计算 evidence_text 中词语在页面中的命中数
            words = set(evidence.split()) if evidence else {key}
            score = sum(1 for w in words if w in page_texts[p])
            if score > best_score:
                best_score = score
                best_page = p

        if best_page:
            row["page_start"] = str(best_page)
            row["page_end"] = str(best_page)


def read_manifest(pkg: Path) -> dict:
    manifest_path = pkg / "manifest.json"
    if not manifest_path.exists():
        sys.exit(f"错误：找不到 manifest.json: {manifest_path}")
    with open(manifest_path) as f:
        return json.load(f)


def read_markdown(pkg: Path, manifest: dict) -> str | None:
    """读取合并 Markdown；不存在时返回 None 而不退出，由调用方走空草案路径。"""
    stem = manifest.get("model", pkg.name)
    md_rel = manifest.get("files", {}).get("markdown") or f"{stem}.md"
    md_path = pkg / md_rel
    if not md_path.exists():
        return None
    return md_path.read_text(encoding="utf-8", errors="replace")


def read_content_lists(pkg: Path) -> list:
    segs_dir = pkg / "segments"
    results = []
    for seg_dir in sorted(segs_dir.iterdir()):
        if not seg_dir.is_dir():
            continue
        for cl_path in sorted(seg_dir.rglob("*content_list_v2.json")):
            with open(cl_path) as f:
                pages = json.load(f)
            for page_idx, elements in enumerate(pages):
                results.append((seg_dir.name, page_idx, elements))
    return results


def parse_sections(md_text: str) -> list:
    sections = []
    for m in SECTION_RE.finditer(md_text):
        level = len(m.group(1))
        title = m.group(2).strip()
        line_no = md_text[: m.start()].count("\n") + 1
        sections.append((line_no, level, title))
    return sections


def build_section_path(line_no: int, sections: list) -> str:
    path_parts = []
    for sec_line, level, title in sections:
        if sec_line <= line_no:
            if len(path_parts) >= level:
                path_parts = path_parts[: level - 1]
            path_parts.append(title)
    return " / ".join(path_parts)


def load_toc_tree(pkg: Path) -> list | None:
    """加载 toc_tree.json，不存在时返回 None。"""
    tree_path = pkg / "toc_tree.json"
    if not tree_path.exists():
        return None
    with open(tree_path) as f:
        return json.load(f)


def _check_page_numbering_safety(manifest: dict) -> dict:
    """检查页码坐标系状态，返回安全评估。

    返回 {"safe": bool, "status": str, "warning": str | None}
    - verified → safe=True, warning=None
    - proposed/needs_review/missing → safe=False, warning 含人类可读说明
    """
    pn = manifest.get("page_numbering")
    if not isinstance(pn, dict):
        return {
            "safe": False,
            "status": "missing",
            "warning": (
                "manifest 缺少 page_numbering 块；toc_tree.target_page 可能不是物理页码。"
                "请重新运行 pdf-auto 以生成页码检测，或手动补充 manifest.page_numbering。"
            ),
        }

    status = pn.get("status", "needs_review")
    if status == "verified":
        return {"safe": True, "status": status, "warning": None}

    # needs_review 或未知状态
    mapping_type = pn.get("mapping_type", "unknown")
    if mapping_type == "unknown":
        msg = (
            "page_numbering.status=needs_review（mapping_type=unknown）；"
            "toc_tree.target_page 可能是印刷页码而非物理页码。"
            "章节归属结果可能不准确。"
        )
    else:
        offset = pn.get("printed_to_physical_offset", "?")
        msg = (
            f"page_numbering.status=needs_review（偏移={offset}）；"
            "toc_tree.target_page 未经验证，章节归属结果可能不准确。"
        )

    return {"safe": False, "status": status, "warning": msg}


def build_page_section_map(toc_tree: list) -> dict[int, str]:
    """构建 {page_num: section_path} 映射。

    每个 TOC 条目覆盖从指向页(target_page) 到下一条目 target_page-1 的页面范围。
    """
    if not toc_tree:
        return {}

    depth_stack = []  # [(depth, title), ...]
    paths = []        # [(page, full_path), ...]

    for entry in toc_tree:
        depth = entry["depth"]
        title = entry["title"]
        # target_page 是条目指向的正文页；兼容旧包的 page 字段
        page = entry.get("target_page", entry.get("page"))

        while depth_stack and depth_stack[-1][0] >= depth:
            depth_stack.pop()

        depth_stack.append((depth, title))
        full_path = " / ".join(t for _, t in depth_stack)
        paths.append((page, full_path))

    page_map = {}
    for i, (page, path) in enumerate(paths):
        next_page = paths[i + 1][0] if i + 1 < len(paths) else 999999
        for p in range(page, next_page):
            page_map[p] = path

    return page_map


def get_section_path(line_no: int, sections: list, page_start: str,
                     page_section_map: dict[int, str] | None) -> str:
    """获取 section_path：优先用 TOC 树（按页码），回退到 Markdown 标题。"""
    if page_section_map:
        try:
            p = int(page_start)
        except (ValueError, TypeError):
            p = 0
        toc_path = page_section_map.get(p, "")
        if toc_path:
            return toc_path
    return build_section_path(line_no, sections)


def extract_unit(value: str) -> tuple[str, str]:
    """从 value 尾部提取单位，返回 (value_without_unit, unit)."""
    m = UNIT_RE.search(value)
    if not m:
        return value, ""
    unit = m.group(1)
    if len(unit) > 10:
        return value, ""
    clean = value[: m.start()].strip().rstrip(",").strip()
    if not clean or clean == value:
        return value, ""
    return clean, unit


def is_valid_colon_line(key: str, value: str) -> bool:
    for pat in COLON_BAD_PATTERNS:
        if pat.search(key) or pat.search(value):
            return False
    if len(key) < 2 or len(value) < 1:
        return False
    return True


def extract_colon_rows(md_text: str, sections: list, source_pdf: str, model: str,
                       page_map: dict, counters: dict,
                       page_section_map: dict | None = None,
                       numeric_key_policy: str = "keep") -> list:
    rows = []
    for line_idx, line in enumerate(md_text.split("\n")):
        line_orig = line.strip()
        if not line_orig:
            continue
        m = COLON_RE.match(line_orig)
        if not m:
            continue
        key = m.group(1).strip()
        value = m.group(2).strip()
        if not is_valid_colon_line(key, value):
            continue
        if should_skip_numeric_key(key, numeric_key_policy):
            continue
        clean_val, unit = extract_unit(value)
        has_digit = bool(DIGIT_RE.search(clean_val))
        line_no = line_idx + 1
        sec_path = build_section_path(line_no, sections)
        pg_start, pg_end = get_page_range(line_no, page_map)
        counters["paragraph"] += 1
        rows.append({
            "source_pdf": source_pdf, "model": model, "section_path": sec_path,
            "key": key, "value": clean_val, "unit": unit,
            "page_start": pg_start, "page_end": pg_end,
            "evidence_text": line_orig[:200],
            "confidence": "medium" if (has_digit and unit) else "low",
            "status": "needs_review",
            "notes": "colon_line" + ("+unit" if unit else ""),
            "source_block_id": f"paragraph:{counters['paragraph']}",
            "table_id": "",
            "row_index": "",
            "parent_key": "",
            "key_role": classify_key_role(key),
        })
    return rows


def parse_html_tables(md_text: str) -> list[list[list[str]]]:
    """从 markdown 中解析 HTML <table>，返回 [table[cells_per_row]]."""
    tables = []

    class TableParser(HTMLParser):
        def __init__(self):
            super().__init__()
            self.in_table = False
            self.in_tr = False
            self.in_td = False
            self.current_table = []
            self.current_row = []
            self.current_cell = ""
            self.span_depth = 0

        def handle_starttag(self, tag, attrs):
            if tag == "table":
                self.in_table = True
                self.current_table = []
            elif tag == "tr":
                self.in_tr = True
                self.current_row = []
            elif tag in ("td", "th"):
                self.in_td = True
                self.current_cell = ""

        def handle_endtag(self, tag):
            if tag == "table":
                if self.current_table:
                    tables.append(self.current_table)
                self.in_table = False
                self.current_table = []
            elif tag == "tr":
                if self.in_tr and self.current_row:
                    self.current_table.append(self.current_row)
                self.in_tr = False
            elif tag in ("td", "th"):
                if self.in_td:
                    self.current_row.append(self.current_cell.strip())
                self.in_td = False
                self.current_cell = ""

        def handle_data(self, data):
            if self.in_td:
                self.current_cell += data

    parser = TableParser()
    try:
        parser.feed(md_text)
    except Exception:
        pass

    return tables


def _get_html_table_row_lines(md_text: str) -> list[list[int]]:
    """为每个 HTML <table> 返回行号列表 [table_idx][row_idx] = line_no (1-based)。

    逐行扫描 md_text，检测 <table> 块和 <tr> 边界，确保行号与 HTML 表格遍历顺序一致。
    """
    results: list[list[int]] = []
    TABLE_BLOCK = re.compile(r'(<table>.*?</table>)', re.DOTALL)
    for table_match in TABLE_BLOCK.finditer(md_text):
        table_html = table_match.group(1)
        base_line = md_text[:table_match.start()].count('\n') + 1
        row_lines = []
        # 统计 table_html 内每个 <tr> 前的换行数以计算实际行号
        for tr_match in re.finditer(r'<tr>', table_html):
            before_tr = table_html[:tr_match.start()]
            offset_lines = before_tr.count('\n')
            row_lines.append(base_line + offset_lines)
        results.append(row_lines)
    return results


ROWSPAN_PARENT_RE = re.compile(
    r'<(?:td|th)([^>]*?)>(.*?)</(?:td|th)>', re.DOTALL
)
ROWSPAN_ATTR_RE = re.compile(r'rowspan\s*=\s*"(\d+)"')


def build_html_parent_maps(md_text: str) -> list[dict[int, str]]:
    """为每个 HTML <table> 构建 {data_row_index: parent_text} 映射。

    从首列 <td rowspan="N"> 提取父级分组标签，返回与 parse_html_tables
    同顺序的 parent map 列表。parent_map 的 key 是 data_row 的 0-based 索引
    （即 table[1:] 中的位置），value 是父级文本。
    """
    parent_maps = []
    table_pattern = re.compile(r'<table>(.*?)</table>', re.DOTALL)
    for table_match in table_pattern.finditer(md_text):
        table_html = table_match.group(0)
        rows_html = re.findall(r'<tr>(.*?)</tr>', table_html, re.DOTALL)
        parent_map: dict[int, str] = {}
        pending: list[list] = []  # [[remaining, text], ...]
        for html_row_idx, row_html in enumerate(rows_html):
            # 注入待生效的 rowspan 父级
            if pending:
                # data_row 索引 = html_row_idx - 1（跳过表头行）
                data_idx = html_row_idx - 1
                if data_idx >= 0:
                    parent_map[data_idx] = pending[0][1]
                pending[0][0] -= 1
                if pending[0][0] <= 1:
                    pending.pop(0)
            # 检查首列是否有 rowspan
            first_cell = ROWSPAN_PARENT_RE.search(row_html)
            if first_cell:
                attrs = first_cell.group(1)
                text = re.sub(r'<[^>]+>', '', first_cell.group(2)).strip()
                rs_match = ROWSPAN_ATTR_RE.search(attrs)
                if rs_match:
                    rs = int(rs_match.group(1))
                    if rs > 1:
                        pending.append([rs, text])
        parent_maps.append(parent_map)
    return parent_maps


def guess_key_col_idx(headers: list, rows: list) -> int:
    """猜测 key 列索引."""
    if not headers or len(headers) < 2:
        return 0
    key_markers = ["项目", "参数", "名称", "部件", "规格"]
    for i, h in enumerate(headers):
        for m in key_markers:
            if m in h:
                return i
    return 0


def guess_value_col_idx(headers: list, rows: list) -> int:
    """猜测 value 列索引."""
    if not headers or len(headers) < 2:
        return 1
    val_markers = ["值", "规格", "说明", "参数", "性能", "尺寸"]
    for i, h in enumerate(headers):
        for m in val_markers:
            if m in h:
                return i
    # 找有数字的最右列
    return max(1, len(headers) - 1)


def parse_html_tables_with_spans(md_text: str) -> list[list[list[str]]]:
    """解析 HTML 表格并在内存中展开 rowspan/colspan。

    只给复杂表格抽取使用，不改变 canonical Markdown。普通表格仍沿用
    parse_html_tables() 的原始单元格视图，避免改变既有 record_id 规则。
    """

    def expand(raw_rows: list[list[tuple[str, int, int]]]) -> list[list[str]]:
        expanded: list[list[str]] = []
        active: dict[int, tuple[int, str]] = {}

        for raw_row in raw_rows:
            cells: dict[int, str] = {}
            occupied = set(active)
            next_active: dict[int, tuple[int, str]] = {}
            for col, (_, text) in active.items():
                cells[col] = text

            col = 0
            for text, colspan, rowspan in raw_row:
                while col in occupied:
                    col += 1
                span_cols = list(range(col, col + max(1, colspan)))
                while any(c in occupied for c in span_cols):
                    col += 1
                    span_cols = list(range(col, col + max(1, colspan)))
                for c in span_cols:
                    cells[c] = text
                    occupied.add(c)
                    if rowspan > 1:
                        next_active[c] = (rowspan - 1, text)
                col += max(1, colspan)

            width = max(cells, default=-1) + 1
            expanded.append([cells.get(i, "") for i in range(width)])
            for c, (remaining, text) in active.items():
                if remaining > 1:
                    next_active[c] = (remaining - 1, text)
            active = next_active

        width = max((len(row) for row in expanded), default=0)
        return [row + [""] * (width - len(row)) for row in expanded]

    class SpanTableParser(HTMLParser):
        def __init__(self):
            super().__init__()
            self.in_table = False
            self.in_tr = False
            self.in_cell = False
            self.current_table: list[list[tuple[str, int, int]]] = []
            self.current_row: list[tuple[str, int, int]] = []
            self.current_text = ""
            self.current_colspan = 1
            self.current_rowspan = 1
            self.tables: list[list[list[str]]] = []

        def handle_starttag(self, tag, attrs):
            if tag == "table":
                self.in_table = True
                self.current_table = []
            elif tag == "tr" and self.in_table:
                self.in_tr = True
                self.current_row = []
            elif tag in ("td", "th") and self.in_tr:
                attrs_dict = dict(attrs)
                self.in_cell = True
                self.current_text = ""
                self.current_colspan = int(attrs_dict.get("colspan", "1") or "1")
                self.current_rowspan = int(attrs_dict.get("rowspan", "1") or "1")

        def handle_endtag(self, tag):
            if tag in ("td", "th") and self.in_cell:
                self.current_row.append((
                    self.current_text.strip(),
                    self.current_colspan,
                    self.current_rowspan,
                ))
                self.in_cell = False
            elif tag == "tr" and self.in_tr:
                if self.current_row:
                    self.current_table.append(self.current_row)
                self.in_tr = False
            elif tag == "table" and self.in_table:
                if self.current_table:
                    self.tables.append(expand(self.current_table))
                self.in_table = False
                self.current_table = []

        def handle_data(self, data):
            if self.in_cell:
                self.current_text += data

    parser = SpanTableParser()
    try:
        parser.feed(md_text)
    except Exception:
        pass
    return parser.tables


def is_uniform_nonempty_row(row: list[str]) -> bool:
    """判断由 colspan 展开的纯分类行。"""
    values = [cell.strip() for cell in row]
    return bool(values) and len(values) >= 6 and all(values) and len(set(values)) == 1


def load_extraction_overrides(pkg: Path) -> dict[str, dict]:
    """读取 LLM/人工确认的表格语义和包级策略配置。"""
    path = pkg / "data" / "extraction_overrides.json"
    if not path.exists():
        return {}
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}
    tables = payload.get("tables", {}) if isinstance(payload, dict) else {}
    policies = payload.get("policies", {}) if isinstance(payload, dict) else {}
    result = {}
    if isinstance(policies, dict):
        result["__policies__"] = policies
    if isinstance(tables, list):
        result.update({
            item.get("table_id", ""): item
            for item in tables
            if isinstance(item, dict) and item.get("table_id")
        })
        return result
    if not isinstance(tables, dict):
        return result
    result.update({str(k): v for k, v in tables.items() if isinstance(v, dict)})
    return result


def extract_html_table_rows(md_text: str, sections: list, source_pdf: str, model: str,
                           page_map: dict, counters: dict,
                           page_section_map: dict | None = None,
                           table_overrides: dict[str, dict] | None = None,
                           numeric_key_policy: str = "keep") -> list:
    rows = []
    tables = parse_html_tables(md_text)
    expanded_tables = parse_html_tables_with_spans(md_text)
    parent_maps = build_html_parent_maps(md_text)
    # 逐行扫描获取每个 HTML 表格行的实际行号
    html_row_lines = _get_html_table_row_lines(md_text)

    for table_idx, table in enumerate(tables):
        if len(table) < 2:
            continue
        table_id = f"html_table:{counters['html_table'] + 1}"
        override = (table_overrides or {}).get(table_id)
        if override and table_idx < len(expanded_tables):
            table = expanded_tables[table_idx]
            header_rows = int(override.get("header_rows", 1))
            data_rows = table[header_rows:]
            key_idx = int(override.get("key_column", 0))
            marker_idx = override.get("marker_column")
            value_columns = override.get("value_columns", {})
            val_idx = max(
                [int(v) for v in value_columns.values()] or [key_idx]
            )
        else:
            headers = table[0]
            data_rows = table[1:]
            key_idx = guess_key_col_idx(headers, data_rows)
            val_idx = guess_value_col_idx(headers, data_rows)
        counters["html_table"] += 1
        current_category = ""

        # rowspan 父级映射（来自 build_html_parent_maps）
        rowspan_parents = parent_maps[table_idx] if table_idx < len(parent_maps) else {}

        for row_idx, row in enumerate(data_rows):
            if len(row) < max(key_idx, val_idx) + 1:
                continue
            key = row[key_idx].strip()
            if should_skip_numeric_key(key, numeric_key_policy):
                continue
            marker = ""
            if override:
                if marker_idx is not None and int(marker_idx) < len(row):
                    marker = row[int(marker_idx)].strip()
                if override.get("category_row") == "all_cells_equal" and is_uniform_nonempty_row(row):
                    # colspan=6 的分类行，例如“电气”“制动”，不是业务记录。
                    current_category = row[0].strip()
                    continue
                value_parts = []
                for label, idx in value_columns.items():
                    idx = int(idx)
                    if idx < len(row) and row[idx].strip():
                        value_parts.append(f"{label}={row[idx].strip()}")
                value_str = "；".join(value_parts)
            else:
                value_str = " / ".join(
                    row[i] for i in range(len(row)) if i != key_idx and row[i].strip()
                )
            if not key or not value_str or len(key) > 60:
                continue

            clean_val, unit = extract_unit(value_str)

            # 按 HTML 行号表获取行号，跳过表头 (row_idx+1 因为第 0 个 <tr> 是表头)
            if table_idx < len(html_row_lines) and row_idx + 1 < len(html_row_lines[table_idx]):
                line_no = html_row_lines[table_idx][row_idx + 1]
            else:
                line_no = 0

            pg_start, pg_end = get_page_range(line_no, page_map)
            sec_path = get_section_path(line_no, sections, pg_start, page_section_map)

            # parent_key：保养表使用展开后的分类行，其余沿用原逻辑。
            parent_key = ""
            if override:
                parent_key = current_category
            else:
                parent_key = rowspan_parents.get(row_idx, "")
            if not parent_key:
                first_col_values = [r[0].strip() if len(r) > 0 else "" for r in data_rows]
                if (
                    key_idx > 0 and len(row) > 0
                    and len(set(first_col_values)) < len(first_col_values)
                    and len(first_col_values) > 2
                ):
                    first_cell = row[0].strip()
                    if first_cell and first_cell != key:
                        parent_key = first_cell

            confidence = "medium" if (key_idx == 0 or override) else "low"
            status = "draft" if confidence == "medium" else "needs_review"
            evidence_key = f"{marker} {key}".strip() if marker else key
            notes = "html_table"
            if override:
                notes += f";extraction_override={table_id}"
                if marker:
                    notes += f";marker={marker}"
            rows.append({
                "source_pdf": source_pdf, "model": model, "section_path": sec_path,
                "key": key, "value": clean_val, "unit": unit,
                "page_start": pg_start, "page_end": pg_end,
                "evidence_text": f"{evidence_key}: {value_str}"[:200],
                "confidence": confidence, "status": status,
                "notes": notes,
                "source_block_id": f"html_table:{counters['html_table']}",
                "table_id": table_id,
                "row_index": str(row_idx + 1),
                "parent_key": parent_key,
                "key_role": classify_key_role(key),
            })

    return rows


def extract_md_table_rows(md_text: str, sections: list, source_pdf: str, model: str,
                         page_map: dict, counters: dict,
                         page_section_map: dict | None = None,
                         numeric_key_policy: str = "keep") -> list:
    rows = []
    lines = md_text.split("\n")
    MD_TABLE_SEP = re.compile(r"^\s*\|[\s\-:|]+\|\s*$")
    i = 0
    while i < len(lines):
        stripped = lines[i].strip()
        if stripped.startswith("|") and not MD_TABLE_SEP.match(stripped):
            if i + 1 < len(lines) and MD_TABLE_SEP.match(lines[i + 1].strip()):
                counters["md_table"] += 1
                table_id = f"md_table:{counters['md_table']}"
                header_cells = [c.strip() for c in stripped.split("|")[1:-1]]
                i += 2
                row_idx = 0
                while i < len(lines) and lines[i].strip().startswith("|"):
                    if MD_TABLE_SEP.match(lines[i].strip()):
                        i += 1
                        continue
                    cells = [c.strip() for c in lines[i].strip().split("|")[1:-1]]
                    if len(cells) >= 2:
                        key = cells[0]
                        if should_skip_numeric_key(key, numeric_key_policy):
                            i += 1
                            continue
                        value = " / ".join(cells[1:])
                        clean_val, unit = extract_unit(value)
                        line_no = i + 1
                        pg_start, pg_end = get_page_range(line_no, page_map)
                        sec_path = get_section_path(line_no, sections, pg_start, page_section_map)
                        row_idx += 1
                        # 保守 parent_key：首列与其他行首列不同且非数字时可能为父级
                        parent_key = ""
                        if len(cells) > 2 and cells[0] and not DIGIT_ONLY_RE.match(cells[0]):
                            pass  # 无法可靠判断时留空
                        rows.append({
                            "source_pdf": source_pdf, "model": model,
                            "section_path": sec_path,
                            "key": key, "value": clean_val, "unit": unit,
                            "page_start": pg_start, "page_end": pg_end,
                            "evidence_text": lines[i].strip()[:200],
                            "confidence": "medium", "status": "draft",
                            "notes": "md_table",
                            "source_block_id": f"md_table:{counters['md_table']}",
                            "table_id": table_id,
                            "row_index": str(row_idx),
                            "parent_key": parent_key,
                            "key_role": classify_key_role(key),
                        })
                    i += 1
                continue
        i += 1
    return rows


def generate_verification(pkg: Path, manifest: dict, cl_data: list,
                          draft_rows: list, output_files: dict,
                          toc_warning: str | None = None) -> list:
    checks = []
    n = 1

    def add(level, target, result, details, source):
        nonlocal n
        checks.append({"check_id": f"V{n:03d}", "level": level, "target": target,
                       "result": result, "details": details, "source": source})
        n += 1

    add("info", "manifest.json", "passed", "manifest 存在且合法", "manifest.json")

    md_rel = manifest.get("files", {}).get("markdown", "")
    md_path = pkg / md_rel if md_rel else None
    if md_path and md_path.exists():
        add("info", "markdown", "passed", f"{md_path.name} 存在", str(md_path))
    else:
        add("error", "markdown", "failed", "合并 Markdown 缺失", str(md_path or "unknown"))

    segs_dir = pkg / "segments"
    seg_count = len([d for d in segs_dir.iterdir() if d.is_dir()]) if segs_dir.exists() else 0
    add("info", "segments", "passed" if seg_count > 0 else "failed",
        f"分段数: {seg_count}", "segments/")

    cl_count = len(cl_data)
    cl_level = "info" if cl_count > 0 else "warning"
    cl_result = "passed" if cl_count > 0 else "needs_review"
    add(cl_level, "content_list_v2", cl_result,
        f"content_list_v2 页面数: {cl_count}", "segments/**/content_list_v2.json")

    img_dir = pkg / "images"
    img_count = len([f for f in img_dir.iterdir() if f.is_file()]) if img_dir.exists() else 0
    add("info", "images", "passed" if img_count >= 0 else "failed",
        f"图片数: {img_count}", "images/")

    # Section path quality
    missing_path = sum(1 for r in draft_rows if not r["section_path"])
    if missing_path > 0:
        add("warning", "section_path", "needs_review",
            f"{missing_path} 行缺少章节路径", "pdf-extract-data section_path logic")

    # Page numbering safety: TOC 章节路径可能基于未验证的页码映射
    if toc_warning:
        add("warning", "toc_section_path", "needs_review",
            f"TOC 章节路径基于未经验证的页码映射: {toc_warning}",
            "manifest.json page_numbering")

    draft_needs_review = sum(1 for r in draft_rows if r["status"] == "needs_review")
    draft_draft = sum(1 for r in draft_rows if r["status"] == "draft")
    draft_high = sum(1 for r in draft_rows if r["confidence"] == "high")
    draft_medium = sum(1 for r in draft_rows if r["confidence"] == "medium")
    draft_low = sum(1 for r in draft_rows if r["confidence"] == "low")
    add("info", "quick_lookup_draft", "passed" if len(draft_rows) > 0 else "info",
        f"行数: {len(draft_rows)}, draft: {draft_draft}, needs_review: {draft_needs_review}, "
        f"high: {draft_high}, medium: {draft_medium}, low: {draft_low}",
        "data/quick_lookup_draft.csv")

    for name, path in output_files.items():
        if Path(path).exists():
            add("info", name, "passed", f"{name} 已生成", str(path))
        else:
            add("error", name, "failed", f"{name} 未生成", str(path))

    return checks


def write_csv(path: Path, fieldnames: list[str], rows: list[dict]):
    path.parent.mkdir(parents=True, exist_ok=True)
    with open(path, "w", newline="", encoding="utf-8") as f:
        w = csv.DictWriter(f, fieldnames=fieldnames, extrasaction="ignore",
                          lineterminator='\n')
        w.writeheader()
        w.writerows(rows)


def write_fixtures(pkg: Path, manifest: dict, draft_rows: list, verification: list,
                   output_files: dict):
    md = []
    md.append("# 数据抽取摘要")
    md.append("")
    md.append(f"生成时间: {datetime.now().strftime('%Y-%m-%d %H:%M')}")
    md.append(f"输出包: {pkg.resolve()}")
    md.append(f"车型: {manifest.get('model', 'unknown')}")
    md.append("")

    md.append("## 抽取统计")
    md.append("")
    needs_r = sum(1 for r in draft_rows if r["status"] == "needs_review")
    draft_d = sum(1 for r in draft_rows if r["status"] == "draft")
    md.append(f"- 草案行数: {len(draft_rows)}")
    md.append(f"- 待审核: {needs_r}")
    md.append(f"- 可入库草案: {draft_d}")

    errors = [c for c in verification if c["level"] == "error"]
    warnings = [c for c in verification if c["level"] == "warning"]
    md.append(f"- 错误: {len(errors)}")
    md.append(f"- 警告: {len(warnings)}")
    md.append("")

    md.append("## 规则命中统计")
    md.append("")
    note_counter = Counter(r["notes"] for r in draft_rows)
    for note, count in note_counter.most_common():
        md.append(f"- {note}: {count} 行")
    md.append("")

    conf_counter = Counter(r["confidence"] for r in draft_rows)
    md.append("## 置信度分布")
    md.append("")
    for c in ("high", "medium", "low"):
        md.append(f"- {c}: {conf_counter.get(c, 0)} 行")
    md.append("")

    section_counter = Counter(r["section_path"] for r in draft_rows if r["section_path"])
    if section_counter:
        md.append("## 命中章节")
        md.append("")
        for path, count in section_counter.most_common(10):
            md.append(f"- {path}: {count} 行")
        md.append("")

    md.append("## 待审核原因")
    md.append("")
    needs_r_rows = [r for r in draft_rows if r["status"] == "needs_review"]
    reason_counter = Counter(r["notes"] for r in needs_r_rows)
    if reason_counter:
        for reason, count in reason_counter.most_common():
            md.append(f"- {reason}: {count} 行")
    else:
        md.append("- 无待审核行")
    md.append("")

    if errors:
        md.append("## 错误")
        md.append("")
        for e in errors:
            md.append(f"- **{e['check_id']}** [{e['target']}]: {e['details']}")
        md.append("")

    if warnings:
        md.append("## 警告")
        md.append("")
        for w in warnings:
            md.append(f"- **{w['check_id']}** [{w['target']}]: {w['details']}")
        md.append("")

    md.append("## 可复现命令")
    md.append("")
    md.append(f"```bash")
    md.append(f"scripts/pdf-extract-data {pkg}")
    md.append(f"```")
    md.append("")

    md.append("## 输出文件")
    md.append("")
    for name, path in output_files.items():
        md.append(f"- `{name}`: {path}")

    report_path = pkg / "data" / "fixtures_result.md"
    report_path.parent.mkdir(parents=True, exist_ok=True)
    report_path.write_text("\n".join(md), encoding="utf-8")


def main():
    if len(sys.argv) != 2:
        print("用法: scripts/pdf-extract-data <package>", file=sys.stderr)
        print("示例: scripts/pdf-extract-data pdf/demo20", file=sys.stderr)
        sys.exit(1)

    pkg = Path(sys.argv[1]).resolve()
    if not pkg.is_dir():
        sys.exit(f"错误：不是目录: {pkg}")

    manifest = read_manifest(pkg)
    md_text = read_markdown(pkg, manifest)
    cl_data = read_content_lists(pkg)

    source_pdf = manifest.get("files", {}).get("pdf", manifest.get("model", "") + ".pdf")
    model = manifest.get("model", pkg.name)

    fields = ["source_pdf", "model", "section_path", "key", "value", "unit",
              "page_start", "page_end", "evidence_text", "confidence", "status", "notes",
              "source_block_id", "table_id", "row_index", "parent_key", "key_role"]

    if md_text is None:
        # 缺少合并 Markdown：生成空草案并在 verification 中记录
        draft_rows = []
        draft_path = pkg / "data" / "quick_lookup_draft.csv"
        write_csv(draft_path, fields, draft_rows)

        v_path = pkg / "data" / "verification.csv"
        output_files = {"quick_lookup_draft.csv": str(draft_path)}
        verification = generate_verification(pkg, manifest, cl_data, draft_rows, output_files)
        verification.append({
            "check_id": f"V{len(verification)+1:03d}", "level": "error",
            "target": "markdown", "result": "failed",
            "details": "合并 Markdown 缺失，无法抽取结构化数据。请先运行 pdf-auto 生成。",
            "source": "manifest.json files.markdown"
        })
        v_fields = ["check_id", "level", "target", "result", "details", "source"]
        write_csv(v_path, v_fields, verification)
        output_files["verification.csv"] = str(v_path)

        write_fixtures(pkg, manifest, draft_rows, verification, output_files)
        output_files["fixtures_result.md"] = str(pkg / "data" / "fixtures_result.md")

        print(f"数据抽取: {pkg}/data/")
        print(f"  ⚠ 合并 Markdown 缺失，已生成空草案")
        print(f"  quick_lookup_draft.csv: 0 行（仅表头）")
        print(f"  verification.csv: {len(verification)} 项检查")
        print(f"  fixtures_result.md: 已生成")
        return

    sections = parse_sections(md_text)
    page_map = parse_page_comments(md_text)
    counters = new_block_counters()
    table_overrides = load_extraction_overrides(pkg)
    policies = table_overrides.get("__policies__", {})
    numeric_key_policy = policies.get("numeric_key", "keep")

    md_table_rows = extract_md_table_rows(
        md_text, sections, source_pdf, model, page_map, counters,
        numeric_key_policy=numeric_key_policy,
    )
    html_table_rows = extract_html_table_rows(
        md_text, sections, source_pdf, model, page_map, counters,
        table_overrides=table_overrides,
        numeric_key_policy=numeric_key_policy,
    )
    colon_rows = extract_colon_rows(
        md_text, sections, source_pdf, model, page_map, counters,
        numeric_key_policy=numeric_key_policy,
    )
    draft_rows = md_table_rows + html_table_rows + colon_rows

    # refine_page_numbers：用 PyMuPDF 逐页搜索，将段级定位精确定位到单页
    pdf_path = pkg / manifest.get("files", {}).get("pdf", f"{model}.pdf")
    if draft_rows:
        refine_page_numbers(draft_rows, pdf_path)
        print(f"  refine_page_numbers 定位: {len(draft_rows)} 行", file=sys.stderr)

    # TOC 树 section_path 二次修正（依赖精确定位后的 page_start）
    toc_tree = load_toc_tree(pkg)
    toc_section_warning = None
    if toc_tree:
        # 页码坐标系安全评估：仍构建 section_map（最佳信源），
        # 但如果 page_numbering 未验证，记录 warning 以供 verification
        safety = _check_page_numbering_safety(manifest)
        if safety["warning"]:
            print(f"  ⚠ page_numbering: {safety['warning']}", file=sys.stderr)
            toc_section_warning = safety["warning"]

        page_section_map = build_page_section_map(toc_tree)
        updated = 0
        for row in draft_rows:
            pg = row.get("page_start", "")
            toc_path = get_section_path(0, [], pg, page_section_map)
            if toc_path:
                row["section_path"] = toc_path
                updated += 1
        if updated:
            print(f"  TOC section_path 修正: {updated}/{len(draft_rows)} 行", file=sys.stderr)

    draft_path = pkg / "data" / "quick_lookup_draft.csv"
    write_csv(draft_path, fields, draft_rows)

    v_path = pkg / "data" / "verification.csv"
    output_files = {"quick_lookup_draft.csv": str(draft_path)}
    verification = generate_verification(pkg, manifest, cl_data, draft_rows,
                                         output_files, toc_warning=toc_section_warning)
    v_fields = ["check_id", "level", "target", "result", "details", "source"]
    write_csv(v_path, v_fields, verification)
    output_files["verification.csv"] = str(v_path)

    write_fixtures(pkg, manifest, draft_rows, verification, output_files)
    output_files["fixtures_result.md"] = str(pkg / "data" / "fixtures_result.md")

    print(f"数据抽取完成: {pkg}/data/")
    print(f"  quick_lookup_draft.csv: {len(draft_rows)} 行")
    needs_r = sum(1 for r in draft_rows if r["status"] == "needs_review")
    print(f"    needs_review: {needs_r}")
    print(f"  verification.csv: {len(verification)} 项检查")
    print(f"  fixtures_result.md: 已生成")


if __name__ == "__main__":
    main()
