#!/usr/bin/env python3
"""生成输出包结构化数据草案。

用法:
  scripts/pdf-extract-data <package>

示例:
  scripts/pdf-extract-data pdf/demo20
  scripts/pdf-extract-data pdf/demo5
"""

import csv
import json
import re
import sys
from datetime import datetime
from io import StringIO
from pathlib import Path


SECTION_RE = re.compile(r"^(#{1,3})\s+(.+)$", re.MULTILINE)
COLON_RE = re.compile(r"^(.{2,40})[：:]\s*(.{1,200})$")
MD_TABLE_SEP = re.compile(r"^\s*\|[\s\-|]+\|\s*$")


def read_manifest(pkg: Path) -> dict:
    manifest_path = pkg / "manifest.json"
    if not manifest_path.exists():
        sys.exit(f"错误：找不到 manifest.json: {manifest_path}")
    with open(manifest_path) as f:
        return json.load(f)


def read_markdown(pkg: Path, manifest: dict) -> str:
    stem = manifest.get("model", pkg.name)
    md_rel = manifest.get("files", {}).get("markdown", f"{stem}.md")
    md_path = pkg / md_rel
    if not md_path.exists():
        sys.exit(f"错误：找不到 Markdown 文件: {md_path}")
    return md_path.read_text(encoding="utf-8", errors="replace")


def read_content_lists(pkg: Path) -> list[dict]:
    """返回 [(seg_name, page_idx, elements), ...]"""
    segs_dir = pkg / "segments"
    results = []
    for seg_dir in sorted(segs_dir.iterdir()):
        if not seg_dir.is_dir():
            continue
        seg_name = seg_dir.name
        for cl_path in sorted(seg_dir.rglob("*content_list_v2.json")):
            with open(cl_path) as f:
                pages = json.load(f)
            for page_idx, elements in enumerate(pages):
                results.append((seg_name, page_idx, elements))
    return results


def parse_sections(md_text: str) -> list[tuple[int, str, str]]:
    """返回 [(line_no, level, title), ...] 按行序排列"""
    sections = []
    for m in SECTION_RE.finditer(md_text):
        level = len(m.group(1))
        title = m.group(2).strip()
        line_no = md_text[: m.start()].count("\n") + 1
        sections.append((line_no, level, title))
    return sections


def build_section_path(line_no: int, sections: list) -> str:
    path_parts = []
    for sec_line, level, title in sections:
        if sec_line <= line_no:
            if len(path_parts) >= level:
                path_parts = path_parts[: level - 1]
            path_parts.append(title)
    return " / ".join(path_parts)


def extract_colon_rows(md_text: str, sections: list, source_pdf: str, model: str):
    rows = []
    for line in md_text.split("\n"):
        line = line.strip()
        if not line:
            continue
        m = COLON_RE.match(line)
        if not m:
            continue
        key = m.group(1).strip()
        value = m.group(2).strip()
        if not key or not value:
            continue
        line_no = md_text[: md_text.find(line)].count("\n") + 1
        rows.append({
            "source_pdf": source_pdf,
            "model": model,
            "section_path": build_section_path(line_no, sections),
            "key": key,
            "value": value,
            "unit": "",
            "page_start": "",
            "page_end": "",
            "evidence_text": line[:200],
            "confidence": "low",
            "status": "needs_review",
            "notes": "colon_line",
        })
    return rows


def extract_table_rows(md_text: str, sections: list, source_pdf: str, model: str):
    rows = []
    lines = md_text.split("\n")
    i = 0
    while i < len(lines):
        stripped = lines[i].strip()
        if stripped.startswith("|") and not MD_TABLE_SEP.match(stripped):
            # Check if next line is a separator
            if i + 1 < len(lines) and MD_TABLE_SEP.match(lines[i + 1].strip()):
                header_cells = [c.strip() for c in stripped.split("|")[1:-1]]
                sep_line = i + 1
                i = sep_line + 1
                while i < len(lines) and lines[i].strip().startswith("|"):
                    if MD_TABLE_SEP.match(lines[i].strip()):
                        i += 1
                        continue
                    cells = [c.strip() for c in lines[i].strip().split("|")[1:-1]]
                    if len(cells) >= 2 and len(header_cells) >= 2:
                        key = cells[0]
                        value = " / ".join(cells[1:])
                        line_no = i + 1
                        rows.append({
                            "source_pdf": source_pdf,
                            "model": model,
                            "section_path": build_section_path(line_no, sections),
                            "key": key,
                            "value": value,
                            "unit": "",
                            "page_start": "",
                            "page_end": "",
                            "evidence_text": lines[i].strip()[:200],
                            "confidence": "medium",
                            "status": "draft",
                            "notes": "md_table",
                        })
                    i += 1
                continue
        i += 1
    return rows


def generate_verification(pkg: Path, manifest: dict, cl_data: list,
                          draft_rows: list, output_files: dict) -> list[dict]:
    checks = []
    n = 1

    def add(level, target, result, details, source):
        nonlocal n
        checks.append({"check_id": f"V{n:03d}", "level": level, "target": target,
                       "result": result, "details": details, "source": source})
        n += 1

    # manifest
    add("info", "manifest.json", "passed", "manifest 存在且合法", "manifest.json")

    # markdown
    md_rel = manifest.get("files", {}).get("markdown", "")
    md_path = pkg / md_rel if md_rel else None
    if md_path and md_path.exists():
        add("info", "markdown", "passed", f"{md_path.name} 存在", str(md_path))
    else:
        add("error", "markdown", "failed", "合并 Markdown 缺失", str(md_path or "unknown"))

    # segments
    segs_dir = pkg / "segments"
    seg_count = len([d for d in segs_dir.iterdir() if d.is_dir()]) if segs_dir.exists() else 0
    add("info", "segments", "passed" if seg_count > 0 else "failed",
        f"分段数: {seg_count}", "segments/")

    # content_list_v2
    cl_count = len(cl_data)
    cl_level = "info" if cl_count > 0 else "warning"
    cl_result = "passed" if cl_count > 0 else "needs_review"
    add(cl_level, "content_list_v2", cl_result,
        f"content_list_v2 页面数: {cl_count}", "segments/**/content_list_v2.json")

    # images
    img_dir = pkg / "images"
    img_count = len([f for f in img_dir.iterdir() if f.is_file()]) if img_dir.exists() else 0
    add("info", "images", "passed" if img_count >= 0 else "failed",
        f"图片数: {img_count}", "images/")

    # draft row stats
    draft_needs_review = sum(1 for r in draft_rows if r["status"] == "needs_review")
    draft_high = sum(1 for r in draft_rows if r["confidence"] == "high")
    draft_medium = sum(1 for r in draft_rows if r["confidence"] == "medium")
    draft_low = sum(1 for r in draft_rows if r["confidence"] == "low")
    add("info", "quick_lookup_draft", "passed" if len(draft_rows) > 0 else "info",
        f"行数: {len(draft_rows)}, needs_review: {draft_needs_review}, "
        f"high: {draft_high}, medium: {draft_medium}, low: {draft_low}",
        "data/quick_lookup_draft.csv")

    # output files written
    for name, path in output_files.items():
        if Path(path).exists():
            add("info", name, "passed", f"{name} 已生成", str(path))
        else:
            add("error", name, "failed", f"{name} 未生成", str(path))

    return checks


def write_csv(path: Path, fieldnames: list[str], rows: list[dict]):
    path.parent.mkdir(parents=True, exist_ok=True)
    with open(path, "w", newline="", encoding="utf-8") as f:
        w = csv.DictWriter(f, fieldnames=fieldnames, extrasaction="ignore")
        w.writeheader()
        w.writerows(rows)


def write_fixtures(pkg: Path, manifest: dict, draft_rows: list, verification: list,
                   output_files: dict):
    md = []
    md.append("# 数据抽取摘要")
    md.append("")
    md.append(f"生成时间: {datetime.now().strftime('%Y-%m-%d %H:%M')}")
    md.append(f"输出包: {pkg.resolve()}")
    md.append(f"车型: {manifest.get('model', 'unknown')}")
    md.append("")

    md.append("## 抽取统计")
    md.append("")
    needs_r = sum(1 for r in draft_rows if r["status"] == "needs_review")
    md.append(f"- 草案行数: {len(draft_rows)}")
    md.append(f"- 待审核: {needs_r}")

    errors = [c for c in verification if c["level"] == "error"]
    warnings = [c for c in verification if c["level"] == "warning"]
    md.append(f"- 错误: {len(errors)}")
    md.append(f"- 警告: {len(warnings)}")
    md.append("")

    if errors:
        md.append("## 错误")
        md.append("")
        for e in errors:
            md.append(f"- **{e['check_id']}** [{e['target']}]: {e['details']}")
        md.append("")

    if warnings:
        md.append("## 警告")
        md.append("")
        for w in warnings:
            md.append(f"- **{w['check_id']}** [{w['target']}]: {w['details']}")
        md.append("")

    md.append("## 可复现命令")
    md.append("")
    md.append(f"```bash")
    md.append(f"scripts/pdf-extract-data {pkg}")
    md.append(f"```")
    md.append("")

    md.append("## 输出文件")
    md.append("")
    for name, path in output_files.items():
        md.append(f"- `{name}`: {path}")

    report_path = pkg / "data" / "fixtures_result.md"
    report_path.parent.mkdir(parents=True, exist_ok=True)
    report_path.write_text("\n".join(md), encoding="utf-8")


def main():
    if len(sys.argv) != 2:
        print("用法: scripts/pdf-extract-data <package>", file=sys.stderr)
        print("示例: scripts/pdf-extract-data pdf/demo20", file=sys.stderr)
        sys.exit(1)

    pkg = Path(sys.argv[1]).resolve()
    if not pkg.is_dir():
        sys.exit(f"错误：不是目录: {pkg}")

    manifest = read_manifest(pkg)
    md_text = read_markdown(pkg, manifest)
    cl_data = read_content_lists(pkg)

    source_pdf = manifest.get("files", {}).get("pdf", manifest.get("model", "") + ".pdf")
    model = manifest.get("model", pkg.name)

    sections = parse_sections(md_text)

    # Extract drafts
    table_rows = extract_table_rows(md_text, sections, source_pdf, model)
    colon_rows = extract_colon_rows(md_text, sections, source_pdf, model)
    draft_rows = table_rows + colon_rows

    # Write quick_lookup_draft.csv
    fields = ["source_pdf", "model", "section_path", "key", "value", "unit",
              "page_start", "page_end", "evidence_text", "confidence", "status", "notes"]
    draft_path = pkg / "data" / "quick_lookup_draft.csv"
    write_csv(draft_path, fields, draft_rows)

    # Generate and write verification.csv
    v_path = pkg / "data" / "verification.csv"
    # Build output_files incrementally: draft first, then verification
    output_files = {"quick_lookup_draft.csv": str(draft_path)}
    verification = generate_verification(pkg, manifest, cl_data, draft_rows, output_files)
    v_fields = ["check_id", "level", "target", "result", "details", "source"]
    write_csv(v_path, v_fields, verification)
    output_files["verification.csv"] = str(v_path)

    # Generate fixtures_result.md
    write_fixtures(pkg, manifest, draft_rows, verification, output_files)
    output_files["fixtures_result.md"] = str(pkg / "data" / "fixtures_result.md")

    print(f"数据抽取完成: {pkg}/data/")
    print(f"  quick_lookup_draft.csv: {len(draft_rows)} 行")
    needs_r = sum(1 for r in draft_rows if r["status"] == "needs_review")
    print(f"    needs_review: {needs_r}")
    print(f"  verification.csv: {len(verification)} 项检查")
    print(f"  fixtures_result.md: 已生成")


if __name__ == "__main__":
    main()
